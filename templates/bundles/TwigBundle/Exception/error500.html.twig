{% extends 'base.html.twig' %}

{% block title %}Erreur serveur — Afdal{% endblock %}

{% block body %}
<main class="min-h-[100dvh] grid place-items-center bg-[var(--color-background,#F9FAFB)] px-4 sm:px-6 py-8 sm:py-12">
    <div class="w-full max-w-xl text-center">
        {# Illustration — engrenage en panne #}
        <div class="w-32 h-32 sm:w-44 sm:h-44 md:w-48 md:h-48 mx-auto mb-6 sm:mb-8 relative">
            <svg viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
                <circle cx="100" cy="100" r="90" fill="#FEE4E2" fill-opacity="0.5"/>

                {# Engrenage principal #}
                <g transform="translate(100 100)">
                    <g fill="#B42318">
                        {% for i in 0..7 %}
                            <rect x="-6" y="-58" width="12" height="20" rx="2" transform="rotate({{ i * 45 }})"/>
                        {% endfor %}
                    </g>
                    <circle r="42" fill="#D92D20"/>
                    <circle r="30" fill="#ffffff"/>
                    {# Éclair au centre #}
                    <path d="M-4 -14 L6 -14 L-2 0 L8 0 L-4 14 L0 2 L-8 2 Z" fill="#D92D20"/>
                </g>

                {# Petites pièces éparses pour l'effet "cassé" #}
                <circle cx="40" cy="55" r="6" fill="#D92D20" fill-opacity="0.5"/>
                <circle cx="160" cy="145" r="4" fill="#D92D20" fill-opacity="0.4"/>
                <rect x="156" y="55" width="8" height="8" rx="1" fill="#D92D20" fill-opacity="0.5" transform="rotate(25 160 59)"/>
            </svg>
        </div>

        <div class="inline-block px-3 py-1 rounded-full bg-red-50 text-red-700 text-xs font-semibold uppercase tracking-wide mb-3 sm:mb-4">
            Erreur 500
        </div>
        <h1 class="font-display text-2xl sm:text-3xl md:text-4xl font-semibold text-[var(--color-foreground)] mb-2 sm:mb-3 px-2">
            Quelque chose a cassé de notre côté
        </h1>
        <p class="text-[var(--color-body)] text-sm sm:text-base leading-relaxed max-w-md mx-auto mb-2 px-2">
            Un problème est survenu sur nos serveurs. L'équipe Afdal a été notifiée et s'en occupe.
        </p>
        <p class="text-[var(--color-secondary)] text-xs sm:text-sm mb-6 sm:mb-8 px-2">
            En attendant, tu peux réessayer dans quelques instants.
        </p>

        <div class="flex flex-col sm:flex-row items-stretch sm:items-center justify-center gap-3 sm:flex-wrap max-w-sm sm:max-w-none mx-auto">
            <a href="{{ path('app_home') }}" class="btn btn-primary justify-center">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/></svg>
                Retour à l'accueil
            </a>
            <button type="button" onclick="location.reload()" class="btn btn-outline justify-center">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99"/></svg>
                Réessayer
            </button>
        </div>
    </div>
</main>
{% endblock %}
