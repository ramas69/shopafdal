{% extends 'base.html.twig' %}

{% block title %}Page introuvable — Afdal{% endblock %}

{% block body %}
<main class="min-h-[100dvh] grid place-items-center bg-[var(--color-background,#F9FAFB)] px-4 sm:px-6 py-8 sm:py-12">
    <div class="w-full max-w-xl text-center">
        {# Illustration inline — "page perdue" avec compas brisé #}
        <div class="w-32 h-32 sm:w-44 sm:h-44 md:w-48 md:h-48 mx-auto mb-6 sm:mb-8 relative">
            <svg viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
                <circle cx="100" cy="100" r="90" fill="var(--color-primary-light)" fill-opacity="0.4"/>
                <circle cx="100" cy="100" r="68" fill="#ffffff" stroke="var(--color-primary)" stroke-width="2" stroke-dasharray="4 6" stroke-opacity="0.4"/>

                {# Aiguille cassée #}
                <g transform="rotate(35 100 100)">
                    <line x1="100" y1="100" x2="100" y2="48" stroke="var(--color-primary)" stroke-width="4" stroke-linecap="round"/>
                    <polygon points="100,42 94,56 106,56" fill="var(--color-primary)"/>
                </g>
                <g transform="rotate(-60 100 100)">
                    <line x1="100" y1="100" x2="100" y2="60" stroke="var(--color-primary-focus)" stroke-width="3" stroke-linecap="round" stroke-opacity="0.6"/>
                </g>

                <circle cx="100" cy="100" r="6" fill="var(--color-primary)"/>

                {# Étoile N/S #}
                <text x="100" y="28" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" font-weight="600" fill="var(--color-secondary,#64748B)">N</text>
                <text x="100" y="182" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" font-weight="600" fill="var(--color-secondary,#64748B)">S</text>
                <text x="22" y="105" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" font-weight="600" fill="var(--color-secondary,#64748B)">O</text>
                <text x="178" y="105" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" font-weight="600" fill="var(--color-secondary,#64748B)">E</text>
            </svg>
        </div>

        <div class="inline-block px-3 py-1 rounded-full bg-[var(--color-primary-light)] text-[var(--color-primary)] text-xs font-semibold uppercase tracking-wide mb-3 sm:mb-4">
            Erreur 404
        </div>
        <h1 class="font-display text-2xl sm:text-3xl md:text-4xl font-semibold text-[var(--color-foreground)] mb-2 sm:mb-3 px-2">
            Cette page s'est perdue
        </h1>
        <p class="text-[var(--color-body)] text-sm sm:text-base leading-relaxed max-w-md mx-auto mb-6 sm:mb-8 px-2">
            L'adresse n'existe pas (ou plus). Vérifie le lien, ou reviens à l'accueil.
        </p>

        <div class="flex flex-col sm:flex-row items-stretch sm:items-center justify-center gap-3 sm:flex-wrap max-w-sm sm:max-w-none mx-auto">
            <a href="{{ path('app_home') }}" class="btn btn-primary justify-center">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/></svg>
                Retour à l'accueil
            </a>
            <button type="button" onclick="history.back()" class="btn btn-outline justify-center">
                ← Page précédente
            </button>
        </div>
    </div>
</main>
{% endblock %}
