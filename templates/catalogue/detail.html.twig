{% extends 'dashboard/_shell.html.twig' %}

{% block title %}{{ product.name }} — Catalogue{% endblock %}

{% block content %}
<a href="{{ path('app_catalogue') }}" class="text-sm text-[var(--color-secondary)] hover:text-[var(--color-primary)] inline-flex items-center gap-1 mb-6">
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
    </svg>
    Retour au catalogue
</a>

<form method="post" action="{{ path('app_catalogue_add', {slug: product.slug}) }}"
      class="grid grid-cols-1 lg:grid-cols-2 gap-8"
      data-controller="quantities"
      data-quantities-unit-price-value="{{ product.basePriceCents }}">
    <div>
        <div class="aspect-[4/3] rounded-xl bg-gradient-to-br from-slate-100 to-slate-200 flex items-center justify-center mb-4">
            <span class="font-display text-7xl font-bold text-slate-300">{{ product.name|first|upper }}</span>
        </div>
    </div>

    <div>
        {% if product.category %}
            <div class="text-xs font-medium text-[var(--color-secondary)] uppercase tracking-wide mb-2">{{ product.category }}</div>
        {% endif %}
        <h1 class="text-3xl font-semibold text-[var(--color-primary)] mb-2">{{ product.name }}</h1>
        {% if product.material %}
            <p class="text-sm text-[var(--color-secondary)] mb-4">{{ product.material }}</p>
        {% endif %}
        {% if product.description %}
            <p class="text-[var(--color-foreground)] mb-6">{{ product.description }}</p>
        {% endif %}

        <div class="text-2xl font-semibold text-[var(--color-primary)] mb-6">{{ product.basePriceCents|price }} <span class="text-sm font-normal text-[var(--color-secondary)]">HT / pièce</span></div>

        <div class="space-y-6">
            <div>
                <h2 class="text-sm font-medium text-[var(--color-foreground)] mb-3">Couleur</h2>
                <div class="flex flex-wrap gap-3" role="radiogroup" aria-label="Couleur">
                    {% for v in variants_by_color %}
                        <label class="cursor-pointer" data-quantities-target="colorLabel">
                            <input type="radio" name="color" value="{{ loop.index0 }}" class="sr-only peer" {{ loop.first ? 'checked' }}
                                data-action="change->quantities#selectColor"
                                data-quantities-target="colorInput">
                            <div class="flex items-center gap-2 px-3 py-2 rounded-md border border-[var(--color-border)] bg-white peer-checked:border-[var(--color-primary)] peer-checked:bg-[var(--color-muted)] transition-colors duration-200 hover:bg-[var(--color-muted)]">
                                <span class="w-5 h-5 rounded-full border border-[var(--color-border)]" style="background-color: {{ v.hex }}"></span>
                                <span class="text-sm font-medium">{{ v.color }}</span>
                            </div>
                        </label>
                    {% endfor %}
                </div>
            </div>

            <div>
                <h2 class="text-sm font-medium text-[var(--color-foreground)] mb-3">Tailles & quantités</h2>
                {% for v in variants_by_color %}
                    <div class="space-y-2 {{ not loop.first ? 'hidden' : '' }}" data-quantities-target="colorPanel" data-color-index="{{ loop.index0 }}">
                        {% for size, info in v.sizes %}
                            <div class="flex items-center justify-between gap-3 p-2 rounded-md hover:bg-[var(--color-muted)]">
                                <span class="font-medium text-[var(--color-foreground)] w-12">{{ size }}</span>
                                <span class="text-xs text-[var(--color-secondary)] flex-1 font-mono">{{ info.sku }}</span>
                                <input type="number" name="quantities[{{ info.id }}]" min="0" value="0" step="1"
                                    data-action="input->quantities#recompute"
                                    data-quantities-target="qtyInput"
                                    class="w-20 px-2 py-1.5 rounded-md border border-[var(--color-border)] bg-white text-right focus-visible:outline-2 focus-visible:outline-[var(--color-ring)]">
                            </div>
                        {% endfor %}
                    </div>
                {% endfor %}
            </div>

            <details class="bg-white rounded-md border border-[var(--color-border)] p-4">
                <summary class="cursor-pointer text-sm font-medium text-[var(--color-foreground)]">Ajouter un marquage (optionnel)</summary>
                <div class="mt-4 grid grid-cols-2 gap-3">
                    <label>
                        <span class="text-xs font-medium text-[var(--color-secondary)] uppercase tracking-wide mb-1 block">Zone</span>
                        <select name="marking_zone" class="w-full px-3 py-2 rounded-md border border-[var(--color-border)] bg-white">
                            <option value="">Aucun</option>
                            <option value="poitrine">Poitrine</option>
                            <option value="dos">Dos</option>
                            <option value="manche">Manche</option>
                        </select>
                    </label>
                    <label>
                        <span class="text-xs font-medium text-[var(--color-secondary)] uppercase tracking-wide mb-1 block">Taille</span>
                        <select name="marking_size" class="w-full px-3 py-2 rounded-md border border-[var(--color-border)] bg-white">
                            <option value="A6">A6</option>
                            <option value="A5">A5</option>
                            <option value="A4" selected>A4</option>
                            <option value="A3">A3</option>
                        </select>
                    </label>
                </div>
            </details>

            <div class="bg-[var(--color-muted)] rounded-md p-4 flex items-center justify-between">
                <div>
                    <div class="text-xs text-[var(--color-secondary)] uppercase tracking-wide">Total</div>
                    <div class="text-2xl font-semibold text-[var(--color-primary)]">
                        <span data-quantities-target="totalPrice">0,00 €</span>
                    </div>
                    <div class="text-xs text-[var(--color-secondary)]"><span data-quantities-target="totalQty">0</span> pièce(s)</div>
                </div>
                <button type="submit" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md bg-[var(--color-primary)] text-[var(--color-on-primary)] font-medium cursor-pointer transition-colors duration-200 hover:bg-[var(--color-secondary)]">
                    Ajouter au panier
                </button>
            </div>
        </div>
    </div>
</form>
{% endblock %}
