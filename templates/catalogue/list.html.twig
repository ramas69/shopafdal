{% extends 'dashboard/_shell.html.twig' %}

{% block title %}Catalogue — Afdal{% endblock %}

{% block content %}
<div class="mb-8 flex flex-wrap items-end justify-between gap-4">
    <div>
        <div class="text-xs font-medium text-[var(--color-navy-400)] uppercase tracking-wide mb-1">Catalogue produits</div>
        <h1 class="font-display text-2xl font-semibold text-[var(--color-navy-700)]">{{ products|length }} produit{{ products|length > 1 ? 's' : '' }} disponible{{ products|length > 1 ? 's' : '' }}</h1>
    </div>
</div>

<form method="get" class="card mb-6 p-4 flex flex-wrap items-center gap-3">
    <div class="relative flex-1 min-w-[240px]">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-[var(--color-navy-400)] pointer-events-none" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z"/></svg>
        <input type="search" name="q" value="{{ q }}" placeholder="Rechercher un produit..."
            class="form-input pl-9">
    </div>
    <select name="category" class="form-input !w-auto min-w-[180px]">
        <option value="">Toutes catégories</option>
        {% for c in categories %}
            <option value="{{ c }}" {{ current_category == c ? 'selected' }}>{{ c }}</option>
        {% endfor %}
    </select>
    <button type="submit" class="btn btn-primary">Filtrer</button>
    {% if q or current_category %}
        <a href="{{ path('app_catalogue') }}" class="text-sm text-[var(--color-navy-400)] hover:text-[var(--color-navy-700)] px-2">Réinitialiser</a>
    {% endif %}
</form>

{% if products is empty %}
    <div class="card p-12 text-center">
        <div class="w-16 h-16 rounded-full bg-[var(--color-slate-150)] flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-[var(--color-navy-400)]" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z"/>
            </svg>
        </div>
        <h2 class="font-display text-lg font-semibold text-[var(--color-navy-700)] mb-1">Aucun produit trouvé</h2>
        <p class="text-sm text-[var(--color-navy-400)]">Essayez de modifier vos filtres ou la recherche.</p>
    </div>
{% else %}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
        {% for product in products %}
            <a href="{{ path('app_catalogue_detail', {slug: product.slug}) }}" class="card group block overflow-hidden cursor-pointer transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[var(--shadow-md)]">
                <div class="aspect-[4/3] relative overflow-hidden bg-gradient-to-br from-[var(--color-slate-150)] to-[var(--color-muted)]">
                    <div class="absolute inset-0 flex items-center justify-center">
                        <span class="font-display text-6xl font-bold text-white/80 transition-transform duration-500 group-hover:scale-110" style="-webkit-text-stroke: 2px var(--color-navy-200);">{{ product.name|first|upper }}</span>
                    </div>
                    {% if product.category %}
                        <div class="absolute top-3 left-3 tag backdrop-blur-sm bg-white/80">{{ product.category }}</div>
                    {% endif %}
                </div>
                <div class="p-5">
                    <h3 class="font-display font-semibold text-[var(--color-navy-700)] text-base mb-1 group-hover:text-[var(--color-primary)] transition-colors">{{ product.name }}</h3>
                    {% if product.material %}
                        <div class="text-xs text-[var(--color-navy-400)] mb-4">{{ product.material }}</div>
                    {% endif %}
                    <div class="flex items-baseline justify-between pt-3 border-t border-[var(--color-border-soft)]">
                        <span class="text-xs text-[var(--color-navy-400)]">À partir de</span>
                        <span class="font-display font-semibold text-lg text-[var(--color-navy-700)]">{{ product.basePriceCents|price }}</span>
                    </div>
                </div>
            </a>
        {% endfor %}
    </div>
{% endif %}
{% endblock %}
