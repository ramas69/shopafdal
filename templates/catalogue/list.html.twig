{% extends 'dashboard/_shell.html.twig' %}

{% block title %}Catalogue — Afdal{% endblock %}

{% block content %}
<div class="page-header flex flex-wrap items-end justify-between gap-4">
    <div>
        <p class="page-header__eyebrow">Catalogue</p>
        <h1 class="page-header__title">{{ products|length }} produit{{ products|length > 1 ? 's' : '' }} disponible{{ products|length > 1 ? 's' : '' }}</h1>
    </div>
</div>

{% set has_active_filters = q or current_category or current_colors|length > 0 or current_sizes|length > 0 %}
<form method="get" class="card mb-6 p-4 space-y-4" data-controller="autosubmit catalogue-filters" data-turbo-action="replace">
    <div class="flex flex-wrap items-center gap-3">
        <div class="relative flex-1 min-w-[240px]">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-[var(--color-secondary)] pointer-events-none" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z"/></svg>
            <input type="search" name="q" value="{{ q }}" placeholder="Rechercher un produit..."
                data-action="input->autosubmit#submit"
                class="form-input pl-9">
        </div>
        <select name="category" data-action="change->autosubmit#submitNow" data-controller="tom-select" class="form-input !w-auto min-w-[180px]">
            <option value="">Toutes catégories</option>
            {% for c in categories %}
                <option value="{{ c }}" {{ current_category == c ? 'selected' }}>{{ c }}</option>
            {% endfor %}
        </select>
        {% if has_active_filters %}
            <a href="{{ path('app_catalogue') }}" class="text-sm text-[var(--color-secondary)] hover:text-[var(--color-foreground)] px-2">Réinitialiser</a>
        {% endif %}
        <noscript><button type="submit" class="btn btn-primary">Filtrer</button></noscript>
    </div>

    <input type="hidden" name="colors" value="{{ current_colors|join(',') }}" data-catalogue-filters-target="colorsInput">
    <input type="hidden" name="sizes" value="{{ current_sizes|join(',') }}" data-catalogue-filters-target="sizesInput">

    {% if color_facets|length > 0 %}
        <div class="flex flex-wrap items-center gap-2">
            <span class="text-xs font-medium text-[var(--color-secondary)] uppercase tracking-wide mr-1">Couleur</span>
            {% for c in color_facets %}
                {% set active = c.name in current_colors %}
                <button type="button"
                    data-action="click->catalogue-filters#toggleColor"
                    data-value="{{ c.name }}"
                    class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs border transition-colors cursor-pointer {{ active ? 'bg-[var(--color-primary)] text-[var(--color-on-primary)] border-[var(--color-primary)]' : 'bg-white text-[var(--color-foreground)] border-[var(--color-border)] hover:border-[var(--color-primary)]' }}">
                    <span class="w-3 h-3 rounded-full border border-[var(--color-border)]" style="background-color: {{ c.hex ?: '#fff' }}"></span>
                    {{ c.name }}
                </button>
            {% endfor %}
        </div>
    {% endif %}

    {% if size_facets|length > 0 %}
        <div class="flex flex-wrap items-center gap-2">
            <span class="text-xs font-medium text-[var(--color-secondary)] uppercase tracking-wide mr-1">Taille</span>
            {% for s in size_facets %}
                {% set active = s in current_sizes %}
                <button type="button"
                    data-action="click->catalogue-filters#toggleSize"
                    data-value="{{ s }}"
                    class="inline-flex items-center justify-center min-w-[2.25rem] px-2.5 py-1 rounded-md text-xs font-semibold border transition-colors cursor-pointer {{ active ? 'bg-[var(--color-primary)] text-[var(--color-on-primary)] border-[var(--color-primary)]' : 'bg-white text-[var(--color-foreground)] border-[var(--color-border)] hover:border-[var(--color-primary)]' }}">
                    {{ s }}
                </button>
            {% endfor %}
        </div>
    {% endif %}
</form>

{% if products is empty %}
    <div class="card p-12 text-center">
        <div class="w-16 h-16 rounded-full bg-[var(--color-slate-150)] flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-[var(--color-navy-400)]" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z"/>
            </svg>
        </div>
        <h2 class="font-display text-lg font-semibold text-[var(--color-navy-700)] mb-1">Aucun produit trouvé</h2>
        <p class="text-sm text-[var(--color-navy-400)]">Essayez de modifier vos filtres ou la recherche.</p>
    </div>
{% else %}
    <div class="bg-white rounded-2xl ring-1 ring-[var(--color-border-soft)] p-5 sm:p-8">
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-x-6 gap-y-10">
            {% for product in products %}
            {% set is_out = product.isAllOutOfStock() %}
            {% set is_low = not is_out and product.hasLowStockVariant() %}
            {% set is_fav = product.id in favorited_ids %}
            {% set unique_colors = [] %}
            {% for v in product.variants %}
                {% if v.color not in unique_colors %}{% set unique_colors = unique_colors|merge([{name: v.color, hex: v.colorHex}]) %}{% endif %}
            {% endfor %}
            {% set images_list = product.imagePaths %}

            <div class="group relative flex flex-col {{ is_out ? 'opacity-70' : '' }}"
                 data-controller="product-carousel"
                 data-product-carousel-total-value="{{ images_list|length }}">
                {# Image avec coins arrondis larges #}
                <a href="{{ path('app_catalogue_detail', {slug: product.slug}) }}" class="block relative aspect-[3/4] overflow-hidden rounded-2xl bg-white ring-1 ring-[var(--color-border-soft)]">
                    {% if images_list|length > 0 %}
                        <div data-product-carousel-target="track" class="absolute inset-0 flex transition-transform duration-500 ease-out">
                            {% for img_path in images_list %}
                                <img src="{{ img_path }}"
                                     alt="{{ product.name }}"
                                     class="flex-none w-full h-full object-cover {{ is_out ? 'grayscale' : '' }}">
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="absolute inset-0 flex items-center justify-center">
                            <span class="font-display text-6xl font-bold text-slate-200">{{ product.name|first|upper }}</span>
                        </div>
                    {% endif %}

                    {# Badges stock — top-left #}
                    {% if is_out %}
                        <span class="absolute top-3 left-3 inline-flex items-center px-2.5 py-1 rounded-full text-[10px] font-semibold uppercase tracking-wider bg-[var(--color-destructive)] text-white">Rupture</span>
                    {% elseif is_low %}
                        <span class="absolute top-3 left-3 inline-flex items-center px-2.5 py-1 rounded-full text-[10px] font-semibold uppercase tracking-wider bg-amber-500 text-white">Stock limité</span>
                    {% endif %}

                    {# Favori en haut à droite — apparaît au hover #}
                    <button type="button"
                        data-controller="favorite-button"
                        data-favorite-button-url-value="{{ path('app_favorites_toggle', {id: product.id}) }}"
                        data-favorite-button-favorited-value="{{ is_fav ? 'true' : 'false' }}"
                        data-action="click->favorite-button#toggle"
                        aria-pressed="{{ is_fav ? 'true' : 'false' }}"
                        title="{{ is_fav ? 'Retirer des favoris' : 'Ajouter aux favoris' }}"
                        class="absolute top-3 right-3 w-11 h-11 rounded-full bg-white flex items-center justify-center shadow-md hover:shadow-lg hover:scale-105 transition-all opacity-0 translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 duration-200 {{ is_fav ? 'text-[var(--color-destructive)] !opacity-100 !translate-x-0' : 'text-[var(--color-foreground)]' }}">
                        <svg data-favorite-button-target="icon" class="w-5 h-5" fill="{{ is_fav ? 'currentColor' : 'none' }}" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z"/>
                        </svg>
                    </button>

                    {# Carrousel bas-gauche — uniquement si plusieurs images #}
                    {% if images_list|length > 1 %}
                        <div class="absolute bottom-3 left-3 flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity duration-200">
                            <button type="button" data-action="click->product-carousel#prev"
                                    title="Image précédente"
                                    class="w-11 h-11 rounded-full bg-white flex items-center justify-center shadow-md hover:shadow-lg hover:scale-105 transition-all text-[var(--color-foreground)]">
                                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5"/></svg>
                            </button>
                            <button type="button" data-action="click->product-carousel#next"
                                    title="Image suivante"
                                    class="w-11 h-11 rounded-full bg-[var(--color-foreground)] flex items-center justify-center shadow-md hover:shadow-lg hover:scale-105 transition-all text-white">
                                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"/></svg>
                            </button>
                        </div>
                    {% endif %}
                </a>

                {# Bloc texte sans card wrapper #}
                <div class="pt-4 flex flex-col gap-1.5">
                    {% if product.category %}
                        <p class="text-[11px] font-semibold uppercase tracking-[0.1em] text-[var(--color-secondary)]">{{ product.category }}</p>
                    {% endif %}
                    <a href="{{ path('app_catalogue_detail', {slug: product.slug}) }}" class="text-[15px] text-[var(--color-foreground)] hover:text-[var(--color-primary)] transition-colors line-clamp-2 leading-snug">
                        {{ product.name }}
                    </a>
                    <p class="font-display font-bold text-lg text-[var(--color-primary)] mt-0.5">{{ product.basePriceCents|price }}</p>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
{% endif %}
{% endblock %}
