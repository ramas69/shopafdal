{% extends 'dashboard/_shell.html.twig' %}

{% block title %}Modifier {{ order.reference }} — Mes commandes{% endblock %}

{% block content %}
<a href="{{ path('app_order_detail', {reference: order.reference}) }}" class="text-sm text-[var(--color-secondary)] hover:text-[var(--color-foreground)] mb-4 inline-block">&larr; Retour au détail</a>

<div class="mb-8">
    <div class="text-xs font-medium text-[var(--color-secondary)] uppercase tracking-wide mb-1">Modification</div>
    <h1 class="font-display text-2xl font-semibold text-[var(--color-foreground)] font-mono">{{ order.reference }}</h1>
    <p class="text-sm text-[var(--color-secondary)] mt-1">Vous pouvez ajuster les quantités, retirer des lignes, changer l'antenne ou les notes tant qu'Afdal n'a pas confirmé.</p>
</div>

<form method="post" class="space-y-6" data-controller="order-edit">
    <section class="card overflow-hidden">
        <h2 class="text-sm font-semibold text-[var(--color-foreground)] px-6 py-4 border-b border-[var(--color-border-soft)]">Articles</h2>
        <div class="divide-y divide-[var(--color-border-soft)]">
            {% for item in order.items %}
                <div class="flex items-center justify-between gap-4 p-4 transition-opacity"
                     data-order-edit-target="row"
                     data-unit-price="{{ item.unitPriceCents }}">
                    <div class="min-w-0 flex-1">
                        <div class="font-medium text-[var(--color-foreground)]">{{ item.variant.product.name }}</div>
                        <div class="text-sm text-[var(--color-secondary)] flex items-center gap-2 mt-1 flex-wrap">
                            <span class="w-3 h-3 rounded-full border border-[var(--color-border)]" style="background-color: {{ item.variant.colorHex }}"></span>
                            {{ item.variant.color }} · {{ item.variant.size }}
                            <span class="font-mono text-xs">{{ item.variant.sku }}</span>
                        </div>
                        {% if item.marking %}
                            <div class="text-xs text-[var(--color-secondary)] mt-1">Marquage : {{ item.marking.zone|capitalize }} ({{ item.marking.size }})</div>
                        {% endif %}
                    </div>
                    <div class="flex items-center gap-3">
                        <label class="flex flex-col items-center text-xs text-[var(--color-secondary)]">
                            <span class="mb-1">Qté</span>
                            <input type="number" name="quantity[{{ item.id }}]" min="0" value="{{ item.quantity }}"
                                data-action="input->order-edit#recompute"
                                class="form-input !w-20 text-center font-semibold text-[var(--color-foreground)]">
                        </label>
                        <span class="text-sm text-[var(--color-secondary)] whitespace-nowrap">×&nbsp;{{ item.unitPriceCents|price }}</span>
                        <span class="font-semibold text-[var(--color-foreground)] w-24 text-right text-sm"
                              data-order-edit-target="lineTotal">{{ (item.quantity * item.unitPriceCents)|price }}</span>
                        <label class="inline-flex items-center gap-1.5 cursor-pointer text-xs text-[var(--color-destructive)] px-2 py-1 rounded hover:bg-[var(--color-accent-light)]">
                            <input type="checkbox" name="remove[{{ item.id }}]" value="1"
                                data-action="change->order-edit#recompute"
                                class="form-checkbox !w-4 !h-4">
                            Retirer
                        </label>
                    </div>
                </div>
            {% endfor %}
        </div>
        <div class="flex justify-between items-center p-4 bg-[var(--color-muted)] border-t border-[var(--color-border-soft)]">
            <span class="text-[var(--color-secondary)]">Total HT</span>
            <span class="text-xl font-semibold text-[var(--color-primary)]" data-order-edit-target="total">{{ order.totalCents|price }}</span>
        </div>
    </section>

    <section class="card p-6">
        <h2 class="text-sm font-semibold text-[var(--color-foreground)] mb-4">Antenne de livraison</h2>
        <div class="space-y-2" role="radiogroup" aria-label="Antenne">
            {% for antenna in antennas %}
                <label class="flex items-start gap-3 p-4 rounded-md border border-[var(--color-border)] cursor-pointer hover:bg-[var(--color-muted)] transition-colors duration-200 has-[:checked]:border-[var(--color-primary)] has-[:checked]:bg-[var(--color-primary-light)]">
                    <input type="radio" name="antenna_id" value="{{ antenna.id }}" {{ order.antenna.id == antenna.id ? 'checked' }} class="mt-1">
                    <div class="flex-1">
                        <div class="font-medium text-[var(--color-foreground)]">{{ antenna.name }}</div>
                        <div class="text-sm text-[var(--color-secondary)]">{{ antenna.fullAddress }}</div>
                    </div>
                </label>
            {% endfor %}
        </div>
    </section>

    <section class="card p-6">
        <h2 class="text-sm font-semibold text-[var(--color-foreground)] mb-2">Notes</h2>
        <textarea name="notes" rows="3" placeholder="Instructions particulières…" class="form-input">{{ order.notes }}</textarea>
    </section>

    <div class="flex flex-wrap gap-3">
        <button type="submit" class="btn btn-primary">
            Enregistrer les modifications
        </button>
        <a href="{{ path('app_order_detail', {reference: order.reference}) }}" class="btn btn-outline">Annuler</a>
    </div>
</form>

{# === Bouton + modal Ajouter un article === #}
<div class="mt-6" data-controller="add-article"
     data-add-article-action-url-value="{{ path('app_order_add_item', {reference: order.reference}) }}">
    <button type="button" data-action="click->add-article#open" class="btn btn-primary">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
        Ajouter un article
    </button>

    {# Products data (JSON for the Stimulus controller) #}
    <script type="application/json" data-add-article-target="data">
    {{ available_products|map(p => {
        id: p.id,
        name: p.name,
        category: p.category ?? '',
        price: p.basePriceCents,
        image: p.images|length > 0 ? p.images|first : null,
        variants: p.variants|map(v => {
            id: v.id,
            size: v.size,
            color: v.color,
            hex: v.colorHex,
            sku: v.sku
        })|values
    })|json_encode|raw }}
    </script>

    {# Modal skeleton #}
    <div data-add-article-target="backdrop"
         data-action="click->add-article#backdropClick"
         class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-[100] items-center justify-center p-4"
         style="display:none">
        <div class="card w-full max-w-4xl max-h-[85vh] flex flex-col overflow-hidden" data-add-article-target="dialog">
            <div class="flex items-center gap-3 p-5 border-b border-[var(--color-border-soft)]">
                <button type="button" data-action="click->add-article#showList"
                        data-add-article-target="backBtn"
                        class="hidden w-9 h-9 items-center justify-center rounded-md text-[var(--color-secondary)] hover:bg-[var(--color-muted)]"
                        aria-label="Retour">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5"/></svg>
                </button>
                <h2 data-add-article-target="title" class="font-display text-lg font-semibold text-[var(--color-foreground)]">Ajouter un article</h2>
                <button type="button" data-action="click->add-article#close"
                        class="ml-auto w-9 h-9 inline-flex items-center justify-center rounded-md text-[var(--color-secondary)] hover:bg-[var(--color-muted)]"
                        aria-label="Fermer">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/></svg>
                </button>
            </div>

            {# LIST view #}
            <div data-add-article-target="listPanel" class="flex-1 overflow-y-auto p-5">
                <div class="relative mb-4">
                    <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-[var(--color-secondary)] pointer-events-none" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z"/></svg>
                    <input type="search" placeholder="Rechercher un produit..."
                           data-action="input->add-article#filter"
                           data-add-article-target="search"
                           class="form-input pl-9">
                </div>
                <div data-add-article-target="grid" class="grid grid-cols-2 md:grid-cols-3 gap-3"></div>
                <div data-add-article-target="empty" class="hidden text-center text-sm text-[var(--color-secondary)] py-8">Aucun produit trouvé.</div>
            </div>

            {# DETAIL view (filled dynamically) #}
            <form data-add-article-target="detailPanel"
                  method="post"
                  action="{{ path('app_order_add_item', {reference: order.reference}) }}"
                  class="hidden flex-1 overflow-y-auto p-5 space-y-4">
                <input type="hidden" name="variant_id" data-add-article-target="variantInput">
                <div data-add-article-target="detailContent"></div>
                <div class="flex justify-end gap-3 pt-2 border-t border-[var(--color-border-soft)]">
                    <button type="button" data-action="click->add-article#showList" class="btn btn-outline">Retour</button>
                    <button type="submit" class="btn btn-primary">Ajouter à la commande</button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}
