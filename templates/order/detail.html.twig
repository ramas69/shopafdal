{% extends 'dashboard/_shell.html.twig' %}

{% block title %}{{ order.reference }} — Mes commandes{% endblock %}

{% block content %}
<a href="{{ path('app_orders') }}" class="text-sm text-[var(--color-secondary)] hover:text-[var(--color-primary)] mb-4 inline-block">&larr; Mes commandes</a>

<div class="flex flex-wrap items-start justify-between gap-4 mb-8">
    <div>
        <div class="text-xs text-[var(--color-secondary)] uppercase tracking-wide">Commande</div>
        <h1 class="text-3xl font-mono font-semibold text-[var(--color-primary)]">{{ order.reference }}</h1>
        <p class="text-[var(--color-secondary)] mt-1">Passée le {{ (order.placedAt ?? order.createdAt)|date('d/m/Y à H:i') }}</p>
    </div>
    <div class="flex flex-wrap items-center gap-3">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-sm font-medium border {{ status_badge_class(order.status) }}">
            <span class="w-2 h-2 rounded-full {{ status_dot_class(order.status) }}"></span>
            {{ order.status.label() }}
        </span>
        {% if order.status.value == 'placed' %}
            <a href="{{ path('app_order_edit', {reference: order.reference}) }}"
               class="inline-flex items-center gap-2 px-3 py-1.5 rounded-md bg-[var(--color-primary)] text-[var(--color-on-primary)] text-sm font-medium cursor-pointer transition-colors duration-200 hover:bg-[var(--color-primary-focus)]">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L6.832 19.82a4.5 4.5 0 0 1-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 0 1 1.13-1.897L16.863 4.487Zm0 0L19.5 7.125"/>
                </svg>
                Modifier
            </a>
        {% endif %}
        <form method="post" action="{{ path('app_order_reorder', {reference: order.reference}) }}">
            <button type="submit" class="inline-flex items-center gap-2 px-3 py-1.5 rounded-md border border-[var(--color-border)] text-[var(--color-foreground)] text-sm font-medium cursor-pointer transition-colors duration-200 hover:bg-[var(--color-muted)]">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" />
                </svg>
                Commander à nouveau
            </button>
        </form>
        <a href="{{ path('app_order_export', {reference: order.reference}) }}"
           class="inline-flex items-center gap-2 px-3 py-1.5 rounded-md border border-[var(--color-border)] text-[var(--color-foreground)] text-sm font-medium cursor-pointer transition-colors duration-200 hover:bg-[var(--color-muted)]">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
            </svg>
            Exporter CSV
        </a>
        {% if can_cancel %}
            <form method="post" action="{{ path('app_order_cancel', {reference: order.reference}) }}"
                  data-controller="confirm"
                  data-confirm-title-value="Annuler la commande {{ order.reference }} ?"
                  data-confirm-message-value="La commande sera marquée comme annulée et ne sera pas traitée par Afdal. Cette action est irréversible."
                  data-confirm-label-value="Annuler la commande"
                  data-action="submit->confirm#gate">
                <button type="submit" class="inline-flex items-center gap-2 px-3 py-1.5 rounded-md border border-[var(--color-destructive)] text-[var(--color-destructive)] text-sm font-medium cursor-pointer transition-colors duration-200 hover:bg-red-50">
                    Annuler la commande
                </button>
            </form>
        {% endif %}
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 space-y-6">
        <div id="order-timeline-frame-{{ order.id }}"
             {% if order.status.value not in ['delivered', 'cancelled'] %}
             data-controller="poll"
             data-poll-url-value="{{ path('app_order_detail', {reference: order.reference}) }}"
             data-poll-interval-value="10000"
             {% endif %}>
        <section class="bg-white rounded-xl border border-[var(--color-border)] shadow-sm p-6">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-sm font-semibold text-[var(--color-primary)]">Suivi</h2>
                {% if order.status.value not in ['delivered', 'cancelled'] %}
                    <span class="inline-flex items-center gap-1.5 text-xs text-[var(--color-secondary)]">
                        <span class="relative flex w-1.5 h-1.5">
                            <span class="absolute inline-flex w-full h-full rounded-full bg-[var(--color-success)] opacity-60 animate-ping"></span>
                            <span class="relative inline-flex rounded-full w-1.5 h-1.5 bg-[var(--color-success)]"></span>
                        </span>
                        Mise à jour auto
                    </span>
                {% endif %}
            </div>
            {% if order.status.value == 'cancelled' %}
                <div class="flex items-start gap-3 p-4 rounded-md bg-red-50 border border-red-200">
                    <div class="w-8 h-8 rounded-full bg-[var(--color-destructive)] flex items-center justify-center flex-shrink-0">
                        <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/></svg>
                    </div>
                    <div class="flex-1">
                        <div class="flex items-center justify-between gap-3 flex-wrap">
                            <div class="font-medium text-[var(--color-destructive)]">Commande annulée</div>
                            {% if order.cancelledAt %}
                                <time datetime="{{ order.cancelledAt|date('c') }}" class="text-xs text-[var(--color-secondary)] font-mono">{{ order.cancelledAt|date('d/m/Y à H:i') }}</time>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% else %}
                <ol class="relative">
                    {% for step in timeline %}
                        {% set is_last = loop.last %}
                        <li class="flex gap-4 {{ not is_last ? 'pb-6' : '' }} relative">
                            {% if not is_last %}
                                <div class="absolute left-4 top-8 bottom-0 w-px {{ step.state == 'done' ? 'bg-emerald-400' : 'bg-[var(--color-border)]' }}"></div>
                            {% endif %}
                            <div class="relative z-10 w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0 {{ step.state == 'done' ? 'bg-emerald-500' : step.state == 'current' ? 'bg-[var(--color-primary)] ring-4 ring-[var(--color-primary-light)]' : 'bg-[var(--color-muted)] border border-[var(--color-border)]' }}">
                                {% if step.state == 'done' %}
                                    <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                                {% elseif step.state == 'current' %}
                                    <div class="w-2 h-2 rounded-full bg-white"></div>
                                {% endif %}
                            </div>
                            <div class="pt-1 flex-1">
                                <div class="flex items-center justify-between gap-3 flex-wrap">
                                    <div class="font-medium {{ step.state == 'upcoming' ? 'text-[var(--color-secondary)]' : 'text-[var(--color-foreground)]' }}">{{ step.status.label() }}</div>
                                    {% if step.at %}
                                        <time datetime="{{ step.at|date('c') }}" class="text-xs text-[var(--color-secondary)] font-mono">
                                            {{ step.at|date('d/m/Y à H:i') }}
                                        </time>
                                    {% endif %}
                                </div>
                                {% if step.state == 'current' %}
                                    <div class="text-xs text-[var(--color-primary)] mt-0.5 font-medium">Étape en cours</div>
                                {% elseif step.state == 'upcoming' %}
                                    <div class="text-xs text-[var(--color-secondary)] mt-0.5">À venir</div>
                                {% endif %}
                            </div>
                        </li>
                    {% endfor %}
                </ol>
            {% endif %}
        </section>
        </div>

        <section class="bg-white rounded-xl border border-[var(--color-border)] shadow-sm overflow-hidden">
            <h2 class="text-sm font-semibold text-[var(--color-primary)] px-6 py-4 border-b border-[var(--color-border)]">Articles</h2>
            <div class="divide-y divide-[var(--color-border)]">
                {% for item in order.items %}
                    <div class="flex items-center justify-between gap-4 p-4">
                        <div class="min-w-0 flex-1">
                            <div class="font-medium text-[var(--color-foreground)]">{{ item.variant.product.name }}</div>
                            <div class="text-sm text-[var(--color-secondary)] flex items-center gap-2 mt-1 flex-wrap">
                                <span class="w-3 h-3 rounded-full border border-[var(--color-border)]" style="background-color: {{ item.variant.colorHex }}"></span>
                                {{ item.variant.color }} · {{ item.variant.size }}
                                <span class="font-mono text-xs">{{ item.variant.sku }}</span>
                            </div>
                            {% if item.marking %}
                                <div class="text-xs text-[var(--color-secondary)] mt-1">Marquage : {{ item.marking.zone|capitalize }} ({{ item.marking.size }})</div>
                            {% endif %}
                        </div>
                        <div class="text-right">
                            <div class="text-sm text-[var(--color-secondary)]">{{ item.quantity }} × {{ item.unitPriceCents|price }}</div>
                            <div class="font-semibold">{{ (item.quantity * item.unitPriceCents)|price }}</div>
                        </div>
                    </div>
                {% endfor %}
            </div>
            <div class="flex justify-between items-center p-4 bg-[var(--color-muted)] border-t border-[var(--color-border)]">
                <span class="text-[var(--color-secondary)]">Total HT</span>
                <span class="text-xl font-semibold text-[var(--color-primary)]">{{ order.totalCents|price }}</span>
            </div>
        </section>

        {% if order.notes %}
            <section class="bg-white rounded-xl border border-[var(--color-border)] shadow-sm p-6">
                <h2 class="text-sm font-semibold text-[var(--color-primary)] mb-2">Vos notes</h2>
                <p class="text-[var(--color-foreground)] whitespace-pre-line">{{ order.notes }}</p>
            </section>
        {% endif %}
    </div>

    <aside class="space-y-6">
        <section class="bg-white rounded-xl border border-[var(--color-border)] shadow-sm p-6">
            <h2 class="text-sm font-semibold text-[var(--color-primary)] mb-3">Livraison</h2>
            <div class="font-medium text-[var(--color-foreground)]">{{ order.antenna.name }}</div>
            <div class="text-sm text-[var(--color-secondary)]">{{ order.antenna.fullAddress }}</div>
            {% if order.antenna.phone %}<div class="text-sm text-[var(--color-secondary)] mt-1">{{ order.antenna.phone }}</div>{% endif %}
        </section>

        <section class="bg-white rounded-xl border border-[var(--color-border)] shadow-sm p-6">
            <h2 class="text-sm font-semibold text-[var(--color-primary)] mb-3">Informations</h2>
            <dl class="text-sm space-y-2">
                <div class="flex justify-between">
                    <dt class="text-[var(--color-secondary)]">Commandée par</dt>
                    <dd class="text-[var(--color-foreground)]">{{ order.createdBy.fullName }}</dd>
                </div>
                <div class="flex justify-between">
                    <dt class="text-[var(--color-secondary)]">Articles</dt>
                    <dd class="text-[var(--color-foreground)]">{{ order.totalQuantity }} pièces</dd>
                </div>
                {% if order.updatedAt %}
                    <div class="flex justify-between">
                        <dt class="text-[var(--color-secondary)]">Dernier MAJ</dt>
                        <dd class="text-[var(--color-foreground)]">{{ order.updatedAt|date('d/m/Y') }}</dd>
                    </div>
                {% endif %}
            </dl>
        </section>
    </aside>
</div>
{% endblock %}
