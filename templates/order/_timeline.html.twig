{# Shared order events timeline — client & admin #}
{# Required vars: events, is_admin #}

{% set event_config = {
    'created':          {title: 'Commande créée',       bg: '#DBEAFE', fg: '#2563EB'},
    'status_changed':   {title: 'Statut mis à jour',    bg: '#D1FAE5', fg: '#059669'},
    'items_edited':     {title: 'Articles modifiés',    bg: '#FEF3C7', fg: '#B45309'},
    'antenna_changed':  {title: 'Antenne changée',      bg: '#E0E7FF', fg: '#4F46E5'},
    'notes_updated':    {title: 'Notes mises à jour',   bg: '#FEF3C7', fg: '#B45309'},
    'cancelled':        {title: 'Commande annulée',     bg: '#FEE2E2', fg: '#DC2626'},
    'admin_note':       {title: 'Note admin',           bg: '#F3E8FF', fg: '#7E22CE'},
    'bat_uploaded':     {title: 'BAT envoyé',           bg: '#FEF3C7', fg: '#B45309'},
    'bat_approved':     {title: 'BAT validé',           bg: '#D1FAE5', fg: '#059669'},
    'bat_rejected':     {title: 'BAT refusé',           bg: '#FEE2E2', fg: '#DC2626'},
    'shipping_updated': {title: 'Livraison mise à jour',bg: '#DBEAFE', fg: '#2563EB'},
} %}

<ol class="relative">
    {% for event in events %}
        {% set cfg = event_config[event.type]|default({title: event.summary, bg: '#F1F5F9', fg: '#64748B'}) %}
        {% set is_admin_evt = event.adminEvent() %}
        <li class="relative flex gap-4 pb-6 last:pb-0">
            {# Connector line #}
            {% if not loop.last %}
                <span class="absolute left-4 top-9 bottom-0 w-px bg-[var(--color-border-soft)]" aria-hidden="true"></span>
            {% endif %}

            {# Icon dot #}
            <div class="relative z-10 flex h-8 w-8 shrink-0 items-center justify-center rounded-full" style="background-color: {{ cfg.bg }}; color: {{ cfg.fg }};">
                {% if event.type == 'created' %}
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
                {% elseif event.type == 'status_changed' or event.type == 'bat_approved' %}
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                {% elseif event.type == 'items_edited' or event.type == 'notes_updated' or event.type == 'admin_note' %}
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L6.832 19.82a4.5 4.5 0 0 1-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 0 1 1.13-1.897L16.863 4.487Z"/></svg>
                {% elseif event.type == 'cancelled' or event.type == 'bat_rejected' %}
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/></svg>
                {% elseif event.type == 'bat_uploaded' %}
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 3m0 0 4.5 4.5M12 3v13.5"/></svg>
                {% elseif event.type == 'antenna_changed' %}
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/></svg>
                {% elseif event.type == 'shipping_updated' %}
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25"/></svg>
                {% else %}
                    <div class="w-2 h-2 rounded-full bg-current"></div>
                {% endif %}
            </div>

            {# Content #}
            <div class="flex-1 min-w-0 flex items-start justify-between gap-3">
                <div class="min-w-0 flex-1">
                    <div class="text-sm font-semibold text-[var(--color-foreground)] leading-snug">{{ cfg.title }}</div>
                    <div class="text-sm text-[var(--color-secondary)] mt-0.5">{{ event.summary }}</div>

                    {# Actor chip #}
                    {% if event.actor %}
                        {% set actor_initials = event.actor.fullName|split(' ')|slice(0, 2)|map(w => w|first)|join('')|upper %}
                        <div class="mt-2 inline-flex items-center gap-3 rounded-full bg-[var(--color-muted)] pl-2 pr-5 py-2">
                            <span class="rounded-full text-white shrink-0" style="display: inline-flex; align-items: center; justify-content: center; width: 32px; height: 32px; min-width: 32px; font-size: 11px; font-weight: 700; line-height: 1; letter-spacing: 0; white-space: nowrap; font-family: system-ui, -apple-system, 'Segoe UI', sans-serif; background: linear-gradient(135deg, {{ cfg.fg }}, {{ cfg.bg }});">{{ actor_initials }}</span>
                            <span class="text-xs font-medium text-[var(--color-foreground)]">
                                {% if is_admin_evt %}Afdal · {{ event.actor.fullName }}{% else %}{{ event.actor.fullName }}{% endif %}
                            </span>
                        </div>
                    {% endif %}

                    {# Items edited detail #}
                    {% if event.type == 'items_edited' and event.data %}
                        <details class="mt-2">
                            <summary class="text-xs font-medium cursor-pointer hover:underline" style="color: {{ cfg.fg }};">Voir le détail</summary>
                            <div class="mt-2 space-y-1 text-xs text-[var(--color-secondary)] pl-3 border-l-2" style="border-color: {{ cfg.bg }};">
                                {% for item in event.data.removed|default([]) %}
                                    <div><span class="text-[var(--color-destructive)] font-semibold">−</span> {{ item.label }} (était {{ item.qty }})</div>
                                {% endfor %}
                                {% for item in event.data.changed|default([]) %}
                                    <div>{{ item.label }} : {{ item.from }} → <strong class="text-[var(--color-foreground)]">{{ item.to }}</strong></div>
                                {% endfor %}
                                {% for item in event.data.added|default([]) %}
                                    <div><span class="text-emerald-600 font-semibold">+</span> {{ item.label }} ({{ item.qty }})</div>
                                {% endfor %}
                            </div>
                        </details>
                    {% endif %}
                </div>
                <span class="shrink-0 text-xs text-[var(--color-secondary)] whitespace-nowrap" title="{{ event.createdAt|date('d/m/Y à H:i') }}">{{ event.createdAt|time_ago }}</span>
            </div>
        </li>
    {% endfor %}
</ol>
