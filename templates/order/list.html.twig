{% extends 'dashboard/_shell.html.twig' %}

{% block title %}Mes commandes — Afdal{% endblock %}

{% block content %}
<div class="mb-8 flex flex-wrap items-start justify-between gap-4">
    <div>
        <h1 class="text-3xl font-semibold text-[var(--color-primary)] mb-2">Mes commandes</h1>
        <p class="text-[var(--color-secondary)]">{{ orders|length }} commande{{ orders|length > 1 ? 's' : '' }} pour {{ app.user.company.name }}.</p>
    </div>
    <a href="{{ path('app_orders_export', app.request.query.all) }}" class="inline-flex items-center gap-2 px-4 py-2 rounded-md border border-[var(--color-border)] text-sm font-medium cursor-pointer transition-colors duration-200 hover:bg-[var(--color-muted)]">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
        </svg>
        Exporter tout {{ orders|length > 0 ? '(' ~ orders|length ~ ')' : '' }}
    </a>
</div>

<form method="get" class="mb-6 flex flex-wrap items-end gap-3 bg-white rounded-xl border border-[var(--color-border)] shadow-sm p-4">
    <label>
        <span class="text-xs font-medium text-[var(--color-secondary)] uppercase tracking-wide mb-1.5 block">Statut</span>
        <select name="status" class="px-3 py-2 rounded-md border border-[var(--color-border)] bg-white focus-visible:outline-2 focus-visible:outline-[var(--color-ring)]">
            <option value="">Tous</option>
            {% for s in statuses %}
                <option value="{{ s.value }}" {{ current_status == s.value ? 'selected' }}>{{ s.label() }}</option>
            {% endfor %}
        </select>
    </label>
    {% if antennas|length > 1 %}
        <label>
            <span class="text-xs font-medium text-[var(--color-secondary)] uppercase tracking-wide mb-1.5 block">Antenne</span>
            <select name="antenna" class="px-3 py-2 rounded-md border border-[var(--color-border)] bg-white focus-visible:outline-2 focus-visible:outline-[var(--color-ring)]">
                <option value="">Toutes</option>
                {% for a in antennas %}
                    <option value="{{ a.id }}" {{ current_antenna == a.id ? 'selected' }}>{{ a.name }}</option>
                {% endfor %}
            </select>
        </label>
    {% endif %}
    <button type="submit" class="inline-flex items-center gap-2 px-4 py-2 rounded-md bg-[var(--color-primary)] text-[var(--color-on-primary)] text-sm font-medium cursor-pointer transition-colors duration-200 hover:bg-[var(--color-secondary)]">
        Filtrer
    </button>
    {% if current_status or current_antenna %}
        <a href="{{ path('app_orders') }}" class="text-sm text-[var(--color-secondary)] hover:text-[var(--color-primary)]">Réinitialiser</a>
    {% endif %}
</form>

{% if orders is empty %}
    <div class="bg-white rounded-xl border border-[var(--color-border)] shadow-sm p-12 text-center">
        <h2 class="text-lg font-semibold text-[var(--color-primary)] mb-1">Aucune commande</h2>
        <p class="text-sm text-[var(--color-secondary)] mb-6">Passez votre première commande depuis le catalogue.</p>
        <a href="{{ path('app_catalogue') }}" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md bg-[var(--color-primary)] text-[var(--color-on-primary)] font-medium cursor-pointer transition-colors duration-200 hover:bg-[var(--color-secondary)]">Voir le catalogue</a>
    </div>
{% else %}
    <div data-controller="selection"
         data-selection-export-base-value="{{ path('app_orders_export') }}">

        <div data-selection-target="bar" class="hidden mb-3 flex items-center justify-between gap-3 p-3 rounded-md bg-[var(--color-muted)] border border-[var(--color-border)]">
            <span class="text-sm text-[var(--color-foreground)]"><strong data-selection-target="counter">0</strong> commande(s) sélectionnée(s)</span>
            <a data-selection-target="exportLink" href="{{ path('app_orders_export') }}" class="inline-flex items-center gap-2 px-3 py-1.5 rounded-md bg-[var(--color-primary)] text-[var(--color-on-primary)] text-sm font-medium cursor-pointer transition-colors duration-200 hover:bg-[var(--color-secondary)]">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
                </svg>
                Exporter la sélection
            </a>
        </div>

        <div class="bg-white rounded-xl border border-[var(--color-border)] shadow-sm overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead class="bg-[var(--color-muted)] text-left text-xs uppercase tracking-wide text-[var(--color-secondary)]">
                        <tr>
                            <th class="px-4 py-3 w-10">
                                <input type="checkbox" data-selection-target="selectAll" data-action="change->selection#toggleAll"
                                    aria-label="Tout sélectionner"
                                    class="rounded border-[var(--color-border)] cursor-pointer">
                            </th>
                            <th class="px-4 py-3 font-medium">Référence</th>
                            <th class="px-4 py-3 font-medium">Date</th>
                            <th class="px-4 py-3 font-medium">Antenne</th>
                            <th class="px-4 py-3 font-medium">Articles</th>
                            <th class="px-4 py-3 font-medium">Total HT</th>
                            <th class="px-4 py-3 font-medium">Statut</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-[var(--color-border)]">
                        {% for order in orders %}
                            <tr class="relative hover:bg-[var(--color-muted)] focus-within:bg-[var(--color-muted)]">
                                <td class="px-4 py-3">
                                    <input type="checkbox" value="{{ order.id }}"
                                        data-selection-target="checkbox"
                                        data-action="change->selection#update"
                                        aria-label="Sélectionner commande {{ order.reference }}"
                                        class="relative z-20 rounded border-[var(--color-border)] cursor-pointer">
                                </td>
                                <td class="px-4 py-3 font-mono font-medium text-[var(--color-primary)]">
                                    <a href="{{ path('app_order_detail', {reference: order.reference}) }}"
                                       class="before:absolute before:inset-0 before:content-[''] focus-visible:outline-none focus-visible:before:outline-2 focus-visible:before:outline-[var(--color-ring)] focus-visible:before:outline-offset-[-2px]"
                                       aria-label="Voir la commande {{ order.reference }}">
                                        {{ order.reference }}
                                    </a>
                                </td>
                                <td class="px-4 py-3 text-[var(--color-secondary)]">{{ (order.placedAt ?? order.createdAt)|date('d/m/Y') }}</td>
                                <td class="px-4 py-3">{{ order.antenna.name }}</td>
                                <td class="px-4 py-3 text-[var(--color-secondary)]">{{ order.totalQuantity }} pc</td>
                                <td class="px-4 py-3 font-medium">{{ order.totalCents|price }}</td>
                                <td class="px-4 py-3">
                                    <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full text-xs font-medium border {{ status_badge_class(order.status) }}">
                                        <span class="w-1.5 h-1.5 rounded-full {{ status_dot_class(order.status) }}"></span>
                                        {{ order.status.label() }}
                                    </span>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endif %}
{% endblock %}
