{% extends 'dashboard/_shell.html.twig' %}

{% block title %}Catalogue — Afdal{% endblock %}

{% block content %}
<div class="mb-10">
    <div class="text-xs font-medium text-[var(--color-secondary)] uppercase tracking-wide mb-2">Bonjour</div>
    <h1 class="font-display text-4xl md:text-5xl font-semibold tracking-tight bg-gradient-to-br from-[var(--color-primary)] via-[var(--color-primary)] to-[var(--color-primary)]/60 bg-clip-text text-transparent">{{ app.user.fullName|split(' ')|first }}</h1>
    <p class="text-[var(--color-secondary)] mt-1">Espace {{ app.user.company.name }}.</p>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-3">
    {% set cards = [
        { label: 'Mes antennes', value: app.user.company.antennas|length, icon: 'pin' },
        { label: 'Commandes totales', value: app.user.company.orders|length, icon: 'list' },
    ] %}
    {% for card in cards %}
        <div class="relative overflow-hidden p-5 rounded-xl bg-[var(--color-surface)] border border-[var(--color-border-soft)] group transition-all hover:border-[var(--color-border)] hover:shadow-[var(--shadow-md)]">
            <span aria-hidden="true" class="pointer-events-none absolute -right-8 -top-8 w-20 h-20 rounded-full bg-[var(--color-muted)]/60 transition-transform duration-300 group-hover:scale-110"></span>
            <div class="relative flex items-start justify-between mb-4">
                <div class="text-xs font-medium text-[var(--color-secondary)] uppercase tracking-wide">{{ card.label }}</div>
                <div class="w-7 h-7 rounded-md bg-[var(--color-surface)] flex items-center justify-center text-[var(--color-secondary)] border border-[var(--color-border-soft)]">
                    {% if card.icon == 'pin' %}
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/></svg>
                    {% else %}
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/></svg>
                    {% endif %}
                </div>
            </div>
            <div class="relative font-display text-3xl md:text-4xl font-semibold tracking-tight text-[var(--color-primary)]">{{ card.value }}</div>
        </div>
    {% endfor %}
    <div class="relative overflow-hidden p-5 rounded-xl bg-[var(--color-surface)] border border-[var(--color-border-soft)]">
        <div class="text-xs font-medium text-[var(--color-secondary)] uppercase tracking-wide mb-4">Statut compte</div>
        <div class="inline-flex items-center gap-2 font-display text-lg font-medium text-emerald-700">
            <span class="relative flex w-2 h-2">
                <span class="absolute inline-flex w-full h-full rounded-full bg-emerald-500 opacity-60 animate-ping"></span>
                <span class="relative inline-flex rounded-full w-2 h-2 bg-emerald-500"></span>
            </span>
            Actif
        </div>
        <p class="text-sm text-[var(--color-secondary)] mt-2">Accès depuis {{ app.user.createdAt|date('m/Y') }}</p>
    </div>
</div>
{% endblock %}
