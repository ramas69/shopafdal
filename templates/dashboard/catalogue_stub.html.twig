{% extends 'dashboard/_shell.html.twig' %}

{% block title %}Catalogue — Afdal{% endblock %}

{% block content %}
<div class="mb-4 sm:mb-5">
    <p class="text-xs font-medium uppercase tracking-wider text-[var(--color-secondary)]">Tableau de bord</p>
    <h1 class="mt-1 font-display text-xl sm:text-2xl font-semibold tracking-tight text-[var(--color-foreground)]">
        Bonjour, {{ app.user.fullName|split(' ')|first }}
    </h1>
    <p class="mt-1 text-sm text-[var(--color-secondary)]">Espace {{ app.user.company.name }}</p>
</div>

<div class="dashboard-grid">
    <div class="card col-span-12 flex flex-col overflow-hidden sm:col-span-6 xl:col-span-4">
        <div class="flex items-start justify-between gap-3 p-4 sm:p-5">
            <div class="min-w-0">
                <p class="lineone-stat-label">Mes antennes</p>
                <p class="lineone-stat-value mt-2 text-[var(--color-primary)]">{{ app.user.company.antennas|length }}</p>
            </div>
            <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-[var(--color-primary)]/10 text-[var(--color-primary)]">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/></svg>
            </div>
        </div>
        <div class="h-1 bg-gradient-to-r from-[var(--color-primary)]/50 to-transparent"></div>
    </div>

    <div class="card col-span-12 flex flex-col overflow-hidden sm:col-span-6 xl:col-span-4">
        <div class="flex items-start justify-between gap-3 p-4 sm:p-5">
            <div class="min-w-0">
                <p class="lineone-stat-label">Commandes totales</p>
                <p class="lineone-stat-value mt-2">{{ app.user.company.orders|length }}</p>
            </div>
            <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-[var(--color-info)]/10 text-[var(--color-info)]">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/></svg>
            </div>
        </div>
        <div class="h-1 bg-gradient-to-r from-[var(--color-info)]/40 to-transparent"></div>
    </div>

    <div class="card col-span-12 flex flex-col overflow-hidden sm:col-span-6 xl:col-span-4">
        <div class="flex items-start justify-between gap-3 p-4 sm:p-5">
            <div class="min-w-0">
                <p class="lineone-stat-label">Compte</p>
                <p class="mt-2 flex items-center gap-2 font-display text-lg font-semibold text-[var(--color-success)]">
                    <span class="relative flex h-2 w-2">
                        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[var(--color-success)] opacity-60"></span>
                        <span class="relative inline-flex h-2 w-2 rounded-full bg-[var(--color-success)]"></span>
                    </span>
                    Actif
                </p>
            </div>
            <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-[var(--color-success)]/10 text-[var(--color-success)]">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z"/></svg>
            </div>
        </div>
        <p class="border-t border-[var(--color-border)] px-4 py-2 text-xs text-[var(--color-secondary)] sm:px-5">Membre depuis {{ app.user.createdAt|date('m/Y') }}</p>
    </div>

    <div class="card col-span-12 p-4 sm:p-5">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h2 class="font-display text-base font-semibold text-[var(--color-foreground)]">Catalogue produits</h2>
                <p class="mt-0.5 text-sm text-[var(--color-secondary)]">Parcourez les articles et passez commande.</p>
            </div>
            <a href="{{ path('app_catalogue') }}" class="btn btn-primary shrink-0 justify-center">
                Ouvrir le catalogue
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
            </a>
        </div>
    </div>
</div>
{% endblock %}
