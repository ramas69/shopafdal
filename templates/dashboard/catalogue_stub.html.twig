{% extends 'dashboard/_shell.html.twig' %}

{% block title %}Catalogue — Afdal{% endblock %}

{% block content %}
<div class="mb-10">
    <div class="text-xs font-medium text-[var(--color-secondary)] uppercase tracking-wide mb-2">Bonjour</div>
    <h1 class="font-display text-4xl font-semibold text-[var(--color-primary)] tracking-tight">{{ app.user.fullName|split(' ')|first }}</h1>
    <p class="text-[var(--color-secondary)] mt-1">Espace {{ app.user.company.name }}.</p>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-3">
    <div class="p-5 rounded-xl bg-[var(--color-surface)] border border-[var(--color-border-soft)]">
        <div class="text-xs font-medium text-[var(--color-secondary)] uppercase tracking-wide mb-3">Mes antennes</div>
        <div class="font-display text-4xl font-semibold tracking-tight text-[var(--color-primary)]">{{ app.user.company.antennas|length }}</div>
    </div>
    <div class="p-5 rounded-xl bg-[var(--color-surface)] border border-[var(--color-border-soft)]">
        <div class="text-xs font-medium text-[var(--color-secondary)] uppercase tracking-wide mb-3">Commandes totales</div>
        <div class="font-display text-4xl font-semibold tracking-tight text-[var(--color-primary)]">{{ app.user.company.orders|length }}</div>
    </div>
    <div class="p-5 rounded-xl bg-[var(--color-surface)] border border-[var(--color-border-soft)]">
        <div class="text-xs font-medium text-[var(--color-secondary)] uppercase tracking-wide mb-3">Statut</div>
        <div class="inline-flex items-center gap-2 font-display text-lg font-medium text-emerald-700">
            <span class="relative flex w-2 h-2">
                <span class="absolute inline-flex w-full h-full rounded-full bg-emerald-500 opacity-60 animate-ping"></span>
                <span class="relative inline-flex rounded-full w-2 h-2 bg-emerald-500"></span>
            </span>
            Actif
        </div>
    </div>
</div>
{% endblock %}
