{% extends 'base.html.twig' %}

{% block body %}
<div class="min-h-screen flex flex-col">
    <header class="h-16 border-b border-[var(--color-border)] bg-white">
        <div class="h-full max-w-7xl mx-auto px-6 flex items-center justify-between">
            <a href="{{ path('app_dashboard') }}" class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-md bg-[var(--color-primary)] text-[var(--color-on-primary)] flex items-center justify-center font-display font-bold">A</div>
                <span class="font-display font-semibold text-[var(--color-foreground)]">Afdal</span>
            </a>

            <div class="flex items-center gap-4">
                <div class="text-right hidden sm:block">
                    <div class="text-sm font-medium text-[var(--color-foreground)]">{{ app.user.fullName }}</div>
                    <div class="text-xs text-[var(--color-secondary)]">
                        {% if app.user.isAdmin() %}
                            Admin Afdal
                        {% else %}
                            {{ app.user.company.name }}
                        {% endif %}
                    </div>
                </div>
                <a href="{{ path('app_logout') }}" class="inline-flex items-center gap-2 px-3 py-1.5 rounded-md border border-[var(--color-border)] text-sm text-[var(--color-foreground)] cursor-pointer transition-colors duration-200 hover:bg-[var(--color-muted)]">
                    Déconnexion
                </a>
            </div>
        </div>
    </header>

    <main class="flex-1 max-w-7xl w-full mx-auto px-6 py-8">
        {% block content %}{% endblock %}
    </main>
</div>
{% endblock %}
