{% extends 'base.html.twig' %}

{% set is_admin = app.user.isAdmin() %}

{% set nav_items = is_admin ? [
    { route: 'app_admin', label: 'Dashboard' },
    { route: 'app_admin_invitations', label: 'Invitations' },
] : [
    { route: 'app_catalogue', label: 'Catalogue' },
    { route: 'app_orders', label: 'Mes commandes' },
    { route: 'app_antennas', label: 'Mes antennes' },
    { route: 'app_settings', label: 'Paramètres' },
] %}

{% macro nav_link(item, current_route) %}
    {% set is_active = current_route == item.route or (current_route starts with item.route and item.route != 'app_admin' and item.route != 'app_catalogue') or current_route == item.route %}
    <a href="{{ path(item.route) }}" class="flex items-center justify-between gap-3 px-3 py-2 rounded-md text-sm font-medium cursor-pointer transition-colors duration-200 {{ is_active ? 'bg-[var(--color-muted)] text-[var(--color-primary)]' : 'text-[var(--color-secondary)] hover:bg-[var(--color-muted)] hover:text-[var(--color-primary)]' }}">
        <span>{{ item.label }}</span>
        {% if item.badge is defined and item.badge > 0 %}
            <span class="inline-flex items-center justify-center min-w-5 h-5 px-1.5 text-xs font-medium rounded-full bg-[var(--color-accent)] text-white">{{ item.badge }}</span>
        {% endif %}
    </a>
{% endmacro %}

{% block body %}
<div class="min-h-screen flex flex-col" data-controller="drawer">
    <header class="h-16 border-b border-[var(--color-border)] bg-white sticky top-0 z-30">
        <div class="h-full px-4 md:px-6 flex items-center justify-between gap-4">
            <div class="flex items-center gap-3">
                <button type="button" data-action="drawer#open" aria-label="Ouvrir le menu"
                    class="lg:hidden p-2 -ml-2 rounded-md cursor-pointer hover:bg-[var(--color-muted)]">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
                    </svg>
                </button>
                <a href="{{ path('app_dashboard') }}" class="flex items-center gap-2">
                    <div class="w-8 h-8 rounded-md bg-[var(--color-primary)] text-[var(--color-on-primary)] flex items-center justify-center font-display font-bold">A</div>
                    <span class="font-display font-semibold text-[var(--color-foreground)] hidden sm:inline">Afdal</span>
                </a>
            </div>

            <div class="flex items-center gap-2 sm:gap-4">
                {% if not is_admin %}
                    <a href="{{ path('app_cart') }}" class="relative p-2 rounded-md cursor-pointer hover:bg-[var(--color-muted)]" aria-label="Panier">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" />
                        </svg>
                        {% if cart.count > 0 %}
                            <span class="absolute -top-0.5 -right-0.5 inline-flex items-center justify-center min-w-[18px] h-[18px] px-1 text-[10px] font-semibold rounded-full bg-[var(--color-accent)] text-white">{{ cart.count }}</span>
                        {% endif %}
                    </a>
                {% endif %}
                <div class="text-right hidden md:block">
                    <div class="text-sm font-medium text-[var(--color-foreground)]">{{ app.user.fullName }}</div>
                    <div class="text-xs text-[var(--color-secondary)]">
                        {% if is_admin %}Admin Afdal{% else %}{{ app.user.company.name }}{% endif %}
                    </div>
                </div>
                <a href="{{ path('app_logout') }}" class="inline-flex items-center gap-2 px-3 py-1.5 rounded-md border border-[var(--color-border)] text-sm text-[var(--color-foreground)] cursor-pointer transition-colors duration-200 hover:bg-[var(--color-muted)]">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9" />
                    </svg>
                    <span class="hidden sm:inline">Déconnexion</span>
                </a>
            </div>
        </div>
    </header>

    <div class="flex-1 flex relative">
        {# Mobile drawer backdrop #}
        <div data-drawer-target="backdrop" data-action="click->drawer#close"
             class="lg:hidden fixed inset-0 bg-black/40 z-40 transition-opacity duration-200 opacity-0 pointer-events-none"></div>

        {# Sidebar : fixed drawer on mobile, sticky on desktop #}
        <aside data-drawer-target="panel"
               class="fixed lg:sticky top-0 lg:top-16 left-0 z-50 lg:z-auto h-screen lg:h-[calc(100vh-4rem)] w-64 bg-white border-r border-[var(--color-border)] transform -translate-x-full lg:translate-x-0 transition-transform duration-200 ease-out">
            <div class="lg:hidden h-16 px-4 flex items-center justify-between border-b border-[var(--color-border)]">
                <span class="font-display font-semibold">Menu</span>
                <button type="button" data-action="drawer#close" aria-label="Fermer"
                    class="p-2 -mr-2 rounded-md cursor-pointer hover:bg-[var(--color-muted)]">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
            <nav class="p-4 space-y-1">
                {% for item in nav_items %}
                    {{ _self.nav_link(item, app.request.attributes.get('_route')) }}
                {% endfor %}
            </nav>
        </aside>

        <main class="flex-1 min-w-0 px-4 md:px-8 py-6 md:py-8">
            {% for type, messages in app.flashes(['success', 'error']) %}
                {% for message in messages %}
                    <div class="mb-4 p-3 rounded-md text-sm {{ type == 'success' ? 'bg-emerald-50 border border-emerald-200 text-emerald-800' : 'bg-red-50 border border-red-200 text-[var(--color-destructive)]' }} break-all" role="status">
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}

            {% block content %}{% endblock %}
        </main>
    </div>
</div>
{% endblock %}
