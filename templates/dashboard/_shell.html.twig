{% extends 'base.html.twig' %}

{% set is_admin = app.user.isAdmin() %}
{% set recent_notifications = notifications_repo.findRecentFor(app.user, 10) %}
{% set unread_count = notifications_repo.countUnreadFor(app.user) %}

{% set nav_items = is_admin ? [
    { route: 'app_admin', label: 'Dashboard', icon: 'grid' },
    { route: 'app_admin_orders', label: 'Commandes', icon: 'list' },
    { route: 'app_admin_products', label: 'Produits', icon: 'package' },
    { route: 'app_admin_companies', label: 'Entreprises', icon: 'building' },
    { route: 'app_admin_invitations', label: 'Invitations', icon: 'mail' },
] : [
    { route: 'app_catalogue', label: 'Catalogue', icon: 'grid' },
    { route: 'app_orders', label: 'Mes commandes', icon: 'list' },
    { route: 'app_antennas', label: 'Mes antennes', icon: 'pin' },
    { route: 'app_settings', label: 'Paramètres', icon: 'cog' },
] %}

{% macro nav_icon(name) %}
    {% if name == 'grid' %}
        {# Dashboard — Lineone duotone house+flag #}
        <svg class="w-[22px] h-[22px]" viewBox="0 0 24 24" fill="none">
            <path fill="currentColor" fill-opacity=".3" d="M5 14.059c0-1.01 0-1.514.222-1.945.221-.43.632-.724 1.453-1.31l4.163-2.974c.56-.4.842-.601 1.162-.601.32 0 .601.2 1.162.601l4.163 2.974c.821.586 1.232.88 1.453 1.31.222.43.222.935.222 1.945V19c0 .943 0 1.414-.293 1.707C18.414 21 17.943 21 17 21H7c-.943 0-1.414 0-1.707-.293C5 20.414 5 19.943 5 19v-4.94Z"/>
            <path fill="currentColor" d="M3 12.387c0 .267 0 .4.084.441.084.041.19-.04.4-.204l7.288-5.669c.59-.459.885-.688 1.228-.688.343 0 .638.23 1.228.688l7.288 5.669c.21.163.316.245.4.204.084-.04.084-.174.084-.441v-.409c0-.48 0-.72-.102-.928-.101-.208-.291-.355-.67-.65l-7-5.445c-.59-.459-.885-.688-1.228-.688-.343 0-.638.23-1.228.688l-7 5.445c-.379.295-.569.442-.67.65-.102.208-.102.448-.102.928v.409Z"/>
            <path fill="currentColor" d="M11.5 15.5h1A1.5 1.5 0 0 1 14 17v3.5h-4V17a1.5 1.5 0 0 1 1.5-1.5Z"/>
        </svg>
    {% elseif name == 'list' %}
        {# Commandes — Lineone apps/box duotone #}
        <svg class="w-[22px] h-[22px]" viewBox="0 0 24 24" fill="none">
            <path fill="currentColor" fill-opacity=".3" d="M5 8H19V16C19 17.8856 19 18.8284 18.4142 19.4142C17.8284 20 16.8856 20 15 20H9C7.11438 20 6.17157 20 5.58579 19.4142C5 18.8284 5 17.8856 5 16V8Z"/>
            <path stroke="currentColor" stroke-linecap="round" stroke-width="1.4" d="M12 8L11.7608 5.84709C11.6123 4.51089 10.4672 3.5 9.12282 3.5C7.68381 3.5 6.5 4.66655 6.5 6.10555C6.5 6.97673 6.93539 7.79026 7.66025 8.2735L9.5 9.5"/>
            <path stroke="currentColor" stroke-linecap="round" stroke-width="1.4" d="M12 8L12.2392 5.84709C12.3877 4.51089 13.5328 3.5 14.8772 3.5C16.3162 3.5 17.5 4.66655 17.5 6.10555C17.5 6.97673 17.0646 7.79026 16.3397 8.2735L14.5 9.5"/>
            <rect x="4" y="8" width="16" height="3" rx="1" fill="currentColor"/>
            <path stroke="currentColor" stroke-linecap="round" stroke-width="1.4" d="M12 11V15"/>
        </svg>
    {% elseif name == 'pin' %}
        {# Antennes — duotone pin #}
        <svg class="w-[22px] h-[22px]" viewBox="0 0 24 24" fill="none">
            <path fill="currentColor" fill-opacity=".3" d="M12 2a8 8 0 0 0-8 8c0 4.2 4.5 9.4 7 11.7.6.5 1.4.5 2 0 2.5-2.3 7-7.5 7-11.7a8 8 0 0 0-8-8Z"/>
            <circle cx="12" cy="10" r="3" fill="currentColor"/>
        </svg>
    {% elseif name == 'cog' %}
        {# Paramètres — Lineone settings duotone #}
        <svg class="w-[22px] h-[22px]" viewBox="0 0 24 24" fill="none">
            <path fill="currentColor" fill-opacity=".3" d="M2 12.947v-1.771c0-1.047.85-1.913 1.899-1.913 1.81 0 2.549-1.288 1.64-2.868a1.919 1.919 0 0 1 .699-2.607l1.729-.996c.79-.474 1.81-.192 2.279.603l.11.192c.9 1.58 2.379 1.58 3.288 0l.11-.192c.47-.795 1.49-1.077 2.279-.603l1.73.996a1.92 1.92 0 0 1 .699 2.607c-.91 1.58-.17 2.868 1.639 2.868 1.04 0 1.899.856 1.899 1.912v1.772c0 1.047-.85 1.912-1.9 1.912-1.808 0-2.548 1.288-1.638 2.869.52.915.21 2.083-.7 2.606l-1.729.997c-.79.473-1.81.191-2.279-.604l-.11-.191c-.9-1.58-2.379-1.58-3.288 0l-.11.19c-.47.796-1.49 1.078-2.279.605l-1.73-.997a1.919 1.919 0 0 1-.699-2.606c.91-1.58.17-2.869-1.639-2.869A1.911 1.911 0 0 1 2 12.947Z"/>
            <path fill="currentColor" d="M11.995 15.332c1.794 0 3.248-1.464 3.248-3.27 0-1.807-1.454-3.272-3.248-3.272-1.794 0-3.248 1.465-3.248 3.271 0 1.807 1.454 3.271 3.248 3.271Z"/>
        </svg>
    {% elseif name == 'mail' %}
        {# Invitations — envelope duotone #}
        <svg class="w-[22px] h-[22px]" viewBox="0 0 24 24" fill="none">
            <path fill="currentColor" fill-opacity=".3" d="M2 7.5A2.5 2.5 0 0 1 4.5 5h15A2.5 2.5 0 0 1 22 7.5v9a2.5 2.5 0 0 1-2.5 2.5h-15A2.5 2.5 0 0 1 2 16.5v-9Z"/>
            <path fill="currentColor" d="m2 7.5 8.9 5.6c.7.4 1.5.4 2.2 0L22 7.5c0-.7-.4-1.3-1-1.8L13.2 11c-.7.4-1.7.4-2.4 0L3 5.7c-.6.5-1 1.1-1 1.8Z"/>
        </svg>
    {% elseif name == 'package' %}
        {# Produits — box duotone #}
        <svg class="w-[22px] h-[22px]" viewBox="0 0 24 24" fill="none">
            <path fill="currentColor" fill-opacity=".3" d="M4 8.5v9c0 .6.4 1.1.9 1.4l6 3c.4.2.8.2 1.2 0l6-3c.5-.3.9-.8.9-1.4v-9l-7.3 3.7a2 2 0 0 1-1.8 0L4 8.5Z"/>
            <path fill="currentColor" d="m12.6 3.2 7 3.5c.6.3.6 1.1 0 1.4l-7 3.5a1.4 1.4 0 0 1-1.2 0l-7-3.5a.8.8 0 0 1 0-1.4l7-3.5c.4-.2.8-.2 1.2 0Z"/>
            <path fill="currentColor" d="M8 9.8 14.5 13v3.5L8 13.3V9.8Z"/>
        </svg>
    {% elseif name == 'building' %}
        {# Entreprises — office building duotone #}
        <svg class="w-[22px] h-[22px]" viewBox="0 0 24 24" fill="none">
            <path fill="currentColor" fill-opacity=".3" d="M4 3h16v18H4V3Z"/>
            <path fill="currentColor" d="M3 21h18v1H3z"/>
            <rect x="7" y="6" width="3" height="3" rx=".3" fill="currentColor"/>
            <rect x="14" y="6" width="3" height="3" rx=".3" fill="currentColor"/>
            <rect x="7" y="11" width="3" height="3" rx=".3" fill="currentColor"/>
            <rect x="14" y="11" width="3" height="3" rx=".3" fill="currentColor"/>
            <rect x="10" y="16" width="4" height="5" rx=".3" fill="currentColor"/>
        </svg>
    {% endif %}
{% endmacro %}

{% macro nav_link(item, current_route, macros) %}
    {% set is_active = current_route == item.route %}
    <a href="{{ path(item.route) }}" class="flex items-center justify-between gap-3 px-4 py-3 rounded-lg text-[15px] font-medium cursor-pointer transition-colors duration-200 {{ is_active ? 'bg-[var(--color-primary)]/10 text-[var(--color-primary)]' : 'text-[var(--color-body)] hover:bg-[var(--color-primary)]/10 hover:text-[var(--color-primary)]' }}">
        <span class="flex items-center gap-3.5">
            {{ _self.nav_icon(item.icon) }}
            <span>{{ item.label }}</span>
        </span>
        {% if item.badge is defined and item.badge > 0 %}
            <span class="inline-flex items-center justify-center min-w-5 h-5 px-1.5 text-xs font-semibold rounded-full bg-[var(--color-primary)] text-white">{{ item.badge }}</span>
        {% endif %}
    </a>
{% endmacro %}

{% block body %}
<div class="min-h-screen flex flex-col bg-[var(--color-background)]" data-controller="drawer">
    <header class="h-[61px] bg-white/80 backdrop-blur-xl sticky top-0 z-30 border-b border-[var(--color-border)]">
        <div class="h-full px-4 md:px-6 flex items-center justify-between gap-4">
            <div class="flex items-center gap-3 flex-1">
                <button type="button" data-action="drawer#open" aria-label="Ouvrir le menu"
                    class="lg:hidden p-2 -ml-2 rounded-md cursor-pointer hover:bg-[var(--color-slate-150)] text-[var(--color-navy-500)]">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/>
                    </svg>
                </button>
                <a href="{{ path('app_dashboard') }}" class="flex items-center gap-2 shrink-0">
                    <div class="w-8 h-8 rounded-lg bg-[var(--color-primary)] text-white flex items-center justify-center font-display font-bold">A</div>
                    <span class="font-display font-semibold text-[var(--color-navy-700)] hidden sm:inline">Afdal</span>
                </a>

                {# Global search #}
                <div class="relative flex-1 max-w-xl ml-4 hidden md:block"
                     data-controller="search"
                     data-search-url-value="{{ path('app_search') }}">
                    <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-[var(--color-secondary)] pointer-events-none" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z"/>
                    </svg>
                    <input type="search"
                           placeholder="Rechercher commande, produit, client..."
                           data-search-target="input"
                           data-action="input->search#input focus->search#focus"
                           class="w-full pl-9 pr-10 py-2 rounded-md border border-[var(--color-border)] bg-[var(--color-muted)]/50 text-sm focus:border-[var(--color-primary)] focus:bg-white focus:outline-2 focus:outline-[var(--color-ring)]/30 focus:outline-offset-0 transition-colors">
                    <span class="absolute right-3 top-1/2 -translate-y-1/2 text-[10px] text-[var(--color-secondary)] pointer-events-none font-mono hidden lg:inline">⌘ K</span>

                    <div data-search-target="dropdown"
                         class="hidden absolute top-full left-0 right-0 mt-2 max-h-[70vh] overflow-y-auto rounded-lg border border-[var(--color-border)] bg-white shadow-[var(--shadow-md)] z-40">
                        <div data-search-target="results" class="py-2"></div>
                    </div>
                </div>
            </div>

            <div class="flex items-center gap-1 sm:gap-2">
                <div id="notifications-dropdown" data-controller="dropdown poll"
                     data-poll-url-value="{{ app.request.uri }}"
                     data-poll-interval-value="10000"
                     class="relative">
                    <button type="button" data-action="click->dropdown#toggle"
                        class="relative p-2 rounded-md cursor-pointer hover:bg-[var(--color-muted)] text-[var(--color-secondary)] transition-colors" aria-label="Notifications">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0"/>
                        </svg>
                        {% if unread_count > 0 %}
                            <span class="absolute top-0.5 right-0.5 inline-flex items-center justify-center min-w-[18px] h-[18px] px-1 text-[10px] font-semibold rounded-full bg-[var(--color-accent)] text-white">{{ unread_count }}</span>
                        {% endif %}
                    </button>
                    <div data-dropdown-target="menu"
                        class="hidden absolute right-0 top-full mt-2 w-80 sm:w-96 flex flex-col max-h-[calc(100vh-6rem)] rounded-lg border border-[var(--color-slate-150)] bg-white shadow-[var(--shadow-soft)] overflow-hidden z-40">
                        <div class="flex items-center justify-between px-4 py-3 bg-[var(--color-muted)] border-b border-[var(--color-border-soft)]">
                            <div class="flex items-center gap-2">
                                <h3 class="font-display font-semibold text-[var(--color-foreground)]">Notifications</h3>
                                {% if unread_count > 0 %}
                                    <span class="inline-flex items-center justify-center min-w-[20px] h-5 px-1.5 text-[10px] font-semibold rounded-full bg-[var(--color-accent)] text-white">{{ unread_count }}</span>
                                {% endif %}
                            </div>
                            {% if unread_count > 0 %}
                                <form method="post" action="{{ path('app_notifications_read_all') }}">
                                    <button type="submit" class="text-xs font-medium text-[var(--color-primary)] hover:text-[var(--color-primary-focus)] transition-colors">Tout marquer lu</button>
                                </form>
                            {% endif %}
                        </div>
                        <div class="overflow-y-auto flex-1 divide-y divide-[var(--color-border-soft)]">
                            {% if recent_notifications is empty %}
                                <div class="px-4 py-12 text-center">
                                    <div class="w-12 h-12 rounded-full bg-[var(--color-muted)] flex items-center justify-center mx-auto mb-3">
                                        <svg class="w-6 h-6 text-[var(--color-secondary)]" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0"/></svg>
                                    </div>
                                    <p class="font-medium text-[var(--color-foreground)] text-sm">Aucune notification</p>
                                    <p class="text-xs text-[var(--color-secondary)] mt-1">Vous serez averti ici.</p>
                                </div>
                            {% else %}
                                {% for n in recent_notifications %}
                                    {% set tile_classes = {'info': 'bg-sky-50 text-sky-600', 'success': 'bg-emerald-50 text-emerald-600', 'warning': 'bg-amber-50 text-amber-600', 'destructive': 'bg-red-50 text-red-600'}[n.type] ?? 'bg-slate-50 text-slate-600' %}
                                    <a href="{{ path('app_notification_read', {id: n.id}) }}"
                                       class="relative flex items-start gap-3 px-4 py-3 hover:bg-[var(--color-muted)] transition-colors {{ not n.read ? 'bg-[var(--color-primary-light)]/40' : '' }}">
                                        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg {{ tile_classes }}">
                                            {% if n.type == 'success' %}
                                                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
                                            {% elseif n.type == 'warning' %}
                                                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/></svg>
                                            {% elseif n.type == 'destructive' %}
                                                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m9.75 9.75 4.5 4.5m0-4.5-4.5 4.5M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
                                            {% else %}
                                                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31"/></svg>
                                            {% endif %}
                                        </div>
                                        <div class="flex-1 min-w-0">
                                            <div class="font-medium text-sm text-[var(--color-foreground)] truncate">{{ n.title }}</div>
                                            {% if n.message %}
                                                <div class="text-xs text-[var(--color-secondary)] mt-0.5 line-clamp-2">{{ n.message }}</div>
                                            {% endif %}
                                            <div class="text-[11px] text-[var(--color-secondary)] mt-1.5">{{ n.createdAt|date('d/m à H:i') }}</div>
                                        </div>
                                        {% if not n.read %}
                                            <span class="absolute top-4 right-3 w-2 h-2 rounded-full bg-[var(--color-primary)]" aria-label="Non lu"></span>
                                        {% endif %}
                                    </a>
                                {% endfor %}
                            {% endif %}
                        </div>
                    </div>
                </div>

                {% if not is_admin %}
                    <a href="{{ path('app_cart') }}" class="relative p-2 rounded-md cursor-pointer hover:bg-[var(--color-muted)] text-[var(--color-secondary)] transition-colors" aria-label="Panier">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z"/>
                        </svg>
                        {% if cart.count > 0 %}
                            <span class="absolute top-0.5 right-0.5 inline-flex items-center justify-center min-w-[18px] h-[18px] px-1 text-[10px] font-semibold rounded-full bg-[var(--color-primary)] text-white">{{ cart.count }}</span>
                        {% endif %}
                    </a>
                {% endif %}
                <div class="w-px h-5 bg-[var(--color-border)] hidden sm:block mx-1"></div>
                <div class="text-right hidden md:block mr-1">
                    <div class="text-sm font-medium text-[var(--color-navy-700)] leading-tight">{{ app.user.fullName }}</div>
                    <div class="text-xs text-[var(--color-navy-400)] leading-tight">
                        {% if is_admin %}Admin Afdal{% else %}{{ app.user.company.name }}{% endif %}
                    </div>
                </div>
                <a href="{{ path('app_logout') }}" class="inline-flex items-center justify-center w-9 h-9 rounded-md cursor-pointer text-[var(--color-navy-400)] transition-colors duration-150 hover:bg-[var(--color-slate-150)] hover:text-[var(--color-navy-700)]" aria-label="Déconnexion">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9"/>
                    </svg>
                </a>
            </div>
        </div>
    </header>

    <div class="flex-1 flex relative">
        <div data-drawer-target="backdrop" data-action="click->drawer#close"
             class="lg:hidden fixed inset-0 bg-black/40 z-40 transition-opacity duration-200 opacity-0 pointer-events-none"></div>

        <aside data-drawer-target="panel"
               class="fixed lg:sticky top-0 lg:top-[61px] left-0 z-50 lg:z-auto h-screen lg:h-[calc(100vh-61px)] w-64 bg-white border-r border-[var(--color-border)] transform -translate-x-full lg:translate-x-0 transition-transform duration-200 ease-out shadow-[var(--shadow-soft)] lg:shadow-none">
            <div class="lg:hidden h-[61px] px-4 flex items-center justify-between border-b border-[var(--color-border)]">
                <span class="font-display font-semibold">Menu</span>
                <button type="button" data-action="drawer#close" aria-label="Fermer"
                    class="p-2 -mr-2 rounded-md cursor-pointer hover:bg-[var(--color-slate-150)]">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/>
                    </svg>
                </button>
            </div>
            <nav class="p-4 space-y-2">
                {% for item in nav_items %}
                    {{ _self.nav_link(item, app.request.attributes.get('_route'), _self) }}
                {% endfor %}
            </nav>
        </aside>

        <main class="flex-1 min-w-0 px-4 md:px-8 py-6 md:py-8 max-w-[1400px]">
            {% for type, messages in app.flashes(['success', 'error']) %}
                {% for message in messages %}
                    <div class="mb-4 p-3 rounded-md text-sm flex items-start gap-2 {{ type == 'success' ? 'bg-emerald-50 border border-emerald-200 text-emerald-800' : 'bg-red-50 border border-red-200 text-[var(--color-error)]' }} break-words" role="status">
                        <svg class="w-4 h-4 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            {% if type == 'success' %}
                                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/>
                            {% else %}
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z"/>
                            {% endif %}
                        </svg>
                        <span>{{ message }}</span>
                    </div>
                {% endfor %}
            {% endfor %}

            {% block content %}{% endblock %}
        </main>
    </div>
</div>
