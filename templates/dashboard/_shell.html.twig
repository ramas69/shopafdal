{% extends 'base.html.twig' %}

{% set is_admin = app.user.isAdmin() %}
{% set recent_notifications = notifications_repo.findRecentFor(app.user, 10) %}
{% set unread_count = notifications_repo.countUnreadFor(app.user) %}

{% set nav_items = is_admin ? [
    { route: 'app_admin', label: 'Dashboard', icon: 'grid' },
    { route: 'app_admin_orders', label: 'Commandes', icon: 'list' },
    { route: 'app_admin_invitations', label: 'Invitations', icon: 'mail' },
] : [
    { route: 'app_catalogue', label: 'Catalogue', icon: 'grid' },
    { route: 'app_orders', label: 'Mes commandes', icon: 'list' },
    { route: 'app_antennas', label: 'Mes antennes', icon: 'pin' },
    { route: 'app_settings', label: 'Paramètres', icon: 'cog' },
] %}

{% macro nav_icon(name) %}
    {% if name == 'grid' %}
        <svg class="w-[22px] h-[22px]" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z"/></svg>
    {% elseif name == 'list' %}
        <svg class="w-[22px] h-[22px]" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 12h16.5m-16.5 3.75h16.5M3.75 19.5h16.5M5.625 4.5h12.75a1.875 1.875 0 0 1 0 3.75H5.625a1.875 1.875 0 0 1 0-3.75Z"/></svg>
    {% elseif name == 'pin' %}
        <svg class="w-[22px] h-[22px]" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/></svg>
    {% elseif name == 'cog' %}
        <svg class="w-[22px] h-[22px]" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/></svg>
    {% elseif name == 'mail' %}
        <svg class="w-[22px] h-[22px]" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/></svg>
    {% endif %}
{% endmacro %}

{% macro nav_link(item, current_route, macros) %}
    {% set is_active = current_route == item.route %}
    <a href="{{ path(item.route) }}" class="flex items-center justify-between gap-3 px-4 py-3 rounded-lg text-[15px] font-medium cursor-pointer transition-all duration-150 {{ is_active ? 'bg-[var(--color-primary)] text-white shadow-[var(--shadow-soft)]' : 'text-[var(--color-body)] hover:bg-[var(--color-muted)] hover:text-[var(--color-foreground)]' }}">
        <span class="flex items-center gap-3.5">
            {{ _self.nav_icon(item.icon) }}
            <span>{{ item.label }}</span>
        </span>
        {% if item.badge is defined and item.badge > 0 %}
            <span class="inline-flex items-center justify-center min-w-5 h-5 px-1.5 text-xs font-semibold rounded-full {{ is_active ? 'bg-white text-[var(--color-primary)]' : 'bg-[var(--color-primary)] text-white' }}">{{ item.badge }}</span>
        {% endif %}
    </a>
{% endmacro %}

{% block body %}
<div class="min-h-screen flex flex-col bg-[var(--color-background)]" data-controller="drawer">
    <header class="h-[61px] bg-white/80 backdrop-blur-xl sticky top-0 z-30 border-b border-[var(--color-border)]">
        <div class="h-full px-4 md:px-6 flex items-center justify-between gap-4">
            <div class="flex items-center gap-3">
                <button type="button" data-action="drawer#open" aria-label="Ouvrir le menu"
                    class="lg:hidden p-2 -ml-2 rounded-md cursor-pointer hover:bg-[var(--color-slate-150)] text-[var(--color-navy-500)]">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/>
                    </svg>
                </button>
                <a href="{{ path('app_dashboard') }}" class="flex items-center gap-2">
                    <div class="w-8 h-8 rounded-lg bg-[var(--color-primary)] text-white flex items-center justify-center font-display font-bold">A</div>
                    <span class="font-display font-semibold text-[var(--color-navy-700)] hidden sm:inline">Afdal</span>
                </a>
            </div>

            <div class="flex items-center gap-1 sm:gap-2">
                <div data-controller="dropdown" class="relative">
                    <button type="button" data-action="click->dropdown#toggle"
                        class="relative p-2 rounded-md cursor-pointer hover:bg-[var(--color-muted)] text-[var(--color-secondary)] transition-colors" aria-label="Notifications">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0"/>
                        </svg>
                        {% if unread_count > 0 %}
                            <span class="absolute top-0.5 right-0.5 inline-flex items-center justify-center min-w-[18px] h-[18px] px-1 text-[10px] font-semibold rounded-full bg-[var(--color-accent)] text-white">{{ unread_count }}</span>
                        {% endif %}
                    </button>
                    <div data-dropdown-target="menu"
                        class="hidden absolute right-0 top-full mt-2 w-80 sm:w-96 card p-0 overflow-hidden z-40 max-h-[70vh] flex flex-col">
                        <div class="flex items-center justify-between px-4 py-3 border-b border-[var(--color-border-soft)]">
                            <span class="font-display font-semibold text-[var(--color-foreground)]">Notifications</span>
                            {% if unread_count > 0 %}
                                <form method="post" action="{{ path('app_notifications_read_all') }}">
                                    <button type="submit" class="text-xs text-[var(--color-primary)] hover:underline">Tout marquer lu</button>
                                </form>
                            {% endif %}
                        </div>
                        <div class="overflow-y-auto flex-1">
                            {% if recent_notifications is empty %}
                                <div class="px-4 py-8 text-center text-sm text-[var(--color-secondary)]">Aucune notification.</div>
                            {% else %}
                                {% for n in recent_notifications %}
                                    {% set dot_class = {'info': 'bg-sky-500', 'success': 'bg-emerald-500', 'warning': 'bg-amber-500', 'destructive': 'bg-red-500'}[n.type] ?? 'bg-slate-400' %}
                                    <a href="{{ path('app_notification_read', {id: n.id}) }}"
                                       class="block px-4 py-3 border-b border-[var(--color-border-soft)] hover:bg-[var(--color-muted)] transition-colors {{ not n.read ? 'bg-[var(--color-primary-light)]/30' : '' }}">
                                        <div class="flex items-start gap-3">
                                            <span class="mt-1.5 w-2 h-2 rounded-full {{ dot_class }} shrink-0"></span>
                                            <div class="flex-1 min-w-0">
                                                <div class="flex items-center justify-between gap-2">
                                                    <div class="font-medium text-sm text-[var(--color-foreground)] truncate">{{ n.title }}</div>
                                                    <div class="text-[11px] text-[var(--color-secondary)] shrink-0">{{ n.createdAt|date('d/m H:i') }}</div>
                                                </div>
                                                {% if n.message %}
                                                    <div class="text-xs text-[var(--color-secondary)] mt-0.5 line-clamp-2">{{ n.message }}</div>
                                                {% endif %}
                                            </div>
                                        </div>
                                    </a>
                                {% endfor %}
                            {% endif %}
                        </div>
                    </div>
                </div>

                {% if not is_admin %}
                    <a href="{{ path('app_cart') }}" class="relative p-2 rounded-md cursor-pointer hover:bg-[var(--color-muted)] text-[var(--color-secondary)] transition-colors" aria-label="Panier">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z"/>
                        </svg>
                        {% if cart.count > 0 %}
                            <span class="absolute top-0.5 right-0.5 inline-flex items-center justify-center min-w-[18px] h-[18px] px-1 text-[10px] font-semibold rounded-full bg-[var(--color-primary)] text-white">{{ cart.count }}</span>
                        {% endif %}
                    </a>
                {% endif %}
                <div class="w-px h-5 bg-[var(--color-border)] hidden sm:block mx-1"></div>
                <div class="text-right hidden md:block mr-1">
                    <div class="text-sm font-medium text-[var(--color-navy-700)] leading-tight">{{ app.user.fullName }}</div>
                    <div class="text-xs text-[var(--color-navy-400)] leading-tight">
                        {% if is_admin %}Admin Afdal{% else %}{{ app.user.company.name }}{% endif %}
                    </div>
                </div>
                <a href="{{ path('app_logout') }}" class="inline-flex items-center justify-center w-9 h-9 rounded-md cursor-pointer text-[var(--color-navy-400)] transition-colors duration-150 hover:bg-[var(--color-slate-150)] hover:text-[var(--color-navy-700)]" aria-label="Déconnexion">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9"/>
                    </svg>
                </a>
            </div>
        </div>
    </header>

    <div class="flex-1 flex relative">
        <div data-drawer-target="backdrop" data-action="click->drawer#close"
             class="lg:hidden fixed inset-0 bg-black/40 z-40 transition-opacity duration-200 opacity-0 pointer-events-none"></div>

        <aside data-drawer-target="panel"
               class="fixed lg:sticky top-0 lg:top-[61px] left-0 z-50 lg:z-auto h-screen lg:h-[calc(100vh-61px)] w-64 bg-white border-r border-[var(--color-border)] transform -translate-x-full lg:translate-x-0 transition-transform duration-200 ease-out shadow-[var(--shadow-soft)] lg:shadow-none">
            <div class="lg:hidden h-[61px] px-4 flex items-center justify-between border-b border-[var(--color-border)]">
                <span class="font-display font-semibold">Menu</span>
                <button type="button" data-action="drawer#close" aria-label="Fermer"
                    class="p-2 -mr-2 rounded-md cursor-pointer hover:bg-[var(--color-slate-150)]">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/>
                    </svg>
                </button>
            </div>
            <nav class="p-4 space-y-2">
                {% for item in nav_items %}
                    {{ _self.nav_link(item, app.request.attributes.get('_route'), _self) }}
                {% endfor %}
            </nav>
        </aside>

        <main class="flex-1 min-w-0 px-4 md:px-8 py-6 md:py-8 max-w-[1400px]">
            {% for type, messages in app.flashes(['success', 'error']) %}
                {% for message in messages %}
                    <div class="mb-4 p-3 rounded-md text-sm flex items-start gap-2 {{ type == 'success' ? 'bg-emerald-50 border border-emerald-200 text-emerald-800' : 'bg-red-50 border border-red-200 text-[var(--color-error)]' }} break-words" role="status">
                        <svg class="w-4 h-4 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            {% if type == 'success' %}
                                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/>
                            {% else %}
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z"/>
                            {% endif %}
                        </svg>
                        <span>{{ message }}</span>
                    </div>
                {% endfor %}
            {% endfor %}

            {% block content %}{% endblock %}
        </main>
    </div>
</div>
{% endblock %}
