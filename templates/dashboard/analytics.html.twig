{% extends 'dashboard/_shell.html.twig' %}

{% block title %}Analytics — {{ company.name }}{% endblock %}

{% block content %}
<div class="mb-6">
    <div class="text-xs font-medium text-[var(--color-secondary)] uppercase tracking-wide mb-1">{{ company.name }}</div>
    <h1 class="font-display text-2xl font-semibold text-[var(--color-foreground)]">Analytics</h1>
</div>

{% if late_count > 0 %}
    <div class="mb-6 rounded-xl border border-red-200 bg-red-50/60 p-4 flex items-start gap-3">
        <div class="shrink-0 w-9 h-9 rounded-lg bg-red-100 text-[var(--color-destructive)] flex items-center justify-center">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/></svg>
        </div>
        <div class="min-w-0 flex-1">
            <div class="text-sm font-semibold text-[var(--color-destructive)]">{{ late_count }} commande{{ late_count > 1 ? 's' : '' }} en retard</div>
            <ul class="mt-2 space-y-1 text-sm">
                {% for o in late_orders %}
                    <li class="flex items-center justify-between gap-3">
                        <a href="{{ path('app_order_detail', {reference: o.reference}) }}" class="font-medium text-[var(--color-foreground)] hover:text-[var(--color-primary)] transition-colors">{{ o.reference }}</a>
                        <span class="text-xs text-[var(--color-secondary)]">prévu le {{ o.estimated_delivery_at|date('d/m/Y') }} · {{ status_labels[o.status]|default(o.status) }}</span>
                    </li>
                {% endfor %}
            </ul>
        </div>
    </div>
{% endif %}

<section class="mb-6" style="display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 1.25rem;">
    {# Total commandé — indigo (primary Afdal) #}
    {% set ca_parts = (totals.revenue_cents|price)|split(',') %}
    <div class="card p-4 sm:p-5">
        <div class="flex w-12 h-12 items-center justify-center rounded-xl shrink-0 bg-indigo-500 shadow-xl shadow-indigo-500/50">
            <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-2.21 0-4-1.79-4-4s1.79-4 4-4c1.538 0 2.873.87 3.536 2.143"/></svg>
        </div>
        <p class="mt-16 text-[var(--color-secondary)]">Total commandé</p>
        <p class="mt-2 font-medium text-[var(--color-foreground)]">
            <span class="text-2xl">{{ ca_parts[0] }}</span><span class="text-base">,{{ ca_parts[1]|default('00 €') }}</span>
        </p>
        {% if totals.revenue_delta_pct is not null %}
            {% set up = totals.revenue_delta_pct >= 0 %}
            <p class="mt-1 flex items-center text-xs gap-1 {{ up ? 'text-emerald-600' : 'text-[var(--color-destructive)]' }}">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="{{ up ? 'M7 11l5-5m0 0l5 5m-5-5v12' : 'M17 13l-5 5m0 0l-5-5m5 5V6' }}"/>
                </svg>
                <span>{{ up ? '+' : '' }}{{ totals.revenue_delta_pct|number_format(1, ',', ' ') }}%</span>
            </p>
        {% endif %}
    </div>

    {# Commandes — warning orange #}
    <div class="card p-4 sm:p-5">
        <div class="flex w-12 h-12 items-center justify-center rounded-xl shrink-0 bg-amber-500 shadow-xl shadow-amber-500/50">
            <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        </div>
        <p class="mt-16 text-[var(--color-secondary)]">Commandes</p>
        <p class="mt-2 font-medium text-[var(--color-foreground)]">
            <span class="text-2xl">{{ totals.orders_count }}</span>
        </p>
        <p class="mt-1 flex items-center text-xs text-[var(--color-secondary)] gap-1">
            <span class="inline-block w-1.5 h-1.5 rounded-full bg-amber-500"></span>
            <span>{{ totals.in_progress_count }} en cours</span>
        </p>
    </div>

    {# Panier moyen — info blue #}
    {% set pm_parts = (totals.avg_ticket_cents|price)|split(',') %}
    <div class="card p-4 sm:p-5">
        <div class="flex w-12 h-12 items-center justify-center rounded-xl shrink-0 bg-sky-500 shadow-xl shadow-sky-500/50">
            <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <p class="mt-16 text-[var(--color-secondary)]">Panier moyen</p>
        <p class="mt-2 font-medium text-[var(--color-foreground)]">
            <span class="text-2xl">{{ pm_parts[0] }}</span><span class="text-base">,{{ pm_parts[1]|default('00 €') }}</span>
        </p>
        <p class="mt-1 text-xs text-[var(--color-secondary)]">par commande</p>
    </div>

    {# Économies — secondary pink #}
    {% set sv_parts = (totals.savings_cents|price)|split(',') %}
    <div class="card p-4 sm:p-5">
        <div class="flex w-12 h-12 items-center justify-center rounded-xl shrink-0 shadow-xl" style="background-color: #EC4899; box-shadow: 0 20px 25px -5px rgba(236, 72, 153, 0.5), 0 8px 10px -6px rgba(236, 72, 153, 0.5);">
            <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941"/></svg>
        </div>
        <p class="mt-16 text-[var(--color-secondary)]">Économies</p>
        <p class="mt-2 font-medium text-[var(--color-foreground)]">
            <span class="text-2xl">{{ sv_parts[0] }}</span><span class="text-base">,{{ sv_parts[1]|default('00 €') }}</span>
        </p>
        <p class="mt-1 text-xs text-[var(--color-secondary)]">tarifs négociés</p>
    </div>
</section>

<section class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
    <div class="card p-6 lg:col-span-2" data-controller="chart"
         data-chart-type-value="bar"
         data-chart-minimal-value="true"
         data-chart-payload-value="{{ {
             labels: monthly|map(r => r.month|slice(5, 2)),
             datasets: [{
                 data: monthly|map(r => r.revenue / 100),
                 backgroundColor: monthly|map(r => r.projected ? '#C7D2FE' : '#6366F1'),
             }]
         }|json_encode }}">
        <div class="flex items-end justify-between mb-4 gap-4">
            <h2 class="font-display font-semibold text-[var(--color-foreground)]">Total commandé · 6 derniers mois + 6 prochains</h2>
            <div class="flex items-center gap-3 text-xs text-[var(--color-secondary)]">
                <span class="inline-flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-sm" style="background:#6366F1"></span>Réalisé</span>
                <span class="inline-flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-sm" style="background:#C7D2FE"></span>Projeté</span>
            </div>
        </div>
        <div class="relative h-72">
            <canvas data-chart-target="canvas"></canvas>
        </div>
    </div>

    <div class="card p-6" data-controller="chart"
         data-chart-type-value="doughnut"
         data-chart-payload-value="{{ {
             labels: status_dist|map(r => status_labels[r.status]|default(r.status)),
             datasets: [{
                 data: status_dist|map(r => r.count),
                 backgroundColor: ['#0EA5E9', '#8B5CF6', '#F59E0B', '#10B981', '#F43F5E'],
             }]
         }|json_encode }}">
        <h2 class="font-display font-semibold text-[var(--color-foreground)] mb-4">Commandes actives</h2>
        <div class="relative h-64">
            <canvas data-chart-target="canvas"></canvas>
        </div>
    </div>
</section>

<section class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="card p-6" data-controller="chart"
         data-chart-type-value="bar"
         data-chart-payload-value="{{ {
             labels: top_products|map(r => r.name),
             datasets: [{
                 label: 'Pièces',
                 data: top_products|map(r => r.qty),
                 backgroundColor: '#175CD3',
             }]
         }|json_encode }}"
         data-chart-horizontal-value="true">
        <h2 class="font-display font-semibold text-[var(--color-foreground)] mb-4">Top 5 produits</h2>
        <div class="relative h-72"><canvas data-chart-target="canvas"></canvas></div>
    </div>

    {% if by_antenna|length > 0 %}
        <div class="card p-6" data-controller="chart"
             data-chart-type-value="bar"
             data-chart-payload-value="{{ {
                 labels: by_antenna|map(r => r.name),
                 datasets: [{
                     label: 'Commandes',
                     data: by_antenna|map(r => r.orders_count),
                     backgroundColor: '#8B5CF6',
                 }]
             }|json_encode }}"
             data-chart-horizontal-value="true">
            <h2 class="font-display font-semibold text-[var(--color-foreground)] mb-4">Commandes par antenne</h2>
            <div class="relative h-72"><canvas data-chart-target="canvas"></canvas></div>
        </div>
    {% else %}
        <div class="card p-6 flex flex-col items-center justify-center text-center">
            <div class="w-12 h-12 rounded-full bg-[var(--color-muted)] flex items-center justify-center mb-3">
                <svg class="w-6 h-6 text-[var(--color-secondary)]" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/></svg>
            </div>
            <div class="text-sm font-medium text-[var(--color-foreground)]">Commandes par antenne</div>
            <div class="text-xs text-[var(--color-secondary)] mt-1">Aucune commande rattachée à une antenne pour l'instant.</div>
        </div>
    {% endif %}
</section>
{% endblock %}
