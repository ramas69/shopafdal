{% extends 'dashboard/_shell.html.twig' %}

{% block title %}Admin — Afdal{% endblock %}

{% block content %}
<div class="mb-10">
    <div class="text-xs font-medium text-[var(--color-secondary)] uppercase tracking-wide mb-2">Tableau de bord</div>
    <h1 class="font-display text-4xl md:text-5xl font-semibold tracking-tight bg-gradient-to-br from-[var(--color-primary)] via-[var(--color-primary)] to-[var(--color-primary)]/60 bg-clip-text text-transparent">
        Admin Afdal
    </h1>
</div>

<div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-8">
    {% set metric_cards = [
        { label: 'Clients VIP', value: stats.companies, tone: 'neutral', icon: 'users' },
        { label: 'Produits actifs', value: stats.products, tone: 'neutral', icon: 'package' },
        { label: 'Commandes totales', value: stats.orders, tone: 'neutral', icon: 'list' },
        { label: 'À traiter', value: stats.to_process, tone: 'accent', icon: 'alert' }
    ] %}
    {% for card in metric_cards %}
        <div class="relative overflow-hidden p-5 rounded-xl bg-[var(--color-surface)] border border-[var(--color-border-soft)] transition-all duration-200 hover:border-[var(--color-border)] hover:shadow-[var(--shadow-md)] group">
            <span aria-hidden="true" class="pointer-events-none absolute -right-8 -top-8 w-20 h-20 rounded-full bg-[var(--color-muted)]/60 transition-transform duration-300 group-hover:scale-110"></span>
            <span aria-hidden="true" class="pointer-events-none absolute -right-2 -top-2 w-10 h-10 rounded-full bg-[var(--color-muted)] transition-transform duration-300 group-hover:scale-110"></span>

            <div class="relative flex items-start justify-between mb-4">
                <div class="text-xs font-medium text-[var(--color-secondary)] uppercase tracking-wide">{{ card.label }}</div>
                <div class="w-7 h-7 rounded-md bg-[var(--color-surface)] flex items-center justify-center text-[var(--color-secondary)] border border-[var(--color-border-soft)]">
                    {% if card.icon == 'users' %}
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z"/></svg>
                    {% elseif card.icon == 'package' %}
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m7.5 14.25 5.25 5.25 5.25-5.25M7.5 9h10.5V5.25A2.25 2.25 0 0 0 15.75 3H8.25A2.25 2.25 0 0 0 6 5.25V9h1.5Z M3.375 7.5h17.25c.621 0 1.125.504 1.125 1.125v10.5c0 .621-.504 1.125-1.125 1.125H3.375A1.125 1.125 0 0 1 2.25 19.125v-10.5c0-.621.504-1.125 1.125-1.125Z"/></svg>
                    {% elseif card.icon == 'list' %}
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/></svg>
                    {% else %}
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/></svg>
                    {% endif %}
                </div>
            </div>

            <div class="relative font-display text-3xl md:text-4xl font-semibold tracking-tight {{ card.tone == 'accent' ? 'text-[var(--color-accent)]' : 'text-[var(--color-primary)]' }}">{{ card.value }}</div>
        </div>
    {% endfor %}
</div>

<div class="p-6 rounded-xl bg-[var(--color-surface)] border border-[var(--color-border-soft)]">
    <div class="flex items-start justify-between gap-4 mb-2">
        <div>
            <h2 class="font-display text-lg font-semibold text-[var(--color-primary)] mb-1">Invitations</h2>
            <p class="text-sm text-[var(--color-secondary)]">Invitez des clients VIP à rejoindre la plateforme.</p>
        </div>
        <a href="{{ path('app_admin_invitation_new') }}" class="inline-flex items-center gap-2 px-4 py-2 rounded-md bg-[var(--color-primary)] text-[var(--color-on-primary)] text-sm font-medium cursor-pointer transition-colors duration-150 hover:bg-[#1F1F1F]">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
            Nouvelle invitation
        </a>
    </div>
</div>
{% endblock %}
