{% extends 'dashboard/_shell.html.twig' %}

{% block title %}Admin — Afdal{% endblock %}

{% block content %}
<div class="mb-8 flex flex-wrap items-end justify-between gap-4">
    <div>
        <div class="text-xs font-medium text-[var(--color-navy-400)] uppercase tracking-wide mb-1">Tableau de bord</div>
        <h1 class="font-display text-2xl font-semibold text-[var(--color-navy-700)]">Bonjour {{ app.user.fullName|split(' ')|first }}</h1>
        <p class="text-[var(--color-navy-400)] text-sm mt-1">Voici un aperçu de l'activité de la plateforme.</p>
    </div>
    <a href="{{ path('app_admin_invitation_new') }}" class="btn btn-primary">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
        Nouvelle invitation
    </a>
</div>

<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
    {% set metric_cards = [
        { label: 'Clients VIP', value: stats.companies, icon: 'users', iconBg: 'bg-[var(--color-primary)]/10', iconColor: 'text-[var(--color-primary)]', highlight: false },
        { label: 'Produits actifs', value: stats.products, icon: 'package', iconBg: 'bg-[var(--color-info)]/10', iconColor: 'text-[var(--color-info)]', highlight: false },
        { label: 'Commandes totales', value: stats.orders, icon: 'list', iconBg: 'bg-[var(--color-success)]/10', iconColor: 'text-[var(--color-success)]', highlight: false },
        { label: 'À traiter', value: stats.to_process, icon: 'alert', iconBg: 'bg-[var(--color-warning)]/10', iconColor: 'text-[var(--color-warning)]', highlight: true }
    ] %}
    {% for card in metric_cards %}
        <div class="card p-5 group transition-transform hover:-translate-y-0.5">
            <div class="flex items-start justify-between mb-4">
                <div>
                    <div class="text-xs font-medium text-[var(--color-navy-400)] uppercase tracking-wide mb-2">{{ card.label }}</div>
                    <div class="font-display text-3xl font-semibold tracking-tight {{ card.highlight ? 'text-[var(--color-warning)]' : 'text-[var(--color-navy-700)]' }}">{{ card.value }}</div>
                </div>
                <div class="w-10 h-10 rounded-lg {{ card.iconBg }} {{ card.iconColor }} flex items-center justify-center">
                    {% if card.icon == 'users' %}
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z"/></svg>
                    {% elseif card.icon == 'package' %}
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m7.5 14.25 5.25 5.25 5.25-5.25M7.5 9h10.5V5.25A2.25 2.25 0 0 0 15.75 3H8.25A2.25 2.25 0 0 0 6 5.25V9h1.5Z M3.375 7.5h17.25c.621 0 1.125.504 1.125 1.125v10.5c0 .621-.504 1.125-1.125 1.125H3.375A1.125 1.125 0 0 1 2.25 19.125v-10.5c0-.621.504-1.125 1.125-1.125Z"/></svg>
                    {% elseif card.icon == 'list' %}
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/></svg>
                    {% else %}
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/></svg>
                    {% endif %}
                </div>
            </div>
            <div class="h-1 w-12 rounded-full {{ card.highlight ? 'bg-[var(--color-warning)]' : 'bg-[var(--color-primary)]/40' }}"></div>
        </div>
    {% endfor %}
</div>

<div class="card p-6">
    <div class="flex items-start justify-between gap-4 mb-2">
        <div>
            <h2 class="font-display text-base font-semibold text-[var(--color-navy-700)] mb-1">Invitations</h2>
            <p class="text-sm text-[var(--color-navy-400)]">Invitez des clients VIP à rejoindre la plateforme.</p>
        </div>
        <a href="{{ path('app_admin_invitations') }}" class="btn btn-outline text-sm">
            Voir toutes
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
        </a>
    </div>
</div>
{% endblock %}
