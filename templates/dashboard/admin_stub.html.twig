{% extends 'dashboard/_shell.html.twig' %}

{% block title %}Admin — Dashboard{% endblock %}

{% block content %}
<div class="mb-6">
    <div class="text-xs font-medium text-[var(--color-secondary)] uppercase tracking-wide mb-1">Admin · {{ "now"|date('EEEE d MMMM', 'fr') }}</div>
    <h1 class="font-display text-2xl font-semibold text-[var(--color-foreground)]">Bonjour {{ app.user.fullName|split(' ')|first }}</h1>
</div>

{# === Focus aujourd'hui === #}
<section class="mb-6">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
        <a href="{{ path('app_admin_orders') }}" class="card p-5 block hover:shadow-[var(--shadow-md)] transition-all">
            <div class="flex items-start justify-between mb-2">
                <div class="text-xs font-medium text-[var(--color-secondary)] uppercase tracking-wide">Nouvelles aujourd'hui</div>
                <div class="w-8 h-8 rounded-lg bg-sky-50 text-sky-600 flex items-center justify-center">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 3.75H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V13.5M15 3.75h3.375c.621 0 1.125.504 1.125 1.125V13.5h-4.5V3.75Z"/></svg>
                </div>
            </div>
            <div class="font-display text-3xl font-semibold text-[var(--color-primary)]">{{ today.new }}</div>
        </a>

        <a href="{{ path('app_admin_orders', {status: 'placed'}) }}" class="card p-5 block hover:shadow-[var(--shadow-md)] transition-all">
            <div class="flex items-start justify-between mb-2">
                <div class="text-xs font-medium text-[var(--color-secondary)] uppercase tracking-wide">À confirmer</div>
                <div class="w-8 h-8 rounded-lg bg-emerald-50 text-emerald-600 flex items-center justify-center">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                </div>
            </div>
            <div class="font-display text-3xl font-semibold text-[var(--color-foreground)]">{{ today.to_confirm }}</div>
        </a>

        <a href="{{ path('app_admin_orders') }}" class="card p-5 block hover:shadow-[var(--shadow-md)] transition-all">
            <div class="flex items-start justify-between mb-2">
                <div class="text-xs font-medium text-[var(--color-secondary)] uppercase tracking-wide">À expédier</div>
                <div class="w-8 h-8 rounded-lg bg-indigo-50 text-indigo-600 flex items-center justify-center">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25"/></svg>
                </div>
            </div>
            <div class="font-display text-3xl font-semibold text-[var(--color-foreground)]">{{ today.to_ship }}</div>
        </a>

        <a href="{{ path('app_admin_orders', {status: 'placed'}) }}" class="card p-5 block hover:shadow-[var(--shadow-md)] transition-all {{ today.urgent > 0 ? 'ring-2 ring-[var(--color-destructive)]/30' : '' }}">
            <div class="flex items-start justify-between mb-2">
                <div class="text-xs font-medium text-[var(--color-secondary)] uppercase tracking-wide">Urgentes (>24h)</div>
                <div class="w-8 h-8 rounded-lg bg-red-50 text-red-600 flex items-center justify-center">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/></svg>
                </div>
            </div>
            <div class="font-display text-3xl font-semibold {{ today.urgent > 0 ? 'text-[var(--color-destructive)]' : 'text-[var(--color-foreground)]' }}">{{ today.urgent }}</div>
        </a>
    </div>
</section>

{# === Urgences + CA mois === #}
<section class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
    {# Urgences #}
    <div class="card p-6 lg:col-span-1">
        <div class="flex items-center justify-between mb-4">
            <div>
                <h2 class="font-display font-semibold text-[var(--color-foreground)]">Urgences</h2>
                <p class="text-xs text-[var(--color-secondary)] mt-0.5">Placées depuis +24h</p>
            </div>
            {% if urgent_orders|length > 0 %}
                <span class="badge border bg-red-50 text-red-700 border-red-200">{{ urgent_orders|length }}</span>
            {% endif %}
        </div>
        {% if urgent_orders is empty %}
            <div class="text-center py-8">
                <div class="w-12 h-12 rounded-full bg-emerald-50 flex items-center justify-center mx-auto mb-2">
                    <svg class="w-6 h-6 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                </div>
                <p class="text-sm font-medium text-[var(--color-foreground)]">Tout est à jour</p>
                <p class="text-xs text-[var(--color-secondary)] mt-0.5">Aucune commande en attente.</p>
            </div>
        {% else %}
            <ul class="space-y-2">
                {% for order in urgent_orders %}
                    {% set elapsed_hours = ((date('now').timestamp - order.placedAt.timestamp) / 3600)|round %}
                    <li>
                        <a href="{{ path('app_admin_order_detail', {reference: order.reference}) }}"
                           class="flex items-center justify-between gap-2 p-3 rounded-md border border-[var(--color-border-soft)] hover:border-[var(--color-destructive)] hover:bg-red-50/40 transition-colors">
                            <div class="min-w-0">
                                <div class="font-mono font-semibold text-sm text-[var(--color-foreground)]">{{ order.reference }}</div>
                                <div class="text-xs text-[var(--color-secondary)] truncate">{{ order.company.name }} · {{ order.totalQuantity }} pc</div>
                            </div>
                            <div class="text-right shrink-0">
                                <div class="text-xs font-semibold text-[var(--color-destructive)]">{{ elapsed_hours }}h</div>
                                <div class="text-[10px] text-[var(--color-secondary)]">{{ order.placedAt|date('d/m H:i') }}</div>
                            </div>
                        </a>
                    </li>
                {% endfor %}
            </ul>
        {% endif %}
    </div>

    {# CA mois + graph #}
    <div class="card p-6 lg:col-span-2">
        <div class="flex items-start justify-between mb-4">
            <div>
                <div class="text-xs font-medium text-[var(--color-secondary)] uppercase tracking-wide mb-1">Chiffre d'affaires — {{ "now"|date('MMMM', 'fr') }}</div>
                <div class="flex items-baseline gap-3">
                    <div class="font-display text-3xl font-semibold text-[var(--color-primary)]">{{ month.revenue_cents|price }}</div>
                    {% if month.growth is not null %}
                        <span class="text-sm font-medium {{ month.growth >= 0 ? 'text-emerald-600' : 'text-[var(--color-destructive)]' }}">
                            {{ month.growth >= 0 ? '▲' : '▼' }} {{ month.growth|abs }}%
                        </span>
                    {% endif %}
                </div>
                <p class="text-xs text-[var(--color-secondary)] mt-0.5">{{ month.orders }} commande{{ month.orders > 1 ? 's' : '' }} · vs mois précédent</p>
            </div>
        </div>

        {# 30 day bar chart #}
        <div class="space-y-2">
            <div class="flex items-end gap-[2px] h-32">
                {% for point in daily_chart %}
                    {% set pct = max_daily > 0 ? (point.value / max_daily * 100)|round : 0 %}
                    <div class="flex-1 h-full flex items-end group relative">
                        <div class="w-full rounded-t-sm {{ point.value > 0 ? 'bg-[var(--color-primary)]/70 hover:bg-[var(--color-primary)]' : 'bg-[var(--color-muted)]' }} transition-colors {{ point.value > 0 ? 'min-h-[3px]' : 'h-[2px]' }}"
                             style="{{ point.value > 0 ? 'height: ' ~ pct ~ '%' : '' }}"
                             title="{{ point.day|date('d/m') }} · {{ point.value|price }}"></div>
                    </div>
                {% endfor %}
            </div>
            <div class="flex justify-between text-[10px] text-[var(--color-secondary)]">
                <span>{{ daily_chart|first.day|date('d/m') }}</span>
                <span>{{ daily_chart[14].day|date('d/m') }}</span>
                <span>{{ daily_chart|last.day|date('d/m') }}</span>
            </div>
        </div>
    </div>
</section>

{# === Activité + Top clients === #}
<section class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
    {# Activité récente (live) #}
    <div id="admin-activity-frame" class="card p-6 lg:col-span-2"
         data-controller="poll"
         data-poll-url-value="{{ path('app_admin') }}"
         data-poll-interval-value="15000">
        <div class="flex items-center justify-between mb-4">
            <div>
                <h2 class="font-display font-semibold text-[var(--color-foreground)]">Activité récente</h2>
                <p class="text-xs text-[var(--color-secondary)] mt-0.5 flex items-center gap-1.5">
                    <span class="relative flex w-1.5 h-1.5">
                        <span class="absolute inline-flex w-full h-full rounded-full bg-emerald-500 opacity-60 animate-ping"></span>
                        <span class="relative inline-flex rounded-full w-1.5 h-1.5 bg-emerald-500"></span>
                    </span>
                    Mise à jour auto
                </p>
            </div>
        </div>
        {% if recent_orders is empty %}
            <p class="text-sm text-[var(--color-secondary)] text-center py-8">Aucune activité récente.</p>
        {% else %}
            <ol class="space-y-3">
                {% for order in recent_orders %}
                    {% set tile = status_tile_classes(order.status) %}
                    <li class="flex items-center gap-3 p-2 rounded-md hover:bg-[var(--color-muted)]">
                        <div class="w-9 h-9 shrink-0 rounded-lg {{ tile[0] }} {{ tile[1] }} flex items-center justify-center">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5.586a1 1 0 0 1 .707.293l5.414 5.414a1 1 0 0 1 .293.707V19a2 2 0 0 1-2 2Z"/></svg>
                        </div>
                        <div class="flex-1 min-w-0">
                            <a href="{{ path('app_admin_order_detail', {reference: order.reference}) }}" class="font-medium text-sm text-[var(--color-foreground)] hover:text-[var(--color-primary)]">{{ order.reference }}</a>
                            <div class="text-xs text-[var(--color-secondary)] flex items-center gap-2">
                                <span>{{ order.company.name }}</span>
                                <span>·</span>
                                <span class="badge border {{ status_badge_class(order.status) }}">{{ order.status.label() }}</span>
                            </div>
                        </div>
                        <div class="text-xs text-[var(--color-secondary)] whitespace-nowrap">
                            {{ (order.updatedAt ?? order.createdAt)|date('d/m H:i') }}
                        </div>
                    </li>
                {% endfor %}
            </ol>
        {% endif %}
    </div>

    {# Top clients #}
    <div class="card p-6">
        <h2 class="font-display font-semibold text-[var(--color-foreground)] mb-1">Top clients</h2>
        <p class="text-xs text-[var(--color-secondary)] mb-4">Ce mois · CA HT</p>
        {% if top_clients is empty %}
            <p class="text-sm text-[var(--color-secondary)] text-center py-6">Pas encore de commandes ce mois.</p>
        {% else %}
            <ul class="space-y-3">
                {% for c in top_clients %}
                    <li class="flex items-center justify-between gap-3">
                        <div class="flex items-center gap-3 min-w-0">
                            <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-[var(--color-primary-light)] text-[var(--color-primary)] text-xs font-bold shrink-0">{{ loop.index }}</span>
                            <div class="min-w-0">
                                <div class="font-medium text-sm text-[var(--color-foreground)] truncate">{{ c.name }}</div>
                                <div class="text-xs text-[var(--color-secondary)]">{{ c.orders_count }} cmd</div>
                            </div>
                        </div>
                        <span class="font-display font-semibold text-sm text-[var(--color-primary)]">{{ c.revenue|price }}</span>
                    </li>
                {% endfor %}
            </ul>
        {% endif %}
    </div>
</section>

{# === Pipeline === #}
<section class="card p-6 mb-6">
    <div class="flex items-center justify-between mb-4">
        <h2 class="font-display font-semibold text-[var(--color-foreground)]">Pipeline</h2>
        <a href="{{ path('app_admin_orders') }}" class="text-xs font-medium text-[var(--color-primary)] hover:underline">Voir toutes les commandes →</a>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        {% for step in pipeline %}
            {% set tile = status_tile_classes(step.status) %}
            <a href="{{ path('app_admin_orders', {status: step.status.value}) }}"
               class="relative p-4 rounded-lg border border-[var(--color-border-soft)] hover:border-[var(--color-border)] hover:shadow-sm transition-all">
                <div class="flex items-center gap-2 mb-2">
                    <span class="w-1.5 h-1.5 rounded-full {{ status_dot_class(step.status) }}"></span>
                    <span class="text-xs font-medium text-[var(--color-secondary)]">{{ step.status.label() }}</span>
                </div>
                <div class="font-display text-2xl font-semibold {{ tile[1] }}">{{ step.count }}</div>
            </a>
        {% endfor %}
    </div>
</section>

{# === Alertes === #}
{% if stuck_orders|length > 0 or inactive_companies|length > 0 %}
    <section class="card p-6 border border-amber-200 bg-amber-50/50">
        <div class="flex items-center gap-2 mb-4">
            <svg class="w-5 h-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/></svg>
            <h2 class="font-display font-semibold text-[var(--color-foreground)]">Alertes</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {% if stuck_orders|length > 0 %}
                <div>
                    <div class="text-xs font-medium text-[var(--color-secondary)] uppercase tracking-wide mb-2">
                        Commandes bloquées (>48h)
                    </div>
                    <ul class="space-y-1.5">
                        {% for order in stuck_orders|slice(0, 5) %}
                            <li>
                                <a href="{{ path('app_admin_order_detail', {reference: order.reference}) }}" class="flex items-center justify-between gap-2 text-sm hover:text-[var(--color-primary)]">
                                    <span class="font-mono font-medium">{{ order.reference }}</span>
                                    <span class="text-xs text-[var(--color-secondary)]">{{ order.company.name }}</span>
                                </a>
                            </li>
                        {% endfor %}
                    </ul>
                </div>
            {% endif %}
            {% if inactive_companies|length > 0 %}
                <div>
                    <div class="text-xs font-medium text-[var(--color-secondary)] uppercase tracking-wide mb-2">
                        Clients inactifs (>60j)
                    </div>
                    <ul class="space-y-1.5">
                        {% for c in inactive_companies|slice(0, 5) %}
                            <li class="flex items-center justify-between gap-2 text-sm">
                                <span class="font-medium text-[var(--color-foreground)]">{{ c.name }}</span>
                                <span class="text-xs text-[var(--color-secondary)]">
                                    {% if c.last_order %}
                                        {{ c.last_order|date('d/m/Y') }}
                                    {% else %}
                                        Jamais
                                    {% endif %}
                                </span>
                            </li>
                        {% endfor %}
                    </ul>
                </div>
            {% endif %}
        </div>
    </section>
{% endif %}
{% endblock %}
