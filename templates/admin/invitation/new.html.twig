{% extends 'dashboard/_shell.html.twig' %}

{% block title %}Nouvelle invitation — Admin{% endblock %}

{% block content %}
<div class="mb-8">
    <a href="{{ path('app_admin_invitations') }}" class="text-sm text-[var(--color-secondary)] hover:text-[var(--color-primary)]">&larr; Retour aux invitations</a>
    <h1 class="text-3xl font-semibold text-[var(--color-primary)] mt-2 mb-2">Nouvelle invitation</h1>
    <p class="text-[var(--color-secondary)]">Un lien d'inscription valable 7 jours sera généré.</p>
</div>

<form method="post" class="max-w-lg bg-white rounded-xl border border-[var(--color-border)] shadow-sm p-6 space-y-4">
    <label class="block">
        <span class="text-sm font-medium text-[var(--color-foreground)] mb-1.5 block">Email du client <span class="text-[var(--color-destructive)]">*</span></span>
        <input type="email" name="email" value="{{ email }}" required
            class="w-full px-3 py-2 rounded-md border {{ errors.email is defined ? 'border-[var(--color-destructive)]' : 'border-[var(--color-border)]' }} bg-white focus-visible:outline-2 focus-visible:outline-[var(--color-ring)]">
        {% if errors.email is defined %}
            <span class="text-xs text-[var(--color-destructive)] mt-1 block">{{ errors.email }}</span>
        {% endif %}
    </label>

    <label class="block">
        <span class="text-sm font-medium text-[var(--color-foreground)] mb-1.5 block">Entreprise <span class="text-[var(--color-destructive)]">*</span></span>
        <select name="company_id" required
            class="w-full px-3 py-2 rounded-md border {{ errors.company is defined ? 'border-[var(--color-destructive)]' : 'border-[var(--color-border)]' }} bg-white focus-visible:outline-2 focus-visible:outline-[var(--color-ring)]">
            <option value="">— Choisir une entreprise —</option>
            {% for c in companies %}
                <option value="{{ c.id }}" {{ company_id == c.id ? 'selected' }}>{{ c.name }}</option>
            {% endfor %}
        </select>
        {% if errors.company is defined %}
            <span class="text-xs text-[var(--color-destructive)] mt-1 block">{{ errors.company }}</span>
        {% endif %}
    </label>

    <div class="flex gap-3 pt-2">
        <button type="submit" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md bg-[var(--color-primary)] text-[var(--color-on-primary)] font-medium cursor-pointer transition-colors duration-200 hover:bg-[var(--color-secondary)]">
            Créer l'invitation
        </button>
        <a href="{{ path('app_admin_invitations') }}" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md border border-[var(--color-border)] text-[var(--color-foreground)] font-medium cursor-pointer transition-colors duration-200 hover:bg-[var(--color-muted)]">
            Annuler
        </a>
    </div>
</form>
{% endblock %}
