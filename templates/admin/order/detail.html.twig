{% extends 'dashboard/_shell.html.twig' %}

{% block title %}{{ order.reference }} — Admin{% endblock %}

{% block content %}
<a href="{{ path('app_admin_orders') }}" class="text-sm text-[var(--color-secondary)] hover:text-[var(--color-foreground)] mb-4 inline-block">&larr; Toutes les commandes</a>

<div class="flex flex-wrap items-start justify-between gap-4 mb-8">
    <div>
        <div class="text-xs font-medium text-[var(--color-secondary)] uppercase tracking-wide mb-1">Commande</div>
        <h1 class="font-display text-2xl font-mono font-semibold text-[var(--color-foreground)]">{{ order.reference }}</h1>
        <p class="text-sm text-[var(--color-secondary)] mt-1">{{ order.company.name }} · {{ order.createdBy.fullName }} · {{ (order.placedAt ?? order.createdAt)|date('d/m/Y à H:i') }}</p>
    </div>
    <span class="badge border {{ status_badge_class(order.status) }}">
        <span class="w-2 h-2 rounded-full {{ status_dot_class(order.status) }}"></span>
        {{ order.status.label() }}
    </span>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 space-y-6">
        {% if order.status.value in ['confirmed', 'in_production', 'shipped', 'delivered'] %}
            <section class="card p-6">
                <h2 class="font-display text-base font-semibold text-[var(--color-foreground)] mb-4 flex items-center gap-2">
                    <svg class="w-5 h-5 text-[var(--color-primary)]" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25"/></svg>
                    Expédition
                </h2>
                <form method="post" action="{{ path('app_admin_order_shipping', {reference: order.reference}) }}" class="grid grid-cols-1 md:grid-cols-3 gap-3">
                    <label class="block">
                        <span class="form-label">Transporteur</span>
                        <select name="carrier" class="form-input mt-1.5">
                            <option value="">—</option>
                            {% for c in ['Chronopost', 'Colissimo', 'DPD', 'UPS', 'Autre'] %}
                                <option value="{{ c }}" {{ order.carrier == c ? 'selected' }}>{{ c }}</option>
                            {% endfor %}
                        </select>
                    </label>
                    <label class="block">
                        <span class="form-label">N° de suivi</span>
                        <input type="text" name="tracking_number" value="{{ order.trackingNumber }}" placeholder="Ex. 1Z999AA10123456784" class="form-input mt-1.5 font-mono text-sm">
                    </label>
                    <label class="block">
                        <span class="form-label">Livraison estimée</span>
                        <input type="date" name="estimated_delivery_at" value="{{ order.estimatedDeliveryAt ? order.estimatedDeliveryAt|date('Y-m-d') : '' }}" class="form-input mt-1.5">
                    </label>
                    <div class="md:col-span-3 flex justify-end">
                        <button type="submit" class="btn btn-outline text-sm">Enregistrer l'expédition</button>
                    </div>
                </form>
            </section>
        {% endif %}

        {% if allowed_transitions is not empty %}
            <section class="card p-6">
                <h2 class="font-display text-base font-semibold text-[var(--color-foreground)] mb-4">Actions</h2>
                <div class="flex flex-wrap gap-3">
                    {% for next_status in allowed_transitions %}
                        <form method="post" action="{{ path('app_admin_order_transition', {reference: order.reference}) }}"
                              {% if next_status.value == 'cancelled' %}
                                  data-controller="confirm"
                                  data-confirm-title-value="Annuler la commande {{ order.reference }} ?"
                                  data-confirm-message-value="Le client sera notifié de l'annulation. Cette action est irréversible."
                                  data-confirm-label-value="Annuler la commande"
                                  data-action="submit->confirm#gate"
                              {% endif %}>
                            <input type="hidden" name="status" value="{{ next_status.value }}">
                            <button type="submit" class="btn {{ next_status.value == 'cancelled' ? 'btn-error' : 'btn-primary' }}">
                                {% if next_status.value == 'confirmed' %}
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                                {% elseif next_status.value == 'shipped' %}
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25"/></svg>
                                {% endif %}
                                {{ next_status.label() }}
                            </button>
                        </form>
                    {% endfor %}
                </div>
            </section>
        {% endif %}

        <section id="order-items-{{ order.id }}"
                 class="card overflow-hidden"
                 data-controller="poll"
                 data-poll-url-value="{{ path('app_admin_order_detail', {reference: order.reference}) }}"
                 data-poll-interval-value="5000">
            <div class="flex items-center justify-between px-6 py-4 border-b border-[var(--color-border-soft)] gap-3 flex-wrap">
                <h2 class="font-display text-base font-semibold text-[var(--color-foreground)]">Articles</h2>
                {% if has_pending_bats %}
                    <form method="post" action="{{ path('app_bat_approve_all', {reference: order.reference}) }}"
                          data-controller="confirm"
                          data-confirm-title-value="Valider tous les BAT en attente ?"
                          data-confirm-message-value="Tous les BAT pending de cette commande seront approuvés en une opération."
                          data-confirm-label-value="Valider tous"
                          data-action="submit->confirm#gate">
                        <button type="submit" class="btn btn-primary text-xs !py-1.5 !px-3">
                            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                            Valider tous les BAT
                        </button>
                    </form>
                {% endif %}
            </div>
            <div class="divide-y divide-[var(--color-border-soft)]">
                {% for item in order.items %}
                    <div class="p-4 space-y-3">
                        <div class="flex items-center justify-between gap-4">
                            <div class="min-w-0 flex-1">
                                <div class="font-medium text-[var(--color-foreground)]">{{ item.variant.product.name }}</div>
                                <div class="text-sm text-[var(--color-secondary)] flex items-center gap-2 mt-1 flex-wrap">
                                    <span class="w-3 h-3 rounded-full border border-[var(--color-border)]" style="background-color: {{ item.variant.colorHex }}"></span>
                                    {{ item.variant.color }} · {{ item.variant.size }}
                                    <span class="font-mono text-xs">{{ item.variant.sku }}</span>
                                </div>
                                {% if item.marking %}
                                    <div class="text-xs text-[var(--color-secondary)] mt-1">Marquage : {{ item.marking.zone|capitalize }} ({{ item.marking.size }})</div>
                                {% endif %}
                            </div>
                            <div class="text-right">
                                <div class="text-sm text-[var(--color-secondary)]">{{ item.quantity }} × {{ item.unitPriceCents|price }}</div>
                                <div class="font-semibold">{{ (item.quantity * item.unitPriceCents)|price }}</div>
                            </div>
                        </div>

                        {% if item.marking and item.marking.zone %}
                            {% set assets_all = item.markingAssets|filter(a => true) %}
                            {% set latest = item.latestMarkingAsset %}
                            <div class="rounded-lg border border-[var(--color-border-soft)] bg-[var(--color-muted)]/40 p-3 space-y-2">
                                <div class="flex items-center gap-2 text-xs font-semibold text-[var(--color-foreground)]">
                                    <svg class="w-4 h-4 text-[var(--color-primary)]" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
                                    BAT marquage
                                </div>

                                {% if latest is null %}
                                    <p class="text-xs text-[var(--color-secondary)]">En attente d'un logo client.</p>
                                {% else %}
                                    <div class="flex items-start gap-3">
                                        {% if latest.logoPath ends with '.pdf' %}
                                            <a href="{{ latest.logoPath }}" target="_blank" rel="noopener" class="w-20 h-20 shrink-0 rounded-md border border-[var(--color-border)] bg-white flex items-center justify-center text-[var(--color-secondary)] hover:border-[var(--color-primary)]">
                                                <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/></svg>
                                            </a>
                                        {% else %}
                                            <a href="{{ latest.logoPath }}" target="_blank" rel="noopener" class="w-20 h-20 shrink-0 rounded-md overflow-hidden border border-[var(--color-border)] bg-white">
                                                <img src="{{ latest.logoPath }}" alt="BAT v{{ latest.version }}" class="w-full h-full object-contain">
                                            </a>
                                        {% endif %}
                                        <div class="flex-1 min-w-0 text-xs space-y-1">
                                            <div class="flex items-center gap-2 flex-wrap">
                                                <span class="font-medium text-[var(--color-foreground)]">BAT v{{ latest.version }}</span>
                                                {% if latest.isApproved() %}
                                                    <span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded-full bg-emerald-50 text-emerald-700 border border-emerald-200">
                                                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>Validé
                                                    </span>
                                                {% elseif latest.isRejected() %}
                                                    <span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded-full bg-[var(--color-destructive)]/10 text-[var(--color-destructive)] border border-[var(--color-destructive)]/30">
                                                        <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-destructive)]"></span>Refusé
                                                    </span>
                                                {% else %}
                                                    <span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded-full bg-amber-50 text-amber-800 border border-amber-200">
                                                        <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>À valider
                                                    </span>
                                                {% endif %}
                                                <span class="text-[var(--color-secondary)]">· envoyé par {{ latest.uploadedBy.fullName }}</span>
                                            </div>
                                            {% if latest.feedback %}
                                                <p class="text-[var(--color-destructive)]">Motif : {{ latest.feedback }}</p>
                                            {% endif %}
                                            {% if assets_all|length > 1 %}
                                                <details class="text-[var(--color-secondary)]">
                                                    <summary class="cursor-pointer hover:text-[var(--color-foreground)]">Historique ({{ assets_all|length }} versions)</summary>
                                                    <ul class="mt-1 space-y-0.5 pl-3 border-l border-[var(--color-border-soft)]">
                                                        {% for a in assets_all %}
                                                            <li>v{{ a.version }} · {{ a.status.label() }} · {{ a.createdAt|date('d/m H:i') }}{% if a.feedback %} — {{ a.feedback }}{% endif %}</li>
                                                        {% endfor %}
                                                    </ul>
                                                </details>
                                            {% endif %}
                                        </div>
                                    </div>
                                    {% if latest.isPending() %}
                                        <div class="pt-2 border-t border-[var(--color-border-soft)] flex flex-wrap gap-2" data-controller="bat-review">
                                            <form method="post" action="{{ path('app_bat_approve', {reference: order.reference, asset: latest.id}) }}">
                                                <button type="submit" class="btn btn-primary text-xs !py-1.5 !px-3">
                                                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                                                    Valider le BAT
                                                </button>
                                            </form>
                                            <button type="button" data-action="click->bat-review#toggleReject" class="btn btn-outline text-xs !py-1.5 !px-3 text-[var(--color-destructive)] border-[var(--color-destructive)]/40 hover:bg-[var(--color-destructive)]/5">
                                                Refuser…
                                            </button>
                                            <form data-bat-review-target="rejectForm" method="post" action="{{ path('app_bat_reject', {reference: order.reference, asset: latest.id}) }}" class="hidden basis-full mt-2 space-y-2">
                                                <textarea name="feedback" rows="2" required placeholder="Motif du refus (ex. résolution insuffisante, couleurs non conformes…)" class="form-input text-xs !py-2"></textarea>
                                                <div class="flex justify-end gap-2">
                                                    <button type="button" data-action="click->bat-review#toggleReject" class="btn btn-outline text-xs !py-1.5 !px-3">Annuler</button>
                                                    <button type="submit" class="btn btn-error text-xs !py-1.5 !px-3">Envoyer le refus</button>
                                                </div>
                                            </form>
                                        </div>
                                    {% endif %}
                                {% endif %}
                            </div>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
            <div class="flex justify-between items-center p-4 bg-[var(--color-muted)] border-t border-[var(--color-border-soft)]">
                <span class="text-[var(--color-secondary)]">Total HT</span>
                <span class="text-xl font-semibold text-[var(--color-primary)]">{{ order.totalCents|price }}</span>
            </div>
        </section>

        {% if order.notes %}
            <section class="card p-6">
                <h2 class="font-display text-base font-semibold text-[var(--color-foreground)] mb-2">Notes du client</h2>
                <p class="text-[var(--color-body)] whitespace-pre-line">{{ order.notes }}</p>
            </section>
        {% endif %}
    </div>

    <aside class="space-y-6">
        {{ include('order/_conversation.html.twig', {order: order, messages: messages|default([]), is_admin: true}) }}

        <section id="order-tracking-{{ order.id }}"
                 class="card p-6"
                 data-controller="poll"
                 data-poll-url-value="{{ path('app_admin_order_detail', {reference: order.reference}) }}"
                 data-poll-interval-value="5000">
            <div class="flex items-center justify-between mb-4">
                <h2 class="font-display text-base font-semibold text-[var(--color-foreground)]">Historique</h2>
                <span class="inline-flex items-center gap-1.5 text-xs text-[var(--color-secondary)]">
                    <span class="relative flex w-1.5 h-1.5">
                        <span class="absolute inline-flex w-full h-full rounded-full bg-emerald-500 opacity-60 animate-ping"></span>
                        <span class="relative inline-flex rounded-full w-1.5 h-1.5 bg-emerald-500"></span>
                    </span>
                    Live
                </span>
            </div>
            {% if events is empty %}
                <p class="text-sm text-[var(--color-secondary)]">Aucun événement enregistré.</p>
            {% else %}
                {{ include('order/_timeline.html.twig', {events: events, is_admin: true}) }}
            {% endif %}
        </section>

        <section class="card p-6">
            <h2 class="font-display text-base font-semibold text-[var(--color-foreground)] mb-3">Livraison</h2>
            <div class="font-medium text-[var(--color-foreground)]">{{ order.antenna.name }}</div>
            <div class="text-sm text-[var(--color-secondary)]">{{ order.antenna.fullAddress }}</div>
            {% if order.antenna.phone %}<div class="text-sm text-[var(--color-secondary)] mt-1">{{ order.antenna.phone }}</div>{% endif %}
            {% if order.antenna.contactName %}
                <div class="mt-3 pt-3 border-t border-[var(--color-border-soft)]">
                    <div class="text-xs font-medium text-[var(--color-secondary)] uppercase tracking-wide mb-1">Contact</div>
                    <div class="font-medium text-[var(--color-foreground)]">{{ order.antenna.contactName }}</div>
                    {% if order.antenna.contactEmail %}<a href="mailto:{{ order.antenna.contactEmail }}" class="link text-sm block">{{ order.antenna.contactEmail }}</a>{% endif %}
                    {% if order.antenna.contactPhone %}<div class="text-sm text-[var(--color-secondary)]">{{ order.antenna.contactPhone }}</div>{% endif %}
                </div>
            {% endif %}
            {% if order.antenna.notes %}
                <div class="mt-3 pt-3 border-t border-[var(--color-border-soft)]">
                    <div class="text-xs font-medium text-[var(--color-secondary)] uppercase tracking-wide mb-1">Notes antenne</div>
                    <p class="text-sm text-[var(--color-body)] whitespace-pre-line">{{ order.antenna.notes }}</p>
                </div>
            {% endif %}
        </section>
    </aside>
</div>
{% endblock %}
