{% extends 'dashboard/_shell.html.twig' %}

{% block title %}{{ is_new ? 'Nouveau produit' : product.name }} — Admin{% endblock %}

{% block content %}
<a href="{{ path('app_admin_products') }}" class="text-sm text-[var(--color-secondary)] hover:text-[var(--color-foreground)] mb-4 inline-block">&larr; Tous les produits</a>

<div class="mb-8 flex flex-wrap items-start justify-between gap-4">
    <div>
        <div class="text-xs font-medium text-[var(--color-secondary)] uppercase tracking-wide mb-1">{{ is_new ? 'Nouveau produit' : 'Modifier' }}</div>
        <h1 class="font-display text-2xl font-semibold text-[var(--color-foreground)]">{{ is_new ? 'Nouveau produit' : product.name }}</h1>
        {% if not is_new %}
            <div class="mt-2">
                {% if product.status.value == 'published' %}
                    <span class="badge border bg-emerald-50 text-emerald-700 border-emerald-200">
                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                        Publié · visible par les clients
                    </span>
                {% else %}
                    <span class="badge border bg-slate-50 text-slate-700 border-slate-200">
                        <span class="w-1.5 h-1.5 rounded-full bg-slate-400"></span>
                        Brouillon · invisible pour les clients
                    </span>
                {% endif %}
            </div>
        {% endif %}
    </div>
    {% if not is_new %}
        <div class="flex flex-wrap gap-2">
            {% if product.status.value == 'published' %}
                <form method="post" action="{{ path('app_admin_product_unpublish', {id: product.id}) }}"
                      data-controller="confirm"
                      data-confirm-title-value="Dépublier {{ product.name }} ?"
                      data-confirm-message-value="Le produit ne sera plus visible par les clients. Les commandes existantes restent inchangées."
                      data-confirm-label-value="Dépublier"
                      data-action="submit->confirm#gate">
                    <button type="submit" class="btn btn-outline">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 0 0 1.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.451 10.451 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.522 10.522 0 0 1-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21m-3.228-3.228-3.65-3.65m0 0a3 3 0 1 0-4.243-4.243m4.242 4.242L9.88 9.88"/></svg>
                        Dépublier
                    </button>
                </form>
            {% else %}
                <form method="post" action="{{ path('app_admin_product_publish', {id: product.id}) }}">
                    <button type="submit" class="btn btn-primary">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/></svg>
                        Publier
                    </button>
                </form>
                <form method="post" action="{{ path('app_admin_product_delete', {id: product.id}) }}"
                      data-controller="confirm"
                      data-confirm-title-value="Supprimer {{ product.name }} ?"
                      data-confirm-message-value="Le produit et ses variantes seront définitivement supprimés. Cette action est irréversible."
                      data-confirm-label-value="Supprimer"
                      data-action="submit->confirm#gate">
                    <button type="submit" class="btn btn-error">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166M18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397"/></svg>
                        Supprimer
                    </button>
                </form>
            {% endif %}
        </div>
    {% endif %}
</div>

<form method="post" enctype="multipart/form-data" class="space-y-6" data-controller="variants-editor">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        {# Col 1 — Informations #}
        <section class="card p-6 lg:col-span-2 space-y-4">
            <h2 class="font-display font-semibold text-[var(--color-foreground)] mb-2">Informations</h2>

            <label class="block">
                <span class="form-label">Nom <span class="text-[var(--color-destructive)]">*</span></span>
                <input type="text" name="name" value="{{ is_new ? '' : product.name }}" required
                    placeholder="Ex. T-shirt Premium"
                    class="form-input mt-1.5 {{ errors.name is defined ? '!border-[var(--color-destructive)]' : '' }}">
                {% if errors.name is defined %}<span class="text-xs text-[var(--color-destructive)] mt-1 block">{{ errors.name }}</span>{% endif %}
            </label>

            <div class="grid grid-cols-2 gap-3">
                <label class="block">
                    <span class="form-label">Catégorie</span>
                    <input type="text" name="category" value="{{ is_new ? '' : (product.category ?? '') }}"
                        placeholder="Ex. T-shirt"
                        list="categories"
                        class="form-input mt-1.5">
                    <datalist id="categories">
                        <option value="T-shirt">
                        <option value="Polo">
                        <option value="Sweat">
                        <option value="Couvre-chef">
                        <option value="Accessoire">
                    </datalist>
                </label>
                <label class="block">
                    <span class="form-label">Matière</span>
                    <input type="text" name="material" value="{{ is_new ? '' : (product.material ?? '') }}"
                        placeholder="Ex. Coton bio 180g/m²"
                        class="form-input mt-1.5">
                </label>
            </div>

            <label class="block">
                <span class="form-label">Description</span>
                <textarea name="description" rows="4" placeholder="Description qui sera visible par les clients..."
                    class="form-input mt-1.5">{{ is_new ? '' : (product.description ?? '') }}</textarea>
            </label>
        </section>

        {# Col 2 — Prix #}
        <section class="card p-6 space-y-4">
            <h2 class="font-display font-semibold text-[var(--color-foreground)] mb-2">Tarif</h2>

            <label class="block">
                <span class="form-label">Prix HT de base <span class="text-[var(--color-destructive)]">*</span></span>
                <div class="flex items-stretch mt-1.5 rounded-md border {{ errors.base_price is defined ? 'border-[var(--color-destructive)]' : 'border-[var(--color-border)]' }} bg-white focus-within:border-[var(--color-primary)] focus-within:ring-2 focus-within:ring-[var(--color-primary)]/20 overflow-hidden">
                    <input type="text" name="base_price" value="{{ is_new ? '' : (product.basePriceCents / 100)|number_format(2, ',', '') }}" required
                        placeholder="0,00"
                        class="flex-1 min-w-0 px-3 py-2 bg-transparent text-right font-mono text-sm focus:outline-none">
                    <span class="flex items-center px-3 bg-[var(--color-muted)] text-[var(--color-secondary)] text-sm border-l border-[var(--color-border)]">€</span>
                </div>
                {% if errors.base_price is defined %}<span class="text-xs text-[var(--color-destructive)] mt-1 block">{{ errors.base_price }}</span>{% endif %}
                <p class="text-xs text-[var(--color-secondary)] mt-1.5">Prix unitaire affiché aux clients.</p>
            </label>
        </section>
    </div>

    {# Images #}
    <section class="card p-6">
        <div class="flex items-center justify-between mb-4">
            <div>
                <h2 class="font-display font-semibold text-[var(--color-foreground)]">Images</h2>
                <p class="text-xs text-[var(--color-secondary)] mt-0.5">JPG, PNG, WebP ou GIF. La 1ère image sert de visuel principal.</p>
            </div>
        </div>

        {% if not is_new and product.imagePaths|length > 0 %}
            {% set colors_avail = [] %}
            {% for v in product.variants %}
                {% if v.color not in colors_avail %}{% set colors_avail = colors_avail|merge([v.color]) %}{% endif %}
            {% endfor %}
            <div data-controller="image-sort" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3 mb-4" data-image-sort-target="grid">
                {% for img in product.images %}
                    <div data-controller="image-remove" data-image-sort-target="item" data-path="{{ img.path }}" class="relative rounded-lg overflow-hidden border border-[var(--color-border-soft)] aspect-square bg-white flex flex-col">
                        <input type="hidden" name="existing_images[{{ loop.index0 }}][path]" value="{{ img.path }}" data-image-sort-target="pathInput">
                        <input type="hidden" name="remove_images[]" value="{{ img.path }}" data-image-remove-target="input" disabled>
                        <div class="relative flex-1">
                            <img src="{{ img.path }}" alt="" class="w-full h-full object-cover">
                            <span data-image-sort-target="handle" class="absolute top-2 left-2 w-7 h-7 rounded-md bg-white/90 shadow-sm flex items-center justify-center cursor-grab active:cursor-grabbing text-[var(--color-secondary)]" title="Glisser pour réordonner">
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9h16.5m-16.5 6.75h16.5"/></svg>
                            </span>
                            <button type="button"
                                    data-action="click->image-remove#remove"
                                    title="Retirer l'image"
                                    aria-label="Retirer l'image"
                                    class="absolute top-2 right-2 z-10 w-7 h-7 rounded-full bg-white/95 shadow-sm flex items-center justify-center cursor-pointer hover:bg-[var(--color-destructive)] hover:text-white text-[var(--color-destructive)] transition-colors">
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/></svg>
                            </button>
                            <span data-image-sort-target="primaryBadge" class="{{ loop.first ? '' : 'hidden' }} absolute bottom-2 left-2 px-1.5 py-0.5 rounded bg-[var(--color-primary)] text-white text-[10px] font-semibold uppercase tracking-wide pointer-events-none">Principal</span>
                        </div>
                        <div class="p-2 border-t border-[var(--color-border-soft)] bg-white">
                            <select name="existing_images[{{ loop.index0 }}][color]" class="form-input text-xs !py-1">
                                <option value="">Toutes couleurs</option>
                                {% for c in colors_avail %}
                                    <option value="{{ c }}" {{ img.color == c ? 'selected' }}>{{ c }}</option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>
                {% endfor %}
            </div>
            <p class="text-xs text-[var(--color-secondary)] mb-3">Glissez pour réordonner · la 1ère image est le visuel principal · associez une couleur pour afficher l'image sur les lignes/filtre correspondants.</p>
        {% endif %}

        <div data-controller="image-preview">
            <label class="flex flex-col items-center justify-center gap-2 p-6 rounded-lg border-2 border-dashed border-[var(--color-border)] cursor-pointer hover:border-[var(--color-primary)] hover:bg-[var(--color-primary-light)]/40 transition-colors">
                <svg class="w-8 h-8 text-[var(--color-secondary)]" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0 3 3m-3-3-3 3M6.75 19.5a4.5 4.5 0 0 1-1.41-8.775 5.25 5.25 0 0 1 10.233-2.33 3 3 0 0 1 3.758 3.848A3.752 3.752 0 0 1 18 19.5H6.75Z"/></svg>
                <span class="text-sm text-[var(--color-foreground)] font-medium">Ajouter des images</span>
                <span class="text-xs text-[var(--color-secondary)]">Cliquez ou déposez des fichiers</span>
                <input type="file" name="images[]" accept="image/*" multiple
                    data-action="change->image-preview#show"
                    data-image-preview-target="input"
                    class="sr-only">
            </label>
            <div data-image-preview-target="preview"
                 class="hidden mt-4 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3"></div>
        </div>
    </section>

    {# Variants #}
    <section class="card p-6">
        <div class="flex items-center justify-between mb-4">
            <div>
                <h2 class="font-display font-semibold text-[var(--color-foreground)]">Variantes</h2>
                <p class="text-xs text-[var(--color-secondary)] mt-0.5">Taille × couleur. Au moins 1 variante pour publier.</p>
                {% if errors.variants is defined %}<p class="text-xs text-[var(--color-destructive)] mt-1 font-medium">{{ errors.variants }}</p>{% endif %}
            </div>
            <button type="button" data-action="variants-editor#add" class="btn btn-outline text-sm">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
                Ajouter
            </button>
        </div>

        <div data-variants-editor-target="list" class="space-y-2">
            {% for v in is_new ? [] : product.variants %}
                <div class="grid grid-cols-12 gap-2 items-center p-3 rounded-md border border-[var(--color-border-soft)]" data-variants-editor-target="row">
                    <input type="hidden" name="variants[{{ loop.index0 }}][id]" value="{{ v.id }}">
                    <input type="text" name="variants[{{ loop.index0 }}][size]" value="{{ v.size }}" required placeholder="S" class="form-input col-span-2 text-center">
                    <input type="text" name="variants[{{ loop.index0 }}][color]" value="{{ v.color }}" required placeholder="Blanc" class="form-input col-span-3">
                    <div class="col-span-1 relative" data-controller="color-picker">
                        <input type="hidden" name="variants[{{ loop.index0 }}][color_hex]" value="{{ v.colorHex ?? '#FFFFFF' }}" data-color-picker-target="input">
                        <button type="button" data-action="click->color-picker#toggle" class="w-full h-10 rounded-md border border-[var(--color-border)] cursor-pointer hover:border-[var(--color-primary)] transition-colors">
                            <span data-color-picker-target="swatch" class="block w-full h-full rounded-[5px]"></span>
                        </button>
                        <div data-color-picker-target="panel" class="hidden absolute z-30 left-0 mt-1 w-64 p-3 bg-white border border-[var(--color-border)] rounded-lg shadow-lg"></div>
                    </div>
                    <input type="text" name="variants[{{ loop.index0 }}][sku]" value="{{ v.sku }}" required placeholder="TSHIRT-S-BLC" class="form-input col-span-5 font-mono text-xs">
                    <div class="col-span-1 flex items-center justify-end gap-1">
                        <button type="button" data-action="variants-editor#duplicate" class="inline-flex items-center justify-center h-9 w-9 rounded-md text-[var(--color-secondary)] hover:bg-[var(--color-muted)] hover:text-[var(--color-foreground)]" aria-label="Dupliquer" title="Dupliquer">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 0 1-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H6.75a9.06 9.06 0 0 1 1.5.124m7.5 10.376h3.375c.621 0 1.125-.504 1.125-1.125V11.25c0-4.46-3.243-8.161-7.5-8.876a9.06 9.06 0 0 0-1.5-.124H9.375c-.621 0-1.125.504-1.125 1.125v3.5m7.5 10.375H9.375a1.125 1.125 0 0 1-1.125-1.125v-9.25m12 6.625v-1.875a3.375 3.375 0 0 0-3.375-3.375h-1.5a1.125 1.125 0 0 1-1.125-1.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H9.75"/></svg>
                        </button>
                        <button type="button" data-action="variants-editor#remove" class="inline-flex items-center justify-center h-9 w-9 rounded-md text-[var(--color-destructive)] hover:bg-[var(--color-accent-light)]" aria-label="Retirer" title="Retirer">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/></svg>
                        </button>
                    </div>
                </div>
            {% endfor %}
        </div>

        <template data-variants-editor-target="template">
            <div class="grid grid-cols-12 gap-2 items-center p-3 rounded-md border border-[var(--color-border-soft)]" data-variants-editor-target="row">
                <input type="hidden" name="variants[__INDEX__][id]" value="">
                <input type="text" name="variants[__INDEX__][size]" required placeholder="S" class="form-input col-span-2 text-center">
                <input type="text" name="variants[__INDEX__][color]" required placeholder="Blanc" class="form-input col-span-3">
                <div class="col-span-1 relative" data-controller="color-picker">
                    <input type="hidden" name="variants[__INDEX__][color_hex]" value="#FFFFFF" data-color-picker-target="input">
                    <button type="button" data-action="click->color-picker#toggle" class="w-full h-10 rounded-md border border-[var(--color-border)] cursor-pointer hover:border-[var(--color-primary)] transition-colors">
                        <span data-color-picker-target="swatch" class="block w-full h-full rounded-[5px]"></span>
                    </button>
                    <div data-color-picker-target="panel" class="hidden absolute z-30 left-0 mt-1 w-64 p-3 bg-white border border-[var(--color-border)] rounded-lg shadow-lg"></div>
                </div>
                <input type="text" name="variants[__INDEX__][sku]" required placeholder="TSHIRT-S-BLC" class="form-input col-span-5 font-mono text-xs">
                <div class="col-span-1 flex items-center justify-end gap-1">
                    <button type="button" data-action="variants-editor#duplicate" class="inline-flex items-center justify-center h-9 w-9 rounded-md text-[var(--color-secondary)] hover:bg-[var(--color-muted)] hover:text-[var(--color-foreground)]" aria-label="Dupliquer" title="Dupliquer">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 0 1-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H6.75a9.06 9.06 0 0 1 1.5.124m7.5 10.376h3.375c.621 0 1.125-.504 1.125-1.125V11.25c0-4.46-3.243-8.161-7.5-8.876a9.06 9.06 0 0 0-1.5-.124H9.375c-.621 0-1.125.504-1.125 1.125v3.5m7.5 10.375H9.375a1.125 1.125 0 0 1-1.125-1.125v-9.25m12 6.625v-1.875a3.375 3.375 0 0 0-3.375-3.375h-1.5a1.125 1.125 0 0 1-1.125-1.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H9.75"/></svg>
                    </button>
                    <button type="button" data-action="variants-editor#remove" class="inline-flex items-center justify-center h-9 w-9 rounded-md text-[var(--color-destructive)] hover:bg-[var(--color-accent-light)]" aria-label="Retirer" title="Retirer">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/></svg>
                    </button>
                </div>
            </div>
        </template>

        {% if is_new or product.variants|length == 0 %}
            <p data-variants-editor-target="empty" class="text-center text-sm text-[var(--color-secondary)] py-8">Aucune variante. Cliquez sur « Ajouter ».</p>
        {% endif %}
    </section>

    {# Barème volume #}
    <section class="card p-6" data-controller="price-tiers">
        <div class="flex items-center justify-between mb-4">
            <div>
                <h2 class="font-display font-semibold text-[var(--color-foreground)]">Barème volume</h2>
                <p class="text-xs text-[var(--color-secondary)] mt-0.5">Diminue le prix unitaire selon la quantité totale commandée sur ce produit. Le prix de base s'applique sous le 1er palier.</p>
            </div>
            <button type="button" data-action="price-tiers#add" class="btn btn-outline text-sm">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
                Ajouter un palier
            </button>
        </div>

        <div data-price-tiers-target="list" class="space-y-2">
            {% for t in tiers|default([]) %}
                <div class="grid grid-cols-12 gap-2 items-center p-3 rounded-md border border-[var(--color-border-soft)]" data-price-tiers-target="row">
                    <input type="hidden" name="tiers[{{ loop.index0 }}][id]" value="{{ t.id }}">
                    <label class="col-span-4 block">
                        <span class="text-[10px] uppercase tracking-wide text-[var(--color-secondary)]">À partir de</span>
                        <input type="number" min="1" name="tiers[{{ loop.index0 }}][min_qty]" value="{{ t.minQty }}" required class="form-input mt-1 text-right font-mono" placeholder="50">
                    </label>
                    <div class="col-span-1 text-center text-[var(--color-secondary)] pt-4">pièces</div>
                    <label class="col-span-5 block">
                        <span class="text-[10px] uppercase tracking-wide text-[var(--color-secondary)]">Prix unitaire HT</span>
                        <div class="flex items-stretch mt-1 rounded-md border border-[var(--color-border)] bg-white focus-within:border-[var(--color-primary)] focus-within:ring-2 focus-within:ring-[var(--color-primary)]/20 overflow-hidden">
                            <input type="text" name="tiers[{{ loop.index0 }}][price]" value="{{ (t.unitPriceCents / 100)|number_format(2, ',', '') }}" required class="flex-1 min-w-0 px-3 py-2 bg-transparent text-right font-mono text-sm focus:outline-none" placeholder="12,00">
                            <span class="flex items-center px-3 bg-[var(--color-muted)] text-[var(--color-secondary)] text-sm border-l border-[var(--color-border)]">€</span>
                        </div>
                    </label>
                    <button type="button" data-action="price-tiers#remove" class="col-span-2 inline-flex items-center justify-center h-9 rounded-md text-[var(--color-destructive)] hover:bg-[var(--color-accent-light)] self-end" aria-label="Retirer">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/></svg>
                    </button>
                </div>
            {% endfor %}
        </div>

        <template data-price-tiers-target="template">
            <div class="grid grid-cols-12 gap-2 items-center p-3 rounded-md border border-[var(--color-border-soft)]" data-price-tiers-target="row">
                <input type="hidden" name="tiers[__INDEX__][id]" value="">
                <label class="col-span-4 block">
                    <span class="text-[10px] uppercase tracking-wide text-[var(--color-secondary)]">À partir de</span>
                    <input type="number" min="1" name="tiers[__INDEX__][min_qty]" required class="form-input mt-1 text-right font-mono" placeholder="50">
                </label>
                <div class="col-span-1 text-center text-[var(--color-secondary)] pt-4">pièces</div>
                <label class="col-span-5 block">
                    <span class="text-[10px] uppercase tracking-wide text-[var(--color-secondary)]">Prix unitaire HT</span>
                    <div class="flex items-stretch mt-1 rounded-md border border-[var(--color-border)] bg-white focus-within:border-[var(--color-primary)] focus-within:ring-2 focus-within:ring-[var(--color-primary)]/20 overflow-hidden">
                        <input type="text" name="tiers[__INDEX__][price]" required class="flex-1 min-w-0 px-3 py-2 bg-transparent text-right font-mono text-sm focus:outline-none" placeholder="12,00">
                        <span class="flex items-center px-3 bg-[var(--color-muted)] text-[var(--color-secondary)] text-sm border-l border-[var(--color-border)]">€</span>
                    </div>
                </label>
                <button type="button" data-action="price-tiers#remove" class="col-span-2 inline-flex items-center justify-center h-9 rounded-md text-[var(--color-destructive)] hover:bg-[var(--color-accent-light)] self-end" aria-label="Retirer">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/></svg>
                </button>
            </div>
        </template>

        {% if tiers|default([])|length == 0 %}
            <p class="text-center text-sm text-[var(--color-secondary)] py-6">Aucun palier — le prix de base s'applique à toutes les quantités.</p>
        {% endif %}
    </section>

    {# Accès entreprises #}
    {% set current_ids = [] %}
    {% for c in product.allowedCompanies %}{% set current_ids = current_ids|merge([c.id]) %}{% endfor %}
    <section class="card p-6" data-controller="company-access"
             data-company-access-quick-create-url-value="{{ path('app_admin_company_quick_create') }}">
        <div class="flex items-center justify-between mb-4">
            <div>
                <h2 class="font-display font-semibold text-[var(--color-foreground)]">Entreprises qui ont accès</h2>
                <p class="text-xs text-[var(--color-secondary)] mt-0.5">Seuls les clients cochés verront ce produit dans leur catalogue. Aucune coche = invisible.</p>
            </div>
            <button type="button" data-action="click->company-access#open" class="btn btn-outline text-sm">
                Gérer les accès
                <span class="ml-2 inline-flex items-center justify-center min-w-[1.5rem] px-1.5 h-5 rounded-full bg-[var(--color-primary)] text-[var(--color-on-primary)] text-[11px] font-semibold" data-company-access-target="counter">{{ current_ids|length }}</span>
            </button>
        </div>

        <div data-company-access-target="summary" class="flex flex-wrap gap-1.5"></div>

        <div data-company-access-target="hiddenInputs">
            {% for id in current_ids %}
                <input type="hidden" name="company_access[]" value="{{ id }}">
            {% endfor %}
        </div>

        {# Modal #}
        <div data-company-access-target="modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
            <div data-company-access-target="backdrop" data-action="click->company-access#closeOnBackdrop"
                 class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
            <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-lg max-h-[85vh] flex flex-col">
                <div class="flex items-center justify-between p-5 border-b border-[var(--color-border)]">
                    <h3 class="font-display font-semibold text-[var(--color-foreground)]">Gérer les accès</h3>
                    <button type="button" data-action="click->company-access#close" class="w-8 h-8 flex items-center justify-center rounded-md text-[var(--color-secondary)] hover:bg-[var(--color-muted)]">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/></svg>
                    </button>
                </div>

                <div class="p-4 border-b border-[var(--color-border-soft)]">
                    <div class="relative">
                        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-[var(--color-secondary)]" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z"/></svg>
                        <input type="text" data-company-access-target="search" data-action="input->company-access#filter"
                               placeholder="Rechercher une entreprise ou un SIRET…"
                               class="form-input w-full pl-9 text-sm">
                    </div>
                </div>

                <div data-company-access-target="list" class="flex-1 overflow-y-auto p-2 space-y-0.5">
                    {% for c in all_companies|default([]) %}
                        {% set st = c.getAccessStatus(pending_company_ids[c.id]|default(false)) %}
                        {% set st_class = {
                            'active':   'text-emerald-700',
                            'inactive': 'text-[var(--color-secondary)]',
                            'invited':  'text-blue-700',
                            'orphan':   'text-amber-700',
                        }[st.key] %}
                        <label data-company-row
                               data-search-hay="{{ c.name }} {{ c.siret|default('') }}"
                               class="flex items-center gap-3 px-3 py-2 hover:bg-[var(--color-muted)] cursor-pointer rounded-md">
                            <input type="checkbox" value="{{ c.id }}"
                                   data-name="{{ c.name }}"
                                   data-status-key="{{ st.key }}"
                                   data-action="change->company-access#toggle"
                                   {% if c.id in current_ids %}checked{% endif %}
                                   class="w-4 h-4 rounded border-[var(--color-border)]">
                            <div class="flex-1 min-w-0">
                                <div class="text-sm font-medium text-[var(--color-foreground)] truncate">{{ c.name }}</div>
                                <div class="text-xs {{ st_class }}">{{ st.label }}{% if c.siret %} · <span class="text-[var(--color-secondary)]">{{ c.siret }}</span>{% endif %}</div>
                            </div>
                            {% if st.key == 'orphan' or st.key == 'invited' %}
                                <a href="{{ path('app_admin_invitation_new') }}?company={{ c.id }}"
                                   class="shrink-0 text-xs font-medium px-2 py-1 rounded-md border border-[var(--color-border-soft)] hover:bg-white hover:border-[var(--color-primary)] hover:text-[var(--color-primary)]"
                                   title="Créer une invitation pour cette entreprise"
                                   onclick="event.stopPropagation()">
                                    {{ st.key == 'orphan' ? 'Inviter' : 'Relancer' }}
                                </a>
                            {% endif %}
                        </label>
                    {% endfor %}
                </div>

                <div class="p-4 border-t border-[var(--color-border-soft)] bg-[var(--color-muted)]/30">
                    <details class="mb-3">
                        <summary class="cursor-pointer text-sm font-medium text-[var(--color-primary)] hover:underline">+ Créer une nouvelle entreprise</summary>
                        <div class="mt-3 grid grid-cols-1 sm:grid-cols-3 gap-2">
                            <input type="text" data-company-access-target="newName" placeholder="Nom *" class="form-input text-sm sm:col-span-1">
                            <input type="text" data-company-access-target="newSiret" placeholder="SIRET (optionnel)" class="form-input text-sm sm:col-span-1">
                            <button type="button" data-action="click->company-access#createNew" class="btn btn-primary text-sm sm:col-span-1">Créer + cocher</button>
                        </div>
                        <p data-company-access-target="newError" class="text-xs text-[var(--color-destructive)] mt-1"></p>
                    </details>

                    <div class="flex items-center justify-between gap-3 flex-wrap">
                        <div class="text-xs flex items-center gap-2 flex-wrap">
                            <span class="text-[var(--color-secondary)]"><span data-company-access-target="counter">{{ current_ids|length }}</span> sélectionnée(s)</span>
                            <span data-company-access-target="orphanWarning" class="hidden text-amber-700 font-medium">
                                · dont <span data-company-access-target="orphanCount">0</span> sans utilisateur à inviter
                            </span>
                        </div>
                        <div class="flex gap-2">
                            <button type="button" data-action="click->company-access#close" class="btn btn-outline text-sm">Annuler</button>
                            <button type="button" data-action="click->company-access#apply" class="btn btn-primary text-sm">Appliquer</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="flex gap-3">
        <button type="submit" class="btn btn-primary">
            {{ is_new ? 'Créer le produit (brouillon)' : 'Enregistrer' }}
        </button>
        <a href="{{ path('app_admin_products') }}" class="btn btn-outline">Annuler</a>
    </div>
</form>
{% endblock %}
