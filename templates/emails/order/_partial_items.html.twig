{# Tableau des articles — partagé entre email admin et client #}
<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" class="e-items" style="border-collapse: collapse; margin: 20px 0;">
    <thead>
        <tr>
            <th align="left" style="padding: 10px 12px; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .04em; color: #6b7280; border-bottom: 1px solid #e5e7eb;">Article</th>
            <th align="center" style="padding: 10px 8px; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .04em; color: #6b7280; border-bottom: 1px solid #e5e7eb;">Qté</th>
            <th align="right" style="padding: 10px 12px; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .04em; color: #6b7280; border-bottom: 1px solid #e5e7eb;">Sous-total</th>
        </tr>
    </thead>
    <tbody>
        {% for item in order.items %}
            {% set v = item.variant %}
            {% set p = v.product %}
            <tr>
                <td style="padding: 14px 12px; border-bottom: 1px solid #f0f0f0; vertical-align: top;">
                    <div class="e-item-name" style="font-weight: 600; color: #111; font-size: 14px;">{{ p.name }}</div>
                    <div style="margin-top: 4px; font-size: 12px; color: #6b7280;">
                        {% if v.colorHex %}<span style="display: inline-block; width: 10px; height: 10px; border-radius: 50%; background: {{ v.colorHex }}; border: 1px solid rgba(0,0,0,0.1); vertical-align: middle; margin-right: 4px;"></span>{% endif %}
                        <span style="vertical-align: middle;">{{ v.color }} · Taille {{ v.size }}</span>
                    </div>
                    <div style="margin-top: 2px; font-size: 11px; color: #9ca3af; font-family: Menlo, Monaco, Consolas, monospace;">SKU {{ v.sku }}</div>
                    {% if item.marking and (item.marking.position|default('') or item.marking.technique|default('')) %}
                        <div style="margin-top: 8px; padding: 6px 10px; background: #f9fafb; border-left: 3px solid #6366f1; font-size: 11px; color: #4b5563; display: inline-block; border-radius: 0 4px 4px 0;">
                            <strong style="color: #374151;">Marquage</strong>
                            {% if item.marking.technique|default('') %} · {{ item.marking.technique }}{% endif %}
                            {% if item.marking.position|default('') %} · {{ item.marking.position }}{% endif %}
                            {% if item.marking.size_cm|default('') %} · {{ item.marking.size_cm }} cm{% endif %}
                        </div>
                    {% endif %}
                </td>
                <td align="center" style="padding: 14px 8px; border-bottom: 1px solid #f0f0f0; vertical-align: top; font-size: 14px; color: #111; font-weight: 600;">
                    {{ item.quantity }}
                    <div style="font-size: 11px; font-weight: 400; color: #6b7280; margin-top: 2px;">× {{ item.unitPriceCents|price }}</div>
                </td>
                <td align="right" style="padding: 14px 12px; border-bottom: 1px solid #f0f0f0; vertical-align: top; font-size: 14px; color: #111; font-weight: 600; white-space: nowrap;">
                    {{ (item.unitPriceCents * item.quantity)|price }}
                </td>
            </tr>
        {% endfor %}
    </tbody>
    <tfoot>
        <tr>
            <td colspan="2" align="right" style="padding: 14px 12px 4px; font-size: 13px; color: #6b7280;">Total HT</td>
            <td align="right" style="padding: 14px 12px 4px; font-size: 18px; font-weight: 700; color: #111; white-space: nowrap;">{{ order.totalCents|price }}</td>
        </tr>
        <tr>
            <td colspan="3" align="right" style="padding: 0 12px 10px; font-size: 11px; color: #9ca3af;">{{ order.totalQuantity }} pièce{{ order.totalQuantity > 1 ? 's' }} · hors taxes</td>
        </tr>
    </tfoot>
</table>
