{% extends 'dashboard/_shell.html.twig' %}

{% block title %}Panier — Afdal{% endblock %}

{% block content %}
<div class="page-header flex flex-wrap items-end justify-between gap-4">
    <div>
        <p class="page-header__eyebrow">Commande</p>
        <h1 class="page-header__title">Panier</h1>
        <p class="text-sm text-[var(--color-secondary)] mt-1">{{ lines|length }} ligne{{ lines|length > 1 ? 's' : '' }} · {{ cart.count }} pièce{{ cart.count > 1 ? 's' : '' }}</p>
    </div>
    {% if lines is not empty %}
        <form method="post" action="{{ path('app_cart_clear') }}"
              data-controller="confirm"
              data-confirm-title-value="Vider le panier ?"
              data-confirm-message-value="Toutes les lignes du panier seront retirées."
              data-confirm-label-value="Vider le panier"
              data-action="submit->confirm#gate">
            <button type="submit" class="text-sm text-[var(--color-destructive)] hover:underline cursor-pointer">Vider le panier</button>
        </form>
    {% endif %}
</div>

{% set stock_issues = [] %}
{% for line in lines %}
    {% set s = line.variant.stock %}
    {% if s is not null and line.quantity > s %}
        {% set stock_issues = stock_issues|merge([line.variant.product.name ~ ' · ' ~ line.variant.color ~ ' · ' ~ line.variant.size ~ ' (' ~ line.quantity ~ ' demandé, ' ~ s ~ ' dispo)']) %}
    {% endif %}
{% endfor %}
{% if stock_issues|length > 0 %}
    <div class="mb-6 rounded-md border border-[var(--color-destructive)]/30 bg-[var(--color-destructive)]/5 p-4 flex items-start gap-3">
        <svg class="w-5 h-5 text-[var(--color-destructive)] shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/></svg>
        <div>
            <div class="font-medium text-[var(--color-destructive)]">Stock insuffisant</div>
            <ul class="text-sm text-[var(--color-secondary)] mt-1 list-disc ml-4 space-y-0.5">
                {% for issue in stock_issues %}<li>{{ issue }}</li>{% endfor %}
            </ul>
            <div class="text-sm text-[var(--color-secondary)] mt-2">Ajustez les quantités avant de passer commande.</div>
        </div>
    </div>
{% endif %}

{% if lines is empty %}
    <div class="bg-white rounded-xl border border-[var(--color-border)] shadow-sm p-12 text-center">
        <h2 class="text-lg font-semibold text-[var(--color-primary)] mb-1">Votre panier est vide</h2>
        <p class="text-sm text-[var(--color-secondary)] mb-6">Parcourez le catalogue pour ajouter des produits.</p>
        <a href="{{ path('app_catalogue') }}" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md bg-[var(--color-primary)] text-[var(--color-on-primary)] font-medium cursor-pointer transition-colors duration-200 hover:bg-[var(--color-secondary)]">Voir le catalogue</a>
    </div>
{% else %}
    <div class="bg-white rounded-xl border border-[var(--color-border)] shadow-sm overflow-hidden mb-6">
        <div class="hidden md:grid md:grid-cols-12 gap-4 px-4 py-3 bg-[var(--color-muted)] text-xs uppercase tracking-wide text-[var(--color-secondary)] font-medium">
            <div class="col-span-5">Produit</div>
            <div class="col-span-2">Marquage</div>
            <div class="col-span-2 text-right">Quantité</div>
            <div class="col-span-2 text-right">Total HT</div>
            <div class="col-span-1"></div>
        </div>
        <div class="divide-y divide-[var(--color-border)]">
            {% for line in lines %}
                <div class="grid grid-cols-1 md:grid-cols-12 gap-4 p-4 items-center">
                    <div class="md:col-span-5">
                        <div class="font-medium text-[var(--color-foreground)]">{{ line.variant.product.name }}</div>
                        <div class="text-sm text-[var(--color-secondary)] flex items-center gap-2 mt-1">
                            <span class="w-3 h-3 rounded-full border border-[var(--color-border)]" style="background-color: {{ line.variant.colorHex }}"></span>
                            {{ line.variant.color }} · {{ line.variant.size }}
                            <span class="font-mono text-xs">{{ line.variant.sku }}</span>
                        </div>
                    </div>
                    <div class="md:col-span-2 text-sm text-[var(--color-secondary)]">
                        {% if line.marking %}
                            {% set logo_path = line.marking.logo_path|default(null) %}
                            <div>{{ line.marking.zone|capitalize }} ({{ line.marking.size }})</div>
                            {% if logo_path %}
                                <div class="flex items-center gap-1.5 mt-1">
                                    {% if logo_path ends with '.pdf' %}
                                        <a href="{{ logo_path }}" target="_blank" rel="noopener" class="inline-flex items-center gap-1 text-[10px] uppercase tracking-wide font-semibold text-[var(--color-primary)] hover:underline">
                                            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/></svg>
                                            Logo PDF
                                        </a>
                                    {% else %}
                                        <a href="{{ logo_path }}" target="_blank" rel="noopener" class="w-8 h-8 rounded border border-[var(--color-border-soft)] bg-white overflow-hidden">
                                            <img src="{{ logo_path }}" alt="Logo" class="w-full h-full object-contain">
                                        </a>
                                    {% endif %}
                                    <span class="text-[10px] uppercase tracking-wide text-emerald-700 font-medium">Logo joint</span>
                                </div>
                            {% else %}
                                <div class="text-[10px] text-amber-700 mt-1">Logo à fournir après commande</div>
                            {% endif %}
                        {% else %}
                            <span class="text-[var(--color-secondary)]">—</span>
                        {% endif %}
                    </div>
                    <div class="md:col-span-2 md:text-right">
                        <form method="post" action="{{ path('app_cart_update', {lineId: line.line_id}) }}" class="inline-flex items-center gap-1">
                            <input type="number" name="quantity" min="1" value="{{ line.quantity }}"
                                {% if line.variant.stock is not null %}max="{{ line.variant.stock }}"{% endif %}
                                class="w-20 px-2 py-1 rounded-md border border-[var(--color-border)] text-right {{ line.variant.stock is not null and line.quantity > line.variant.stock ? 'border-[var(--color-destructive)]' : '' }}">
                            <button type="submit" class="text-xs text-[var(--color-accent)] hover:underline cursor-pointer">OK</button>
                        </form>
                        {% if line.variant.stock is not null %}
                            <div class="text-[10px] text-[var(--color-secondary)] mt-0.5">Stock : {{ line.variant.stock }}</div>
                        {% endif %}
                    </div>
                    <div class="md:col-span-2 md:text-right font-semibold">{{ line.subtotal_cents|price }}</div>
                    <div class="md:col-span-1 md:text-right">
                        <form method="post" action="{{ path('app_cart_remove', {lineId: line.line_id}) }}">
                            <button type="submit" class="text-sm text-[var(--color-destructive)] hover:underline cursor-pointer">Retirer</button>
                        </form>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>

    <div class="flex flex-col-reverse sm:flex-row items-center justify-between gap-4 bg-white rounded-xl border border-[var(--color-border)] shadow-sm p-4">
        <a href="{{ path('app_catalogue') }}" class="text-sm text-[var(--color-secondary)] hover:text-[var(--color-primary)]">&larr; Continuer mes achats</a>
        <div class="flex items-center gap-6">
            <div class="text-right">
                <div class="text-xs text-[var(--color-secondary)] uppercase tracking-wide">Total HT</div>
                <div class="text-2xl font-semibold text-[var(--color-primary)]">{{ total_cents|price }}</div>
            </div>
            {% if stock_issues|length > 0 %}
                <button type="button" disabled class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md bg-[var(--color-muted)] text-[var(--color-secondary)] font-medium cursor-not-allowed">
                    Stock insuffisant
                </button>
            {% else %}
                <a href="{{ path('app_checkout') }}" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md bg-[var(--color-primary)] text-[var(--color-on-primary)] font-medium cursor-pointer transition-colors duration-200 hover:bg-[var(--color-secondary)]">
                    Passer commande
                </a>
            {% endif %}
        </div>
    </div>
{% endif %}
{% endblock %}
