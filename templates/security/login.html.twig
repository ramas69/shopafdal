{% extends 'base.html.twig' %}

{% block title %}Connexion — Afdal{% endblock %}

{% block body %}
<div class="min-h-screen flex flex-col relative overflow-hidden">
    <div class="absolute inset-0 -z-10" aria-hidden="true">
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(3,105,161,0.06),transparent_60%)]"></div>
    </div>

    <header class="max-w-6xl mx-auto w-full px-6 py-6">
        <a href="{{ path('app_home') }}" class="inline-flex items-center gap-2">
            <div class="w-8 h-8 rounded-md bg-[var(--color-primary)] text-[var(--color-on-primary)] flex items-center justify-center font-display font-bold text-sm">A</div>
            <span class="font-display font-semibold text-[var(--color-foreground)]">Afdal</span>
        </a>
    </header>

    <main class="flex-1 flex items-center justify-center px-6 pb-12">
        <div class="w-full max-w-sm">
            <div class="text-center mb-8">
                <h1 class="font-display text-3xl font-semibold text-[var(--color-primary)] mb-2 tracking-tight">Connexion</h1>
                <p class="text-sm text-[var(--color-secondary)]">Accédez à votre espace commandes</p>
            </div>

            {% if error %}
                <div class="mb-4 p-3 rounded-md bg-red-50 border border-red-200 text-sm text-[var(--color-destructive)] flex items-start gap-2" role="alert">
                    <svg class="w-4 h-4 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z"/></svg>
                    <span>{{ error.messageKey|trans(error.messageData, 'security') }}</span>
                </div>
            {% endif %}

            <form method="post" class="space-y-4">
                <label class="block">
                    <span class="text-sm font-medium text-[var(--color-foreground)] mb-1.5 block">Email</span>
                    <input type="email" name="_username" value="{{ last_username }}" required autofocus autocomplete="email"
                        class="w-full px-3 py-2.5 rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] transition-colors focus:border-[var(--color-primary)] focus-visible:outline-2 focus-visible:outline-[var(--color-ring)] focus-visible:outline-offset-1">
                </label>

                <label class="block">
                    <span class="text-sm font-medium text-[var(--color-foreground)] mb-1.5 block">Mot de passe</span>
                    <input type="password" name="_password" required autocomplete="current-password"
                        class="w-full px-3 py-2.5 rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] transition-colors focus:border-[var(--color-primary)] focus-visible:outline-2 focus-visible:outline-[var(--color-ring)] focus-visible:outline-offset-1">
                </label>

                <label class="flex items-center gap-2 cursor-pointer py-1">
                    <input type="checkbox" name="_remember_me" class="rounded border-[var(--color-border)]">
                    <span class="text-sm text-[var(--color-secondary)]">Se souvenir de moi</span>
                </label>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <button type="submit" class="w-full inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-md bg-[var(--color-primary)] text-[var(--color-on-primary)] font-medium cursor-pointer transition-all duration-150 hover:bg-[#1F1F1F] active:scale-[0.99] focus-visible:outline-2 focus-visible:outline-[var(--color-ring)] focus-visible:outline-offset-2">
                    Se connecter
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
                </button>
            </form>

            <p class="mt-8 text-sm text-[var(--color-secondary)] text-center">
                Pas encore de compte ?
                <a href="mailto:contact@afdal.fr" class="text-[var(--color-primary)] font-medium hover:underline">Demandez une invitation</a>
            </p>
        </div>
    </main>
</div>
{% endblock %}
