{% extends 'layouts/auth.html.twig' %}

{% block title %}Invitation invalide — Afdal{% endblock %}

{% block auth_content %}
<div class="text-center space-y-4 mt-2">
    <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-[var(--color-destructive)]/8 text-[var(--color-destructive)] ring-1 ring-[var(--color-destructive)]/15">
        <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m0-10.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.75c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Zm0 13.036h.008v.008H12v-.008Z" />
        </svg>
    </div>
    <div>
        <h1 class="font-display text-xl font-semibold text-[var(--color-foreground)]">Invitation invalide ou expirée</h1>
        <p class="text-sm text-[var(--color-secondary)] mt-2">Le lien est introuvable, expiré ou a déjà été utilisé.</p>
    </div>
    <a href="mailto:contact@afdal.fr" class="btn btn-primary justify-center w-full sm:w-auto">
        Contacter Afdal
    </a>
</div>
{% endblock %}
