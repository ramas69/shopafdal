{% extends 'layouts/auth.html.twig' %}

{% block title %}Nouveau mot de passe — Afdal{% endblock %}

{% block auth_content %}
<div class="text-center">
    <h1 class="font-display text-2xl font-semibold text-[var(--color-navy-600)] tracking-tight">Nouveau mot de passe</h1>
    <p class="text-sm text-[var(--color-secondary)] mt-2">Choisissez un mot de passe d’au moins 8 caractères.</p>
</div>

<div class="mt-10 space-y-6">
    {{ form_start(resetForm, {'attr': {'class': 'space-y-4'}}) }}
        {{ form_row(resetForm.plainPassword, {'attr': {'class': 'form-input'}, 'label_attr': {'class': 'form-label'}}) }}
        <button type="submit" class="btn btn-primary w-full justify-center">Enregistrer</button>
    {{ form_end(resetForm) }}
</div>
{% endblock %}
