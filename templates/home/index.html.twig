{% extends 'base.html.twig' %}

{% block title %}Afdal — Plateforme B2B textile{% endblock %}

{% block body %}
<div class="min-h-screen relative overflow-hidden bg-[var(--color-background)]">
    <div class="absolute inset-0 -z-10" aria-hidden="true">
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(79,70,229,0.08),transparent_50%)]"></div>
    </div>

    <header class="max-w-7xl mx-auto px-6 py-6 flex items-center justify-between">
        <div class="flex items-center gap-2">
            <div class="w-9 h-9 rounded-lg bg-[var(--color-primary)] text-white flex items-center justify-center font-display font-bold">A</div>
            <span class="font-display font-semibold text-[var(--color-navy-700)]">Afdal</span>
        </div>
        <a href="{{ path('app_login') }}" class="btn btn-ghost text-sm">
            Se connecter
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
        </a>
    </header>

    <main class="max-w-5xl mx-auto px-6 pt-16 md:pt-24 pb-20">
        <div class="text-center">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-[var(--color-border)] bg-[var(--color-surface)] text-xs font-medium text-[var(--color-navy-500)] mb-8">
                <span class="relative flex w-1.5 h-1.5">
                    <span class="absolute inline-flex w-full h-full rounded-full bg-[var(--color-primary)] opacity-60 animate-ping"></span>
                    <span class="relative inline-flex rounded-full w-1.5 h-1.5 bg-[var(--color-primary)]"></span>
                </span>
                Plateforme sur invitation uniquement
            </div>

            <h1 class="font-display text-5xl md:text-7xl font-semibold tracking-tight mb-6 leading-[1.05] bg-gradient-to-br from-[var(--color-navy-700)] via-[var(--color-navy-700)] to-[var(--color-navy-700)]/50 bg-clip-text text-transparent">
                Commandes textile<br>
                sans friction.
            </h1>

            <p class="text-lg md:text-xl text-[var(--color-navy-400)] max-w-2xl mx-auto mb-10 leading-relaxed">
                Catalogue, configuration, suivi. Vos commandes et celles de vos antennes, centralisées dans un espace dédié.
            </p>

            <div class="flex flex-wrap gap-3 justify-center">
                <a href="{{ path('app_login') }}" class="btn btn-primary">
                    Accéder à mon espace
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
                </a>
                <a href="mailto:contact@afdal.fr" class="btn btn-outline">
                    Demander une invitation
                </a>
            </div>
        </div>

        <div class="mt-24 md:mt-32 grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6">
            {% set features = [
                { icon: 'shield', title: 'Sécurisé', desc: 'Accès nominatif par entreprise. Aucun accès public.' },
                { icon: 'users', title: 'Multi-antennes', desc: 'Un compte, plusieurs adresses de livraison.' },
                { icon: 'package', title: 'Sans paiement', desc: 'Facturation directe par Afdal. Pas de CB en ligne.' }
            ] %}
            {% for f in features %}
                <div class="card p-6">
                    <div class="w-10 h-10 rounded-lg bg-[var(--color-primary)]/10 flex items-center justify-center mb-4 text-[var(--color-primary)]">
                        {% if f.icon == 'shield' %}
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z"/></svg>
                        {% elseif f.icon == 'users' %}
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z"/></svg>
                        {% else %}
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m7.5 7.5-3.75 3.75m0 0 3.75 3.75m-3.75-3.75h13.5M16.5 7.5l3.75 3.75m0 0-3.75 3.75"/></svg>
                        {% endif %}
                    </div>
                    <h3 class="font-display font-semibold text-[var(--color-navy-700)] mb-1">{{ f.title }}</h3>
                    <p class="text-sm text-[var(--color-navy-400)] leading-relaxed">{{ f.desc }}</p>
                </div>
            {% endfor %}
        </div>
    </main>

    <footer class="border-t border-[var(--color-border)] py-6">
        <div class="max-w-7xl mx-auto px-6 text-center text-xs text-[var(--color-navy-400)]">
            &copy; {{ "now"|date('Y') }} Afdal · Plateforme B2B
        </div>
    </footer>
</div>
{% endblock %}
