{% extends 'base.html.twig' %}

{% block title %}Afdal — Espace professionnel textile{% endblock %}

{% block body %}
{# Fond vidéo + léger flou pour effet « tout en blur » (scale compense les bords) #}
<div class="fixed inset-0 z-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <div class="absolute inset-0 scale-[1.08] motion-reduce:scale-100 blur-sm sm:blur-[6px] motion-reduce:blur-none">
        <video class="h-full w-full object-cover object-center motion-reduce:hidden"
               autoplay muted loop playsinline preload="auto"
               poster="{{ asset('hero-home.jpg') }}">
            <source src="{{ asset('hero-mv.mp4') }}" type="video/mp4">
        </video>
        <div class="hidden motion-reduce:block absolute inset-0 bg-cover bg-center bg-no-repeat" style="background-image: url('{{ asset('hero-home.jpg') }}');"></div>
    </div>
</div>
{# Voiles légers : la lisibilité vient surtout du verre (backdrop-blur) sur le contenu #}
<div class="fixed inset-0 z-[1] bg-gradient-to-b from-slate-900/20 via-slate-900/5 to-white/75 pointer-events-none" aria-hidden="true"></div>
<div class="fixed inset-0 z-[1] bg-gradient-to-br from-[var(--color-primary)]/8 via-transparent to-[var(--color-primary-focus)]/10 pointer-events-none" aria-hidden="true"></div>

{# Premier écran : exactement 100dvh, vidéo visible derrière #}
<div class="relative z-10 min-h-[100dvh] flex flex-col">
    <header class="shrink-0 max-w-6xl mx-auto w-full px-5 sm:px-8 py-6 flex items-center justify-between gap-4">
        <a href="{{ path('app_home') }}" class="inline-flex items-center gap-2 rounded-2xl bg-white/35 backdrop-blur-2xl px-4 sm:px-5 py-3 sm:py-3.5 shadow-lg focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-ring)]">
            {% include '_partials/brand_logo.html.twig' with { class: 'h-16 sm:h-[4.5rem] w-auto max-h-[5rem]' } %}
        </a>
        <a href="{{ path('app_login') }}" class="btn btn-primary text-base font-medium gap-2 rounded-2xl px-6 py-3">
            Connexion
            <svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
        </a>
    </header>

    <section class="flex-1 flex flex-col justify-center px-4 sm:px-8 pb-16 sm:pb-20" aria-labelledby="home-hero-title">
        {# Proposition de valeur — verre flouté, typo grande #}
        <div class="text-center max-w-2xl mx-auto w-full rounded-[1.75rem] sm:rounded-[2rem] bg-white/30 backdrop-blur-2xl px-6 sm:px-10 md:px-12 py-8 sm:py-10 md:py-12 shadow-[0_8px_40px_rgba(15,23,42,0.12)]">
            <p class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/45 backdrop-blur-md text-[11px] sm:text-xs font-semibold uppercase tracking-[0.18em] text-slate-800 mb-6 sm:mb-8">
                <span class="relative flex w-1.5 h-1.5">
                    <span class="absolute inline-flex w-full h-full rounded-full bg-[var(--color-primary)] opacity-40 animate-ping"></span>
                    <span class="relative inline-flex rounded-full w-1.5 h-1.5 bg-[var(--color-primary)]"></span>
                </span>
                Plateforme client · Accès réservé
            </p>

            <h1 id="home-hero-title" class="font-display text-3xl sm:text-4xl md:text-5xl leading-[1.1] font-semibold tracking-[-0.025em] text-slate-950 mb-5 sm:mb-6 drop-shadow-sm">
                Bienvenue sur<br class="hidden sm:block">
                <span class="text-[var(--color-primary)]">l'espace Afdal.</span>
            </h1>

            <p class="text-sm sm:text-base md:text-lg text-slate-700 max-w-xl mx-auto mb-8 sm:mb-10 leading-relaxed">
                Accédez à votre catalogue, suivez vos commandes et validez vos marquages.
            </p>

            <div class="flex flex-col items-center gap-3">
                <a href="{{ path('app_login') }}" class="btn btn-primary justify-center px-8 py-3 text-sm sm:text-base rounded-xl shadow-lg">
                    Se connecter
                    <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
                </a>
                <p class="text-xs text-slate-600">
                    Pas encore d'accès ? <a href="mailto:contact@afdal.fr" class="font-medium text-[var(--color-primary)] hover:underline">Contactez votre interlocuteur Afdal</a>.
                </p>
            </div>
        </div>
    </section>
</div>

{# Footer minimaliste sur fond lisible #}
<footer class="relative z-10 bg-white/50 backdrop-blur-sm py-7">
    <div class="max-w-6xl mx-auto px-5 sm:px-8 flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-8 text-xs text-[var(--color-secondary)]">
        <span>&copy; {{ "now"|date('Y') }} Afdal</span>
        <span class="hidden sm:inline text-slate-300">·</span>
        <a href="{{ path('app_legal_mentions') }}" class="hover:text-[var(--color-primary)] transition-colors">Mentions légales</a>
        <a href="{{ path('app_legal_cgv') }}" class="hover:text-[var(--color-primary)] transition-colors">CGV</a>
    </div>
</footer>
{% endblock %}
