{% set registerUrl = url('app_register', {token: invitation.token}) %}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Invitation Afdal</title>
</head>
<body style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; max-width: 560px; margin: 0 auto; padding: 32px 24px; color: #111;">
    <h1 style="font-size: 22px; margin: 0 0 16px;">Bienvenue sur Afdal</h1>

    <p style="font-size: 15px; line-height: 1.55;">Bonjour,</p>

    <p style="font-size: 15px; line-height: 1.55;">
        {% if invitation.targetRole.value == 'ROLE_ADMIN' %}
            Vous avez été invité·e à rejoindre Afdal en tant qu'<strong>administrateur</strong>.
        {% elseif invitation.company %}
            L'équipe Afdal vous invite à rejoindre <strong>{{ invitation.company.name }}</strong> sur la plateforme de commandes textile Afdal.
        {% else %}
            L'équipe Afdal vous invite à rejoindre sa plateforme de commandes textile.
        {% endif %}
    </p>

    <p style="font-size: 15px; line-height: 1.55;">Cliquez sur le bouton ci-dessous pour créer votre compte :</p>

    <p style="margin: 28px 0;">
        <a href="{{ registerUrl }}" style="display: inline-block; background: #111; color: #fff; text-decoration: none; padding: 12px 24px; border-radius: 8px; font-weight: 600; font-size: 15px;">Créer mon compte</a>
    </p>

    <p style="font-size: 13px; color: #666; line-height: 1.55;">
        Ou copiez ce lien dans votre navigateur :<br>
        <a href="{{ registerUrl }}" style="color: #666; word-break: break-all;">{{ registerUrl }}</a>
    </p>

    <p style="font-size: 13px; color: #666; line-height: 1.55; margin-top: 24px;">
        Ce lien expire le {{ invitation.expiresAt|date('d/m/Y à H:i') }}.
    </p>

    <hr style="border: none; border-top: 1px solid #eee; margin: 32px 0 16px;">

    <p style="font-size: 12px; color: #999;">Afdal — Marquage textile professionnel</p>
</body>
</html>
