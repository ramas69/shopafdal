{% extends 'dashboard/_shell.html.twig' %}

{% block title %}Favoris — Afdal{% endblock %}

{% block content %}
<div class="mb-8 flex flex-wrap items-end justify-between gap-4">
    <div>
        <div class="text-xs font-medium text-[var(--color-secondary)] uppercase tracking-wide mb-1">Ma sélection</div>
        <h1 class="font-display text-2xl font-semibold text-[var(--color-foreground)]">{{ favorites|length }} favori{{ favorites|length > 1 ? 's' : '' }}</h1>
    </div>
</div>

{% if favorites is empty %}
    <div class="card p-12 text-center">
        <div class="w-16 h-16 rounded-full bg-[var(--color-muted)] flex items-center justify-center mx-auto mb-4 text-[var(--color-secondary)]">
            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z"/>
            </svg>
        </div>
        <h2 class="font-display text-lg font-semibold text-[var(--color-foreground)] mb-1">Aucun favori</h2>
        <p class="text-sm text-[var(--color-secondary)] mb-6">Cliquez sur le cœur d'un produit pour le retrouver ici.</p>
        <a href="{{ path('app_catalogue') }}" class="btn btn-primary">Parcourir le catalogue</a>
    </div>
{% else %}
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-x-6 gap-y-10">
        {% for fav in favorites %}
            {% set product = fav.product %}
            {% set is_out = product.isAllOutOfStock() %}
            {% set is_low = not is_out and product.hasLowStockVariant() %}
            {% set unique_colors = [] %}
            {% for v in product.variants %}
                {% if v.color not in unique_colors %}{% set unique_colors = unique_colors|merge([{name: v.color, hex: v.colorHex}]) %}{% endif %}
            {% endfor %}
            <div class="group relative flex flex-col bg-white rounded-lg ring-1 ring-[var(--color-border-soft)] overflow-hidden transition-shadow duration-200 hover:shadow-md {{ is_out ? 'opacity-70' : '' }}">
                <a href="{{ path('app_catalogue_detail', {slug: product.slug}) }}" class="block">
                    <div class="relative aspect-[3/4] overflow-hidden bg-white">
                        {% if product.imagePaths|length > 0 %}
                            <img src="{{ product.primaryImage }}" alt="{{ product.name }}"
                                 class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105 {{ is_out ? 'grayscale' : '' }}">
                        {% else %}
                            <div class="absolute inset-0 flex items-center justify-center">
                                <span class="font-display text-6xl font-bold text-slate-200">{{ product.name|first|upper }}</span>
                            </div>
                        {% endif %}
                        {% if is_out %}
                            <span class="absolute top-2.5 left-2.5 inline-flex items-center px-2 py-0.5 rounded text-[10px] font-semibold uppercase tracking-wider bg-[var(--color-destructive)] text-white">Rupture</span>
                        {% elseif is_low %}
                            <span class="absolute top-2.5 left-2.5 inline-flex items-center px-2 py-0.5 rounded text-[10px] font-semibold uppercase tracking-wider bg-amber-500 text-white">Stock limité</span>
                        {% endif %}
                    </div>
                </a>

                <button type="button"
                    data-controller="favorite-button"
                    data-favorite-button-url-value="{{ path('app_favorites_toggle', {id: product.id}) }}"
                    data-favorite-button-favorited-value="true"
                    data-action="click->favorite-button#toggle"
                    aria-pressed="true"
                    title="Retirer des favoris"
                    class="absolute top-2.5 right-2.5 w-9 h-9 rounded-full bg-white flex items-center justify-center shadow-sm hover:shadow-md transition-all text-[var(--color-destructive)]">
                    <svg data-favorite-button-target="icon" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z"/>
                    </svg>
                </button>

                <div class="flex flex-col gap-1 p-4 bg-white border-t border-[var(--color-border-soft)]">
                    {% if product.category %}
                        <p class="text-[11px] font-medium uppercase tracking-wider text-[var(--color-secondary)]">{{ product.category }}</p>
                    {% endif %}
                    <a href="{{ path('app_catalogue_detail', {slug: product.slug}) }}" class="font-medium text-[var(--color-foreground)] hover:text-[var(--color-primary)] transition-colors line-clamp-1">
                        {{ product.name }}
                    </a>
                    <p class="text-sm font-semibold text-[var(--color-foreground)]">{{ product.basePriceCents|price }}</p>
                    {% if unique_colors|length > 1 %}
                        <div class="flex items-center gap-1.5 mt-1">
                            {% for c in unique_colors|slice(0, 5) %}
                                <span class="w-3.5 h-3.5 rounded-full border border-[var(--color-border)]" style="background-color: {{ c.hex ?: '#e2e8f0' }}" title="{{ c.name }}"></span>
                            {% endfor %}
                            {% if unique_colors|length > 5 %}
                                <span class="text-[10px] text-[var(--color-secondary)]">+{{ unique_colors|length - 5 }}</span>
                            {% endif %}
                        </div>
                    {% endif %}
                </div>
            </div>
        {% endfor %}
    </div>
{% endif %}
{% endblock %}
